  statut        StatutActionRecouvrement @default(EN_COURS)
  notes         String?
  resultat      String?
  effectueParId Int?
  dateAction    DateTime                 @default(now())
  dateRelance   DateTime?

  financement OperationFinancementRIA @relation(fields: [financementId], references: [id])
  effectuePar User?                   @relation("ActionsRIAEffectuees", fields: [effectueParId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([financementId])
  @@index([statut])
  @@index([dateAction])
}

// ── Commissions Agents RIA ─────────────────────────────────────────────────────

enum StatutCommissionRIA {
  CALCULE
  APPROUVE
  PAYE
  ANNULE
}

model ConfigCommissionRIA {
  id          Int     @id @default(autoincrement())
  roleType    String  @unique // "AGENT_TERRAIN" | "CHEF_AGENCE" | "RPV_REGIONAL"
  tauxBase    Decimal @default(1.0) // % du montant recouvré
  description String?
  actif       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommissionAgentRIA {
  id     Int    @id @default(autoincrement())
  userId Int
  mois   Int
  annee  Int
  roleType String // "AGENT_TERRAIN" | "CHEF_AGENCE" | "RPV_REGIONAL"
  pdvId  Int?   // PDV concerné (pour chef agence / RPV)

  montantRecouvre      Decimal @default(0)
  nbDossiers           Int     @default(0)
  nbDossiersRembourses Int     @default(0)
  tauxSucces           Decimal @default(0)

  taux    Decimal @default(0)
  montant Decimal @default(0)

  statut          StatutCommissionRIA @default(CALCULE)
  approuveParId   Int?
  dateApprobation DateTime?
  datePaiement    DateTime?
  notes           String?

  user        User  @relation("CommissionsAgent",    fields: [userId],        references: [id])
  approuvePar User? @relation("CommissionsApprob",   fields: [approuveParId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, mois, annee, roleType])
  @@index([mois, annee])
  @@index([statut])
  @@index([userId])
}

// ── Documents Générés RIA ─────────────────────────────────────────────────────

enum TypeDocumentRIAGenere {
  CONTRAT_INVESTISSEUR
  RECU_INVESTISSEMENT
  ATTESTATION_INVESTISSEMENT
  RELEVE_PORTEFEUILLE
  RAPPORT_MENSUEL
  RAPPORT_ANNUEL
  RAPPORT_RENTABILITE
  RAPPORT_RISQUE
  ETAT_CREANCES
  RAPPORT_FINANCIER
}

model DocumentRIAGenere {
  id             Int                   @id @default(autoincrement())
  type           TypeDocumentRIAGenere
  titre          String
  contenu        String?               // HTML généré, stocké pour impression
  version        Int                   @default(1)

  investisseurId Int?
  portefeuilleId Int?
  depotId        Int?
  mois           Int?
  annee          Int?

  genereParId    Int
  archive        Boolean               @default(false)

  investisseur ProfilInvestisseurRIA? @relation(fields: [investisseurId], references: [id])
  portefeuille PortefeuilleRIA?       @relation(fields: [portefeuilleId], references: [id])
  generePar    User                   @relation("DocumentsRIAGeneres", fields: [genereParId], references: [id])

  createdAt DateTime @default(now())

  @@index([type])
  @@index([investisseurId])
  @@index([portefeuilleId])
  @@index([createdAt])
}

// ── Alertes Automatiques RIA ───────────────────────────────────────────────────

model ConfigAlerteRIA {
  id          Int      @id @default(autoincrement())
  cle         String   @unique
  valeur      String   // valeur numérique sérialisée
  description String?
  updatedAt   DateTime @updatedAt
}

// ── Gouvernance des Commissions RIA ──────────────────────────────────────────

enum TypeCommissionRIA {
  FINANCE
  OPERATIONS_TERRAIN
  AUDIT
  OPTIMISATION
}

enum RoleMembreCommissionRIA {
  PRESIDENT
  VICE_PRESIDENT
  SECRETAIRE
  TRESORIER
  MEMBRE
  RAPPORTEUR_1   // Prépare dossiers, analyses, brouillons, rapports — ne valide pas
  RAPPORTEUR_2   // Vérifie dossiers, modifie analyses, produit observations — ne valide pas
}

enum StatutReunionCommissionRIA {
  PLANIFIEE
  EN_COURS
  TENUE
  ANNULEE
  REPORTEE
}

enum StatutResolutionRIA {
  EN_ATTENTE
  APPROUVEE
  REJETEE
  EN_APPLICATION
  APPLIQUEE
  EN_PREPARATION  // CDC — résolution en cours de rédaction
  SOUMISE         // CDC — soumise au vote
  ADOPTEE         // CDC — adoptée par vote
  EXECUTEE        // CDC — entièrement mise en œuvre
}

enum StatutPlanActionCommRIA {
  A_FAIRE
  EN_COURS
  TERMINE
  ABANDONNE
  NON_DEMARRE  // CDC — tâche créée mais pas encore démarrée
  REALISE      // CDC — alias TERMINE (CDC)
  EN_RETARD    // CDC — échéance dépassée sans complétion
}

enum PrioriteActionRIA {
  CRITIQUE
  HAUTE
  MOYENNE
  BASSE
}

model MembreCommissionRIA {
  id             Int                     @id @default(autoincrement())
  typeCommission TypeCommissionRIA
  userId         Int
  role           RoleMembreCommissionRIA @default(MEMBRE)
  dateEntree     DateTime                @default(now())
  dateSortie     DateTime?
  actif          Boolean                 @default(true)
  notes          String?

  user           User                    @relation("MembresCommissionRIA", fields: [userId], references: [id])

  presences      PresenceReunionRIA[]

  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@unique([typeCommission, userId])
  @@index([typeCommission])
  @@index([userId])
}

model ReunionCommissionRIA {
  id             Int                        @id @default(autoincrement())
  typeCommission TypeCommissionRIA
  titre          String
  dateHeure      DateTime
  lieu           String?
  ordreJour      String?                    // Texte libre ou JSON
  statut         StatutReunionCommissionRIA @default(PLANIFIEE)
  compteRendu    String?

  // Visioconférence (réunion à distance)
  salleVisio     String?                    // Salle Jitsi intégrée (générée à la création) — réunion DANS l'appli
  lienVisio      String?                    // Lien externe optionnel (Google Meet / Zoom / Teams)

  // Convocation (CDC)
  convocationEnvoyee Boolean   @default(false)
  dateConvocation    DateTime?

  organisateurId Int

  organisateur   User                       @relation("ReunionsOrganisees", fields: [organisateurId], references: [id])
  presences      PresenceReunionRIA[]
  resolutions    ResolutionCommRIA[]
  plansAction    PlanActionCommRIA[]        // tâches issues de la réunion (CDC)
  compteRenduStr CompteRenduReunionRIA?     // compte rendu structuré

  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@index([typeCommission])
  @@index([statut])
  @@index([dateHeure])
}

model PresenceReunionRIA {
  id          Int                  @id @default(autoincrement())
  reunionId   Int
  membreId    Int
  present     Boolean              @default(true)
  excuse      Boolean              @default(false)   // absent mais excusé
  procuration Boolean              @default(false)
  notes       String?

  // Signature numérique (CDC)
  signatureNumerique Boolean   @default(false)
  dateSignature      DateTime?
  signatureToken     String?   // token unique généré pour valider la signature

  reunion    ReunionCommissionRIA @relation(fields: [reunionId], references: [id], onDelete: Cascade)
  membre     MembreCommissionRIA  @relation(fields: [membreId], references: [id])

  @@unique([reunionId, membreId])
  @@index([reunionId])
}

model ResolutionCommRIA {
  id             Int                   @id @default(autoincrement())
  reunionId      Int?
  typeCommission TypeCommissionRIA
  numero         String                @unique
  titre          String
  description    String?
  statut         StatutResolutionRIA   @default(EN_ATTENTE)
  dateEcheance   DateTime?
  responsableId  Int?

  reunion        ReunionCommissionRIA? @relation(fields: [reunionId], references: [id])
  responsable    User?                 @relation("ResolutionsResponsable", fields: [responsableId], references: [id])
  plansAction    PlanActionCommRIA[]
  analyseOptimisation AnalyseOptimisationRIA?

  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([typeCommission])
  @@index([statut])
}

model PlanActionCommRIA {
  id             Int                     @id @default(autoincrement())
  resolutionId   Int?
  reunionId      Int?                    // réunion d'origine — tâche créée à l'issue de la réunion (CDC)
  typeCommission TypeCommissionRIA
  titre          String
  description    String?
  priorite       PrioriteActionRIA       @default(MOYENNE)
  statut         StatutPlanActionCommRIA @default(A_FAIRE)
  responsableId  Int?
  dateDebut      DateTime?
  dateEcheance   DateTime?
  dateTermine    DateTime?
  progression    Int                     @default(0) // 0-100 %
  notes          String?

  resolution     ResolutionCommRIA?      @relation(fields: [resolutionId], references: [id])
  reunion        ReunionCommissionRIA?   @relation(fields: [reunionId], references: [id])
  responsable    User?                   @relation("PlansActionResponsable", fields: [responsableId], references: [id])

  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([typeCommission])
  @@index([statut])
  @@index([priorite])
  @@index([reunionId])
}

// ── Gouvernance RIA — Nouveaux enums (CDC) ────────────────────────────────────

enum StatutDossierInterCommission {
  EN_PREPARATION
  TRANSMIS
  RECU
  EN_ANALYSE
  EN_ATTENTE_DECISION
  APPROUVE            // « Financement autorisé » — décision du Président réceptrice
  REJETE
  EN_COURS_EXECUTION  // décaissé + clients affectés, financement actif
  EXECUTE             // dossier clôturé/terminé
}

enum TypeDossierIC {
  DEMANDE_FINANCEMENT
  RAPPORT_AUDIT
  RECOMMANDATION
  PLAN_ACTION
  AUTRE
}

enum TypeEchangeIC {
  OBSERVATION
  DEMANDE_AJUSTEMENT
  VALIDATION
  REJET
  INFORMATION
  RETOUR_DOSSIER
}

enum TypeObservationComm {
  COMMENTAIRE
  PLANIFICATION
  DOCUMENT
  DISCUSSION
  ALERTE
}

enum TypeRapportCommRIA {
  MENSUEL
  TRIMESTRIEL
  ANNUEL
  AUDIT
  EXCEPTIONNEL
}

enum StatutRapportCommRIA {
  BROUILLON
  SOUMIS
  VALIDE
  ARCHIVE
}

enum NiveauAnomalieCommRIA {
  MINEURE
  MAJEURE
  CRITIQUE
}

// ── Gouvernance RIA — Nouveaux modèles (CDC) ──────────────────────────────────

// Compte rendu structuré d'une réunion (décisions / recommandations / actions)
model CompteRenduReunionRIA {
  id              Int                  @id @default(autoincrement())
  reunionId       Int                  @unique
  decisions       String?
  recommandations String?
  actionsDefinies String?
  observations    String?
  valideParId     Int?
  dateValidation  DateTime?

  reunion   ReunionCommissionRIA @relation(fields: [reunionId], references: [id], onDelete: Cascade)
  validePar User?                @relation("CRValidesPar", fields: [valideParId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Dossiers de travail inter-commissions (workflow CDC Scénarios 1-4)
model DossierInterCommission {
  id                   Int                          @id @default(autoincrement())
  reference            String                       @unique // DIC-2026-00001
  type                 TypeDossierIC
  titre                String
  description          String?
  statut               StatutDossierInterCommission @default(EN_PREPARATION)

  commissionEmettrice  TypeCommissionRIA
  commissionReceptrice TypeCommissionRIA

  // Données financières (pour DEMANDE_FINANCEMENT)
  montantDemande  Decimal?
  montantApprouve Decimal?

  // Portefeuille choisi par le Président Finance à l'approbation, utilisé par EXECUTER
  portefeuilleExecutionId Int?
  portefeuilleExecution   PortefeuilleRIA? @relation("DossiersICPortefeuilleExecution", fields: [portefeuilleExecutionId], references: [id])

  versionCourante Int @default(1)

  creeParId   Int
  valideParId Int?
  dateValidation DateTime?

  creePar   User  @relation("DossiersICCrees",  fields: [creeParId],   references: [id])
  validePar User? @relation("DossiersICValides", fields: [valideParId], references: [id])

  versions VersionDossierIC[]
  echanges EchangeInterCommission[]
  missionsAudit MissionAuditRIA[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([commissionEmettrice])
  @@index([commissionReceptrice])
  @@index([type])
  @@index([portefeuilleExecutionId])
}

// Historique versionné des modifications d'un dossier inter-commissions
model VersionDossierIC {
  id           Int                    @id @default(autoincrement())
  dossierId    Int
  version      Int
  contenu      Json                   // snapshot structuré du dossier à cette version
  motif        String?
  modifieParId Int

  dossier    DossierInterCommission @relation(fields: [dossierId],    references: [id], onDelete: Cascade)
  modifiePar User                   @relation("VersionsDossiersIC",  fields: [modifieParId], references: [id])

  createdAt DateTime @default(now())

  @@unique([dossierId, version])
  @@index([dossierId])
}

// Échanges entre commissions sur un dossier (observations, demandes d'ajustement, rejets…)
model EchangeInterCommission {
  id          Int                    @id @default(autoincrement())
  dossierId   Int
  auteurId    Int
  commission  TypeCommissionRIA
  type        TypeEchangeIC
  contenu     String
  pieceJointeUrl String?

  dossier DossierInterCommission @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  auteur  User                   @relation("EchangesICAuteur", fields: [auteurId], references: [id])

  createdAt DateTime @default(now())

  @@index([dossierId])
  @@index([auteurId])
  @@index([commission])
}

// Espace de collaboration interne (discussions, planification, documents) par commission
model ObservationCommissionRIA {
  id             Int                 @id @default(autoincrement())
  typeCommission TypeCommissionRIA
  auteurId       Int
  type           TypeObservationComm
  contenu        String
  pieceJointeUrl String?
  epingle        Boolean             @default(false)

  auteur User @relation("ObservationsCommRIA", fields: [auteurId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([typeCommission])
  @@index([auteurId])
  @@index([typeCommission, epingle])
}

// Rapports de gouvernance produits par les commissions (mensuel, trimestriel, audit…)
model RapportCommissionRIA {
  id             Int                  @id @default(autoincrement())
  typeCommission TypeCommissionRIA
  type           TypeRapportCommRIA
  titre          String
  contenu        Json?                // données structurées (KPIs, tableaux…)
  contenuHtml    String?              // HTML rendu pour impression
  statut         StatutRapportCommRIA @default(BROUILLON)
  periode        String?              // ex: "2026-06" | "T2-2026"
  redacteurId    Int?
  valideParId    Int?
  dateValidation DateTime?

  redacteur User? @relation("RapportsCommRediges", fields: [redacteurId], references: [id])
  validePar User? @relation("RapportsCommValides", fields: [valideParId], references: [id])
  analysesOptimisation AnalyseOptimisationRIA[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([typeCommission])
  @@index([type])
  @@index([statut])
  @@index([periode])
}

// Anomalies détectées automatiquement par le système (Centre d'Intelligence Décisionnelle)
model AnomalieGouvRIA {
  id             Int                   @id @default(autoincrement())
  typeCommission TypeCommissionRIA?    // null = visible par toutes les commissions
  niveau         NiveauAnomalieCommRIA @default(MINEURE)
  titre          String
  description    String
  donnees        Json?                 // contexte : IDs, montants, références concernés
  resolue        Boolean               @default(false)
  dateResolution DateTime?
  resolueParId   Int?

  resoluepar User? @relation("AnomaliesRIAResolues", fields: [resolueParId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([typeCommission])
  @@index([niveau])
  @@index([resolue])
  @@index([createdAt])
}

// ── Commission Audit & Contrôle — Mission d'audit (CDC) ───────────────────
enum StatutMissionAuditRIA {
  OUVERTE
  EN_COURS
  CLOTUREE
}

enum ResultatMissionAuditRIA {
  CONFORME
  NON_CONFORME
}

enum NiveauRisqueMissionAuditRIA {
  RISQUE_MINEUR
  RISQUE_MAJEUR
  FRAUDE_SUSPECTEE
}

// "La Commission Audit ne valide pas. Elle contrôle." — pas de gating Président,
// checklist libre en Json (contenu variable selon la cible auditée)
model MissionAuditRIA {
  id            Int                    @id @default(autoincrement())
  reference     String                 @unique // AUD-2026-00001
  objet         String
  financementId Int?
  dossierICId   Int?
  statut        StatutMissionAuditRIA  @default(OUVERTE)
  checklist     Json                   // [{ id, question, reponse: "OUI"|"NON"|null, commentaire }]
  resultat      ResultatMissionAuditRIA?
  niveauRisque  NiveauRisqueMissionAuditRIA?
  conclusion    String?
  auditeurId    Int
  dateCloture   DateTime?

  financement OperationFinancementRIA? @relation(fields: [financementId], references: [id])
  dossierIC   DossierInterCommission?  @relation(fields: [dossierICId],   references: [id])
  auditeur    User                     @relation("MissionsAuditRIAAuditeur", fields: [auditeurId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([financementId])
  @@index([dossierICId])
}

// ── Commission Optimisation des Processus — Analyse d'optimisation (CDC) ──
enum TypeConstatOptimisationRIA {
  LENTEUR
  DOUBLON
  PERTE
  SURCOUT
  RISQUE
  AUTRE
}

enum TypeRecommandationOptimisationRIA {
  VALIDATION_NUMERIQUE
  CIRCUIT_SIMPLIFIE
  AUTOMATISATION_CONTROLES
  AUTRE
}

enum StatutAnalyseOptimisationRIA {
  OUVERTE
  EN_COURS
  TRAITEE
}

// "Identifier les lenteurs, doublons, pertes, surcoûts, risques" à partir des
// rapports Finance/Audit/Terrain reçus automatiquement — pas de gating Président
model AnalyseOptimisationRIA {
  id               Int                         @id @default(autoincrement())
  reference        String                      @unique // OPT-2026-00001
  rapportId        Int?
  constat          TypeConstatOptimisationRIA
  analyse          String                      // ex: "Le délai moyen d'approbation est de 12 jours."
  indicateurActuel String?                     // ex: "12 jours"
  objectifCible    String?                     // ex: "3 jours"
  recommandation       TypeRecommandationOptimisationRIA?
  recommandationDetail String?
  statut           StatutAnalyseOptimisationRIA @default(OUVERTE)
  analysteId       Int
  resolutionId     Int?                        @unique // lien si transformée en suggestion

  rapport    RapportCommissionRIA? @relation(fields: [rapportId],    references: [id])
  analyste   User                  @relation("AnalysesOptimisationRIAAnalyste", fields: [analysteId], references: [id])
  resolution ResolutionCommRIA?    @relation(fields: [resolutionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([rapportId])
}

// ============================================================
// MODULE COMPTE COURANT CLIENT (portefeuille interne / Wallet AfriSime)
// ============================================================

enum StatutCompteCourant {
  ACTIF
  SUSPENDU
  CLOTURE
  DECEDE
  BLACKLIST
  FRAUDULEUX
}

enum NatureMouvementCC {
  DEPOT
  RETRAIT
  PAIEMENT_CREDIT
  PAIEMENT_COMPTANT
  CORRECTION
  ANNULATION
  TRANSFERT
}

enum StatutMouvementCC {
  VALIDE
  EN_ATTENTE
  ANNULE
}

// Nature du titulaire d'un compte courant (CDC §19.A : individuel ou collectif)
enum TypeCompteCC {
  INDIVIDUEL   // une seule personne
  MENAGE       // un foyer / une famille
  COMMUNAUTE   // une communauté
  GROUPEMENT   // un groupement (tontine, coopérative, association…)
}

// Rôle d'un client au sein d'un compte courant collectif (CDC §19.A)
enum RoleMembreCC {
  TITULAIRE    // représentant principal du compte (obligatoire, unique par compte)
  MANDATAIRE   // habilité à opérer sur le compte pour le compte du groupe
  MEMBRE       // membre / bénéficiaire simple
}

// Fréquence de cotisation d'un plan d'épargne programmée (CDC §19.B)
enum FrequenceEpargne {
  QUOTIDIENNE
  HEBDOMADAIRE
  MENSUELLE
}

// Statut d'un plan d'épargne programmée (CDC §19.B)
enum StatutPlanEpargne {
  EN_COURS     // en cours de constitution
  ATTEINT      // objectif atteint
  ABANDONNE    // arrêté volontairement
  EXPIRE       // échéance dépassée sans objectif atteint
}

// Niveau de fidélité d'un client (CDC §19.D) — débloque des avantages croissants.
enum NiveauFidelite {
  BRONZE
  ARGENT
  OR
  PLATINE
}

// Nature d'un mouvement de points de fidélité (CDC §19.D)
enum TypeTransactionFidelite {
  GAIN        // points gagnés sur un dépôt
  BONUS       // bonus manuel (régularité, geste commercial)
  DEPENSE     // points échangés (cadeau, avantage)
  AJUSTEMENT  // correction manuelle (+/−)
}

// Statut d'un blocage volontaire d'épargne (CDC §19.E)
enum StatutBlocageEpargne {
  ACTIF     // fonds indisponibles
  LIBERE    // échéance atteinte ou déblocage anticipé
  ANNULE    // blocage annulé (créé par erreur)
}

// Paramétrage général du module (enregistrement unique, id = 1)
model ParametrageCompteCourant {
  id                    Int      @id @default(1)
  montantMinOuverture   Decimal  @default(500)
  soldeMinObligatoire   Decimal  @default(500)
  depotMin              Decimal  @default(500)
  depotMax              Decimal?
  retraitMin            Decimal?
  retraitMax            Decimal?
  soldeMaxAutorise      Decimal?
  autoriserSoldeNegatif Boolean  @default(false)
  nbRetraitsMaxParMois  Int?
  dureeInactiviteJours  Int      @default(180)
  joursAlerteAvantSuspension Int @default(15) // délai d'alerte préventive avant suspension pour inactivité (CDC §14)
  codeAgence            String   @default("TG-228")
  codeGuichet           String   @default("Afrs001")
  // Plan comptable (numéros de compte utilisés pour les écritures automatiques)
  compteCaisseNumero        String @default("571") // Caisse
  compteCourantClientNumero String @default("419") // Clients créditeurs (compte courant)
  compteVentesNumero        String @default("701") // Ventes (contrepartie paiement)
  updatedAt             DateTime @updatedAt
}

// Compte courant : un par client
model CompteCourant {
  id                  Int                 @id @default(autoincrement())
  numeroCompte        String              @unique // 12 chiffres, commence par 12
  cleRib              String                      // 2 chiffres (contrôle mod 97)
  codeAgence          String
  codeGuichet         String
  ribComplet          String                      // ex: "TG-228 Afrs001 12XXXXXXXXXX 87"

  // Titulaire principal (représentant). N'est plus @unique : un client peut être
  // titulaire de son compte individuel ET représentant d'un compte collectif (CDC §19.A).
  // L'unicité « un seul compte INDIVIDUEL par client » est garantie au niveau applicatif.
  clientId            Int
  client              Client              @relation(fields: [clientId], references: [id])

  typeCompte          TypeCompteCC        @default(INDIVIDUEL) // individuel ou collectif (CDC §19.A)
  libelle             String?                                  // nom du ménage / communauté / groupement (comptes collectifs)
  membres             MembreCompteCourant[]                    // membres du compte (au moins le titulaire)
  plansEpargne        PlanEpargne[]                            // plans d'épargne programmée (CDC §19.B)
  autorisationsPrelevement AutorisationPrelevement[]           // prélèvements automatiques (CDC §19.C)
  blocagesEpargne     BlocageEpargne[]                         // blocages volontaires d'épargne (CDC §19.E)

  dateOuverture       DateTime            @default(now())
  agentCreateurId     Int
  agentCreateur       User                @relation("CCCreateur", fields: [agentCreateurId], references: [id])

  statut              StatutCompteCourant @default(ACTIF)
  motifBlocage        String?

  solde               Decimal             @default(0)
  totalDepose         Decimal             @default(0)
  totalRetire         Decimal             @default(0)
  totalUtilise        Decimal             @default(0)
  nbMouvements        Int                 @default(0)
  derniereOperationAt DateTime?

  mouvements          MouvementCompteCourant[]

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([statut])
  @@index([clientId])
  @@index([typeCompte])
}

// Membre d'un compte courant (CDC §19.A — comptes collectifs : ménage, communauté, groupement).
// Un compte individuel a un unique membre (le titulaire) ; un compte collectif en a plusieurs.
model MembreCompteCourant {
  id          Int           @id @default(autoincrement())
  compteId    Int
  compte      CompteCourant @relation(fields: [compteId], references: [id], onDelete: Cascade)
  clientId    Int
  client      Client        @relation("MembreCC", fields: [clientId], references: [id])
  role        RoleMembreCC  @default(MEMBRE)
  quotePart   Decimal?                       // quote-part indicative (%) du membre dans le compte collectif
  ajouteParId Int?
  ajoutePar   User?         @relation("MembreCCAjoutePar", fields: [ajouteParId], references: [id])
  createdAt   DateTime      @default(now())

  @@unique([compteId, clientId])             // un client n'apparaît qu'une fois par compte
  @@index([compteId])
  @@index([clientId])
}

// Plan d'épargne programmée (CDC §19.B) : objectif chiffré + cotisation périodique.
// Les cotisations sont des dépôts (MouvementCompteCourant.nature = DEPOT) fléchés
// vers le plan via planEpargneId ; montantCumule est le cumul mis en cache.
model PlanEpargne {
  id                Int               @id @default(autoincrement())
  compteId          Int
  compte            CompteCourant     @relation(fields: [compteId], references: [id], onDelete: Cascade)
  libelle           String                              // ex. « Achat moto », « Rentrée scolaire »
  objectifMontant   Decimal
  frequence         FrequenceEpargne
  montantCotisation Decimal                             // montant conseillé par période
  dateDebut         DateTime          @default(now())
  dateEcheance      DateTime
  montantCumule     Decimal           @default(0)       // cumul des cotisations fléchées (cache)
  statut            StatutPlanEpargne @default(EN_COURS)
  dateAtteint       DateTime?                           // date d'atteinte de l'objectif
  observation       String?

  creeParId         Int
  creePar           User              @relation("PlanEpargneCreePar", fields: [creeParId], references: [id])

  cotisations       MouvementCompteCourant[] @relation("CotisationsPlan")

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([compteId])
  @@index([statut])
}

// Autorisation de prélèvement automatique (CDC §19.C) : le client autorise le
// système à débiter son compte courant pour régler les échéances d'un crédit.
model AutorisationPrelevement {
  id                   Int          @id @default(autoincrement())
  compteId             Int
  compte               CompteCourant @relation(fields: [compteId], references: [id], onDelete: Cascade)
  creditId             Int          @unique          // une seule autorisation par crédit
  credit               CreditClient @relation(fields: [creditId], references: [id], onDelete: Cascade)
  actif                Boolean      @default(true)
  montantMax           Decimal?                       // plafond prélevé par exécution (null = montant de l'échéance due)
  montantMinSolde      Decimal?                       // solde plancher à préserver (null = soldeMinObligatoire du paramétrage)
  dernierPrelevementAt DateTime?
  totalPreleve         Decimal      @default(0)
  nbPrelevements       Int          @default(0)

  creeParId            Int
  creePar              User         @relation("PrelevementAutoCreePar", fields: [creeParId], references: [id])

  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([compteId])
  @@index([actif])
}

// Paramétrage du programme de fidélité (CDC §19.D) — enregistrement unique id=1.
model ProgrammeFidelite {
  id                    Int      @id @default(1)
  actif                 Boolean  @default(true)
  pointsParMontant      Int      @default(1000) // 1 point par tranche de X FCFA déposé
  bonusParDepot         Int      @default(0)    // points bonus fixes par dépôt (récompense la régularité)
  seuilArgent           Int      @default(500)  // points cumulés pour atteindre chaque niveau
  seuilOr               Int      @default(2000)
  seuilPlatine          Int      @default(5000)
  reductionFraisArgent  Int      @default(0)     // % de réduction des frais de dossier par niveau
  reductionFraisOr      Int      @default(5)
  reductionFraisPlatine Int      @default(10)
  updatedAt             DateTime @updatedAt
}

// Compte de fidélité d'un client (CDC §19.D) — solde de points + niveau.
model CompteFidelite {
  id            Int             @id @default(autoincrement())
  clientId      Int             @unique
  client        Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  soldePoints   Int             @default(0) // points disponibles (gagnés − dépensés)
  totalGagnes   Int             @default(0) // cumul gagné (détermine le niveau, jamais décrémenté)
  totalUtilises Int             @default(0)
  niveau        NiveauFidelite  @default(BRONZE)
  transactions  TransactionFidelite[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([niveau])
}

// Grand livre des points de fidélité (CDC §19.D).
model TransactionFidelite {
  id               Int                     @id @default(autoincrement())
  compteFideliteId Int
  compteFidelite   CompteFidelite          @relation(fields: [compteFideliteId], references: [id], onDelete: Cascade)
  type             TypeTransactionFidelite
  points           Int                              // signé : + gain/bonus, − dépense
  motif            String
  source           String?                          // DEPOT, COTISATION, MANUEL, CADEAU…
  mouvementId      Int?                             // lien vers le dépôt source éventuel
  creeParId        Int?
  creePar          User?                   @relation("TransactionFideliteCreePar", fields: [creeParId], references: [id])
  createdAt        DateTime                @default(now())

  @@index([compteFideliteId])
  @@index([createdAt])
}

// Blocage volontaire d'épargne (CDC §19.E) : le client rend une partie de son
// solde indisponible jusqu'à une date (préparation d'un achat important). Le
// montant bloqué actif est déduit du solde disponible pour toute sortie.
model BlocageEpargne {
  id            Int                 @id @default(autoincrement())
  compteId      Int
  compte        CompteCourant       @relation(fields: [compteId], references: [id], onDelete: Cascade)
  montant       Decimal
  motif         String?
  dateBlocage   DateTime            @default(now())
  dateDeblocage DateTime                                 // date d'échéance du blocage
  statut        StatutBlocageEpargne @default(ACTIF)
  libereLe      DateTime?                                // date effective de libération (auto ou anticipée)

  creeParId     Int
  creePar       User                @relation("BlocageEpargneCreePar", fields: [creeParId], references: [id])

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([compteId])
  @@index([statut])
  @@index([dateDeblocage])
}

// Grand livre des mouvements d'un compte courant
model MouvementCompteCourant {
  id           Int               @id @default(autoincrement())
  reference    String            @unique
  compteId     Int
  compte       CompteCourant     @relation(fields: [compteId], references: [id])
  nature       NatureMouvementCC
  montant      Decimal                          // signé : + entrée, − sortie
  soldeAvant   Decimal
  soldeApres   Decimal
  modePaiement String?
  observation  String?
  statut       StatutMouvementCC @default(VALIDE)

  userId       Int?
  user         User?             @relation("CCMouvementUser", fields: [userId], references: [id])
  agence       String?

  // Métadonnées de collecte optionnelles (parité avec les remboursements de crédit) :
  // n° de jour de collecte, date effective du dépôt, et agent l'ayant physiquement apporté.
  numeroJour       Int?
  dateOperation    DateTime?
  agentApporteurId Int?
  agentApporteur   User?             @relation("CCMouvementAgentApporteur", fields: [agentApporteurId], references: [id])

  ecritureId   Int?                             // lien Comptabilité (lots suivants)
  venteId      Int?                             // lien paiement comptant (lot suivant)
  creditId     Int?                             // lien paiement crédit (lot suivant)

  planEpargneId Int?                            // cotisation fléchée vers un plan d'épargne (CDC §19.B)
  planEpargne   PlanEpargne? @relation("CotisationsPlan", fields: [planEpargneId], references: [id])

  ip           String?                          // adresse IP de l'auteur (CDC §16)
  userAgent    String?                          // machine / navigateur de l'auteur (CDC §16)

  createdAt    DateTime          @default(now())

  @@index([compteId])
  @@index([nature])
  @@index([createdAt])
  @@index([agentApporteurId])
}

// ============================================================
// MODULE POPC — Planification des Objectifs & Pilotage des Collectes
// ============================================================
// Aucune ressaisie : les réalisations (16èmes/31èmes, encaissements) sont lues
// des modules Crédit (CreditClient/EcheanceCredit/RemboursementCredit) et des
// ventes de carnets. Ce module ne stocke QUE le paramétrage et les objectifs
// générés (historisés par mois pour comparaison — CDC §15.5).
// FK stockées en Int sans relation Prisma (même parti-pris que
// CreditClient.pointDeVenteId) pour rester isolé des modèles User/PDV/Client.

enum StatutParametragePOPC {
  BROUILLON // saisi, objectifs recalculés à la volée, non figé
  VALIDE    // objectifs figés pour le mois (référence de pilotage)
}

// Paramétrage mensuel (CDC §3) : charges + paramètres commerciaux.
// Unicité (annee, mois, pointDeVenteId) : un paramétrage global (pointDeVenteId null)
// et/ou un paramétrage par agence.
model ParametragePOPC {
  id             Int                    @id @default(autoincrement())
  annee          Int
  mois           Int                    // 1..12
  pointDeVenteId Int                    @default(0) // 0 = global (toutes agences), sinon PDV
  statut         StatutParametragePOPC  @default(BROUILLON)

  // ── 3.1 Charges mensuelles (FCFA) ──────────────────────────────────────────
  salaireAgents       Decimal @default(0)
  salaireSuperviseurs Decimal @default(0)
  salaireControleurs  Decimal @default(0)
  salaireResponsables Decimal @default(0)
  carburant           Decimal @default(0)
  entretienMotos      Decimal @default(0)
  telephone           Decimal @default(0)
  internet            Decimal @default(0)
  loyer               Decimal @default(0)
  eau                 Decimal @default(0)
  electricite         Decimal @default(0)
  fournitures         Decimal @default(0)
  publicite           Decimal @default(0)
  divers              Decimal @default(0)

  // ── 3.2 Paramètres commerciaux ─────────────────────────────────────────────
  objectifBenefice     Decimal @default(0) // objectif de bénéfice du mois
  commissionSeizieme   Decimal @default(0) // commission minimum du 16ème
  commissionTrentaine  Decimal @default(0) // commission minimum du 31ème
  prixCarnet           Decimal @default(300)
  joursOuvrables       Int     @default(26)
  nombreAgentsTerrain  Int     @default(1)
  nombreAgences        Int     @default(1)

  // ── Hypothèses de planification (mix de revenu) ────────────────────────────
  // Répartition du revenu-cible entre les 3 sources (somme ≈ 100). Éditable :
  // le CDC ne fixe pas le mix, la Direction le calibre.
  partRevenu16      Decimal @default(50) // % du revenu attendu via les 16èmes
  partRevenu31      Decimal @default(40) // % du revenu attendu via les 31èmes
  partRevenuCarnet  Decimal @default(10) // % du revenu attendu via les carnets
  creditsParClient  Decimal @default(1)  // nb moyen de crédits par client (recrutement)

  // ── Traçabilité (CDC §15.6) ────────────────────────────────────────────────
  creeParId      Int
  valideParId    Int?
  dateValidation DateTime?

  objectif ObjectifPOPC?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([annee, mois, pointDeVenteId])
  @@index([annee, mois])
  @@index([pointDeVenteId])
}

// Tableau de synthèse généré (CDC §4). Snapshot des objectifs calculés à partir
// du paramétrage — conservé pour l'historique et les comparaisons.
model ObjectifPOPC {
  id             Int @id @default(autoincrement())
  parametrageId  Int @unique

  chargesTotales      Decimal @default(0)
  objectifBenefice    Decimal @default(0)
  revenuMinimum       Decimal @default(0)
  nbSeiziemes         Int     @default(0)
  nbTrentiemes        Int     @default(0)
  nbCarnets           Int     @default(0)
  nbNouveauxCredits   Int     @default(0)
  nbClientsRecruter   Int     @default(0)
  objectifQuotidien   Decimal @default(0)
  objectifHebdomadaire Decimal @default(0)
  objectifMensuel     Decimal @default(0)

  parametrage ParametragePOPC @relation(fields: [parametrageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Vente d'un carnet de crédit (300 FCFA — CDC §1). Source des « carnets vendus »
// des tableaux §8/§9/§11. Traçabilité agent + agence sans ressaisie.
model VenteCarnet {
  id             Int      @id @default(autoincrement())
  reference      String   @unique // ex: CAR-20260721-0001
  montant        Decimal  @default(300)
  agentId        Int?     // AGENT_TERRAIN ayant vendu (commercial)
  pointDeVenteId Int?     // agence concernée
  clientId       Int?     // client acheteur (optionnel)
  dateVente      DateTime @default(now())
  enregistreParId Int
  notes          String?

  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([pointDeVenteId])
  @@index([dateVente])
}
