  distributions DistributionBenefice[]
  documents     DocumentInvestisseur[]
  rapports      RapportMensuelRIA[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profilRIAId])
  @@index([actif])
}

model AffectationClientRIA {
  id             Int             @id @default(autoincrement())
  portefeuilleId Int
  clientId       Int
  pourcentage    Decimal
  montantAlloue  Decimal         @default(0)
  classeRisque   ClasseRisqueRIA @default(A)
  actif          Boolean         @default(true)
  dateDebut      DateTime        @default(now())
  dateFin        DateTime?
  notes          String?

  portefeuille PortefeuilleRIA           @relation(fields: [portefeuilleId], references: [id])
  client       Client                    @relation(fields: [clientId],       references: [id])
  financements OperationFinancementRIA[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([portefeuilleId])
  @@index([clientId])
  @@index([clientId, actif])
}

model DepotInvestisseur {
  id              Int            @id @default(autoincrement())
  reference       String         @unique
  portefeuilleId  Int
  montant         Decimal
  statut          StatutDepotRIA @default(EN_ATTENTE)
  modePaiement    String?
  justificatifUrl String?
  notes           String?
  valideParId     Int?
  dateValidation  DateTime?

  portefeuille PortefeuilleRIA    @relation(fields: [portefeuilleId], references: [id])
  validePar    User?              @relation("DepotsValides",   fields: [valideParId], references: [id])
  mouvement    MouvementFondsRIA? @relation("MouvementDepot")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([portefeuilleId])
  @@index([statut])
}

model RetraitInvestisseur {
  id             Int              @id @default(autoincrement())
  reference      String           @unique
  portefeuilleId Int
  montant        Decimal
  statut         StatutRetraitRIA @default(EN_ATTENTE)
  motif          String?
  modePaiement   String?
  notes          String?
  valideParId    Int?
  dateValidation DateTime?
  datePaiement   DateTime?

  portefeuille PortefeuilleRIA    @relation(fields: [portefeuilleId], references: [id])
  validePar    User?              @relation("RetraitsValides",  fields: [valideParId], references: [id])
  mouvement    MouvementFondsRIA? @relation("MouvementRetrait")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([portefeuilleId])
  @@index([statut])
}

model MouvementFondsRIA {
  id             Int              @id @default(autoincrement())
  type           TypeMouvementRIA
  montant        Decimal
  sens           String
  description    String?
  reference      String?

  portefeuilleId Int
  depotId        Int?  @unique
  retraitId      Int?  @unique
  financementId  Int?
  distributionId Int?

  portefeuille PortefeuilleRIA          @relation("MouvementsPF",          fields: [portefeuilleId], references: [id])
  depot        DepotInvestisseur?        @relation("MouvementDepot",         fields: [depotId],         references: [id])
  retrait      RetraitInvestisseur?      @relation("MouvementRetrait",        fields: [retraitId],        references: [id])
  financement  OperationFinancementRIA? @relation("MouvementsFinancement",  fields: [financementId],   references: [id])
  distribution DistributionBenefice?    @relation("MouvementsDistribution", fields: [distributionId],  references: [id])

  createdAt DateTime @default(now())

  @@index([portefeuilleId])
  @@index([type])
  @@index([createdAt])
  @@index([financementId])
  @@index([distributionId])
}

model OperationFinancementRIA {
  id             Int                  @id @default(autoincrement())
  reference      String               @unique
  portefeuilleId Int
  affectationId  Int?
  clientId       Int
  creditClientId Int?

  montantFinance   Decimal
  montantRembourse Decimal @default(0)
  encours          Decimal

  statut          StatutFinancementRIA @default(ACTIF)
  dateFinancement DateTime             @default(now())
  dateEcheance    DateTime?
  notes           String?

  portefeuille PortefeuilleRIA        @relation(fields: [portefeuilleId], references: [id])
  affectation  AffectationClientRIA?  @relation(fields: [affectationId],  references: [id])
  client       Client                 @relation("FinancementsRIAClient",  fields: [clientId],        references: [id])
  creditClient CreditClient?          @relation("FinancementsRIACredit",  fields: [creditClientId],  references: [id])

  remboursements      RemboursementRIA[]
  mouvements          MouvementFondsRIA[]     @relation("MouvementsFinancement")
  actionsRecouvrement ActionRecouvrementRIA[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([portefeuilleId])
  @@index([clientId])
  @@index([statut])
  @@index([creditClientId])
}

model RemboursementRIA {
  id                    Int     @id @default(autoincrement())
  financementId         Int
  montant               Decimal
  remboursementCreditId Int?

  financement OperationFinancementRIA @relation(fields: [financementId], references: [id])

  createdAt DateTime @default(now())

  @@index([financementId])
}

model DistributionBenefice {
  id             Int @id @default(autoincrement())
  portefeuilleId Int
  mois           Int
  annee          Int

  capitalBase         Decimal
  tauxGenere          Decimal
  tauxDistribue       Decimal
  tauxReinvesti       Decimal
  tauxFondSecurite    Decimal
  montantGenere       Decimal
  montantDistribue    Decimal
  montantReinvesti    Decimal
  montantFondSecurite Decimal

  statut       StatutDistributionRIA @default(PLANIFIE)
  datePaiement DateTime?
  traitePar    Int?
  notes        String?

  portefeuille PortefeuilleRIA     @relation(fields: [portefeuilleId], references: [id])
  mouvements   MouvementFondsRIA[] @relation("MouvementsDistribution")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([portefeuilleId, mois, annee])
  @@index([portefeuilleId])
  @@index([mois, annee])
}

model ConfigBeneficeRIA {
  id               Int     @id @default(autoincrement())
  tauxGenere       Decimal @default(10)
  tauxDistribue    Decimal @default(4)
  tauxReinvesti    Decimal @default(4)
  tauxFondSecurite Decimal @default(2)
  actif            Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocumentInvestisseur {
  id             Int    @id @default(autoincrement())
  portefeuilleId Int
  type           String
  nom            String
  url            String
  description    String?

  portefeuille PortefeuilleRIA @relation(fields: [portefeuilleId], references: [id])

  createdAt DateTime @default(now())

  @@index([portefeuilleId])
}

model RapportMensuelRIA {
  id             Int     @id @default(autoincrement())
  portefeuilleId Int
  mois           Int
  annee          Int
  donnees        Json
  pdfUrl         String?
  genereParId    Int?

  portefeuille PortefeuilleRIA @relation(fields: [portefeuilleId], references: [id])

  createdAt DateTime @default(now())

  @@unique([portefeuilleId, mois, annee])
  @@index([portefeuilleId])
}

model ActionRecouvrementRIA {
  id            Int                      @id @default(autoincrement())
  financementId Int
  type          TypeActionRecouvrement
  statut        StatutActionRecouvrement @default(EN_COURS)
  notes         String?
  resultat      String?
  effectueParId Int?
  dateAction    DateTime                 @default(now())
  dateRelance   DateTime?

  financement OperationFinancementRIA @relation(fields: [financementId], references: [id])
  effectuePar User?                   @relation("ActionsRIAEffectuees", fields: [effectueParId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([financementId])
  @@index([statut])
  @@index([dateAction])
}

// ── Commissions Agents RIA ─────────────────────────────────────────────────────

enum StatutCommissionRIA {
  CALCULE
  APPROUVE
  PAYE
  ANNULE
}

model ConfigCommissionRIA {
  id          Int     @id @default(autoincrement())
  roleType    String  @unique // "AGENT_TERRAIN" | "CHEF_AGENCE" | "RPV_REGIONAL"
  tauxBase    Decimal @default(1.0) // % du montant recouvré
  description String?
  actif       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommissionAgentRIA {
  id     Int    @id @default(autoincrement())
  userId Int
  mois   Int
  annee  Int
  roleType String // "AGENT_TERRAIN" | "CHEF_AGENCE" | "RPV_REGIONAL"
  pdvId  Int?   // PDV concerné (pour chef agence / RPV)

  montantRecouvre      Decimal @default(0)
  nbDossiers           Int     @default(0)
  nbDossiersRembourses Int     @default(0)
  tauxSucces           Decimal @default(0)

  taux    Decimal @default(0)
  montant Decimal @default(0)

  statut          StatutCommissionRIA @default(CALCULE)
  approuveParId   Int?
  dateApprobation DateTime?
  datePaiement    DateTime?
  notes           String?

  user        User  @relation("CommissionsAgent",    fields: [userId],        references: [id])
  approuvePar User? @relation("CommissionsApprob",   fields: [approuveParId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, mois, annee, roleType])
  @@index([mois, annee])
  @@index([statut])
  @@index([userId])
}
