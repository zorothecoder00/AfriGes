  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocumentInvestisseur {
  id             Int    @id @default(autoincrement())
  portefeuilleId Int
  type           String
  nom            String
  url            String
  description    String?

  portefeuille PortefeuilleRIA @relation(fields: [portefeuilleId], references: [id])

  createdAt DateTime @default(now())

  @@index([portefeuilleId])
}

model RapportMensuelRIA {
  id             Int     @id @default(autoincrement())
  portefeuilleId Int
  mois           Int
  annee          Int
  donnees        Json
  pdfUrl         String?
  genereParId    Int?

  portefeuille PortefeuilleRIA @relation(fields: [portefeuilleId], references: [id])

  createdAt DateTime @default(now())

  @@unique([portefeuilleId, mois, annee])
  @@index([portefeuilleId])
}

model ActionRecouvrementRIA {
  id            Int                      @id @default(autoincrement())
  financementId Int
