// ============================================================
// AUDIT & NOTIFICATIONS
// ============================================================

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  entite    String
  entiteId  Int?
  details   Json?    // snapshot avant/après ou données contextuelles
  ip        String?  // adresse IP de l'auteur
  userAgent String?  // navigateur / appareil
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entite, entiteId])
  @@index([createdAt])
