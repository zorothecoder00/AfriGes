generator client {
  provider = "prisma-client-js"
}                                                        
                                 
datasource db {
  provider = "postgresql"
}            
  
// ============================================================
// ENUMS — Rôles & statuts généraux
// ============================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum MemberStatus {
  ACTIF
  INACTIF
  SUSPENDU
  BLOQUE
  EN_ATTENTE_VALIDATION  // client créé par agent terrain, attend validation RVC
  REJETE                 // refusé par le responsable crédit (retour agent commercial)
}         

enum RoleGestionnaire {
  SUPER_ADMIN
  ADMIN
  RESPONSABLE_POINT_DE_VENTE         // RPV
  CHEF_AGENCE                        // coordonne plusieurs PDV (nouveau)
  RESPONSABLE_COMMUNAUTE             // alias chef agence communautaire
  AGENT_LOGISTIQUE_APPROVISIONNEMENT // responsable stock & réceptions
  MAGAZINIER
  CAISSIER
  COMMERCIAL
  COMPTABLE
  AUDITEUR_INTERNE
  RESPONSABLE_VENTE_CREDIT
  CONTROLEUR_TERRAIN
  AGENT_TERRAIN                      // vendeur terrain
  RESPONSABLE_ECONOMIQUE
  RESPONSABLE_MARKETING
  ACTIONNAIRE
  REVENDEUR
  RESPONSABLE_RH                     // gestionnaire RH (OGRH)
  INVESTISSEUR_RIA                   // investisseur Réseau AfriSime
  RESPONSABLE_RIA                    // gestionnaire du réseau RIA
}

