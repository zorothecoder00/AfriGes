// ============================================================
// ENUMS — Crédits clients
// ============================================================

// Formule commerciale d'un crédit (module POPC).
// QUINZAINE : 15 mises journalières + une 16ème collecte de rémunération (16 échéances).
// TRENTAINE : 30 mises journalières + une 31ème collecte de rémunération (31 échéances).
// Nullable sur CreditClient : les crédits antérieurs à POPC restent valides sans formule.
enum FormuleCredit {
  QUINZAINE
  TRENTAINE
}

enum StatutCredit {
  EN_ATTENTE_VALIDATION  // créé, en attente d'approbation superviseur
  VALIDE                 // approuvé mais pas encore démarré
  ACTIF                  // en cours de remboursement
  EN_RETARD              // au moins une échéance impayée dépassée
  SOLDE                  // intégralement remboursé
  ANNULE                 // annulé avant démarrage
  REJETE                 // refusé par le superviseur
}

enum StatutEcheanceCredit {
  EN_ATTENTE
  PAYE
  PARTIEL
  EN_RETARD
}

enum StatutLigneCreditClient {
  EN_ATTENTE    // produit inclus dans le crédit, livraison non encore confirmée
  LIVRE         // produit effectivement remis au client
  INDISPONIBLE  // produit non disponible au moment de la livraison
  SUBSTITUE     // remplacé par un autre produit (voir produitSubstitutId)
  ANNULE        // ligne annulée (ex: client ne veut plus ce produit)
}

