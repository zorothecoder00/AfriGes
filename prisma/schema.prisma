datasource db {
  provider = "postgresql"  
}            
  
// ============================================================
// ENUMS — Rôles & statuts généraux
// ============================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum MemberStatus {
  ACTIF
  INACTIF
  SUSPENDU
  BLOQUE
