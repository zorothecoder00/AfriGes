// ============================================================
// OGRH — MODULE 3 : ÉVALUATION DE PERFORMANCE
// ============================================================

enum PeriodeEvaluation {
  ANNUELLE
  SEMESTRIELLE
  TRIMESTRIELLE
  PROBATOIRE
}

enum StatutEvaluationRH {
  BROUILLON
  OBJECTIFS_FIXES
  EN_COURS
  EVALUATION
  VALIDATION
  PLAN_AMELIORATION
  CLOTURE
}

enum TypeEvaluation {
  HIERARCHIQUE
  AUTO_EVALUATION
  EVALUATION_360
}

model EvaluationRH {
  id               Int                 @id @default(autoincrement())
  profilRHId       Int
  evaluateurId     Int?                // ProfilRH.id du manager/RH évaluateur
  periode          PeriodeEvaluation
  annee            Int
  dateDebut        DateTime
  dateFin          DateTime?
  typeEvaluation   TypeEvaluation?
  statut           StatutEvaluationRH  @default(BROUILLON)
  noteGlobale      Decimal?            // /5
  appreciation     String?
  pointsForts      String?
  axesAmelioration String?
  objectifsN1      String?
  planAmelioration String?
  notes            String?

  profilRH   ProfilRH  @relation("EvaluationsCollaborateur", fields: [profilRHId],   references: [id])
  evaluateur ProfilRH? @relation("EvaluationsEffectuees",    fields: [evaluateurId], references: [id])
  criteres   CritereEvaluation[]
  objectifs  ObjectifKPI[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profilRHId])
  @@index([annee])
  @@index([statut])
}

model CritereEvaluation {
  id           Int     @id @default(autoincrement())
  evaluationId Int
  libelle      String
  note         Decimal // /5
  commentaire  String?

  evaluation EvaluationRH @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
}

model ObjectifKPI {
  id             Int      @id @default(autoincrement())
  evaluationId   Int
  libelle        String
  indicateur     String?
  valeurCible    Decimal
  valeurAtteinte Decimal?
  unite          String?
  poids          Int?     // pondération en % (0-100)
  commentaire    String?
  actif          Boolean  @default(true)  // soft delete (CDC §8)

  evaluation EvaluationRH @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([evaluationId])
}

// ============================================================
// OGRH — MODULE 5 : RECRUTEMENT
// ============================================================

enum StatutPoste {
  BROUILLON  // créé, en attente de validation interne
  OUVERT     // validé et publié
  EN_COURS   // recrutement actif
  POURVU     // poste occupé
  ANNULE
}

enum StatutCandidature {
  RECU
  PRE_QUALIFICATION // premier filtre téléphonique ou écrit
  SHORTLISTE
  ENTRETIEN
  TEST              // test technique / pratique
  VALIDATION        // validation RH / direction
  OFFRE
  INTEGRATION       // processus d'onboarding en cours
  ACCEPTE
  REJETE
}

model PosteOuvert {
  id                  Int         @id @default(autoincrement())
  reference           String?     @unique // ex: REC-2026-0001 (auto-généré)
  titre               String
  departement         String?
  service             String?
  lieu                String?
  typeContrat         TypeContrat?
  description         String?
  exigences           String?     // profil requis (ex-competencesRequises)
  competencesRequises String?     // conservé pour compatibilité
  experienceMin       Int?        // années d'expérience minimum
  nbPostes            Int         @default(1)
  salaireMini         Int?        // FCFA
  salaireMaxi         Int?        // FCFA
  budgetPoste         Int?        // budget total alloué au recrutement (FCFA)
  dateOuverture       DateTime    @default(now())
  dateLimite          DateTime?
  statut              StatutPoste @default(OUVERT)
  validateurId        Int?        // User.id du validateur interne
  dateValidation      DateTime?   // date de validation interne
  notes               String?
  createdById         Int         // User.id

  candidatures     Candidature[]
  documentsGeneres DocumentRecrutementGenere[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([createdById])
}

model Candidature {
  id               Int               @id @default(autoincrement())
  posteId          Int
  nomCandidat      String
  prenomCandidat   String
  email            String?
  telephone        String?
  cvUrl            String?
  lettreUrl        String?
  statut           StatutCandidature @default(RECU)
  scoreCandidat    Int?              // score global /100 (calculé ou saisi)
  noteEntretien    Decimal?          // note /5 après entretien
  noteTest         Decimal?          // note /20 après test technique
  dateEntretien    DateTime?
  dateTest         DateTime?
  commentaire      String?
  notes            String?
  competences      String?           // tags CSV ex: "React,TypeScript,Node.js"
  formation        String?           // ex: "Bac+5 Informatique"
  experienceAnnees Int?              // nb années d'expérience déclarées
  sourceCandidat   String?           // ex: "LinkedIn", "Recommandation", "Site web"
  dateCandidature  DateTime          @default(now())

  poste            PosteOuvert        @relation(fields: [posteId], references: [id], onDelete: Cascade)
  onboarding       OnboardingEmploye?
  documentsGeneres DocumentRecrutementGenere[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([posteId])
  @@index([statut])
  @@index([scoreCandidat])
}

enum TypeDocumentRecrutement {
  AVIS_RECRUTEMENT       // rattaché au poste
  CONVOCATION_ENTRETIEN  // rattaché à la candidature
  LETTRE_OFFRE           // rattaché à la candidature
  LETTRE_REFUS           // rattaché à la candidature
  PROMESSE_EMBAUCHE      // rattaché à la candidature
  PV_SELECTION           // rattaché au poste
}

/// Document de recrutement généré (nature A) — rattaché à un PosteOuvert OU une
/// Candidature (exactement l'un des deux selon le type). Versionné par cible+type,
/// contenu HTML réutilisé pour l'export PDF. Miroir de DocumentRHGenere côté recrutement.
model DocumentRecrutementGenere {
  id            Int                     @id @default(autoincrement())
  type          TypeDocumentRecrutement
  titre         String
  version       Int                     @default(1)
  contenu       String?                 // HTML généré
  fileUrl       String?
  generePar     Int                     // User.id
  notes         String?
  archive       Boolean                 @default(false)

  posteId       Int?
  candidatureId Int?
  poste         PosteOuvert? @relation(fields: [posteId], references: [id], onDelete: Cascade)
  candidature   Candidature? @relation(fields: [candidatureId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([posteId])
  @@index([candidatureId])
  @@index([type])
}

// ============================================================
// OGRH — MODULE 4 : ONBOARDING
// Déclenché automatiquement à l'acceptation d'une candidature.
// Crée en une transaction : matricule + email pro + ProfilRH + checklist.
// ============================================================

enum StatutOnboarding {
  EN_COURS   // onboarding lancé, étapes en progression
  TERMINE    // toutes les étapes obligatoires sont FAIT
  SUSPENDU   // mis en pause (ex: délai de prise de poste)
  ANNULE     // collaborateur n'a finalement pas rejoint
}

enum TypeEtapeOnboarding {
  SIGNATURE_CONTRAT  // signature du contrat de travail
  REMISE_MATERIEL    // remise ordinateur, badge, téléphone…
  FORMATION          // session de formation d'intégration
  AFFECTATION        // affectation au PDV / service / manager
  ACCES_SYSTEME      // création des accès informatiques
  PRESENTATION       // présentation à l'équipe
  AUTRE
}

enum StatutEtapeOnboarding {
  EN_ATTENTE  // pas encore traitée
  FAIT        // complétée
  IGNORE      // volontairement ignorée (non applicable)
}

/// Template de checklist réutilisable — 1 template par profil de poste ou type de contrat
model TemplateOnboarding {
  id          Int     @id @default(autoincrement())
  nom         String  // ex: "Intégration Commercial", "Onboarding Tech"
  description String?
  actif       Boolean @default(true)
  createdById Int     // User.id du RH qui a créé le template

  etapes      EtapeTemplate[]
  onboardings OnboardingEmploye[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([actif])
}

/// Étape d'un template — ordonnée, copiée vers EtapeOnboarding à la création de l'instance
model EtapeTemplate {
  id          Int                 @id @default(autoincrement())
  templateId  Int
  ordre       Int                 // position dans la checklist (1, 2, 3…)
  titre       String
  description String?
  type        TypeEtapeOnboarding @default(AUTRE)
  delaiJours  Int                 @default(0)   // délai max en jours depuis le début de l'onboarding
  obligatoire Boolean             @default(true) // si false : peut être IGNORE sans bloquer la progression          

  template TemplateOnboarding @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([templateId, ordre])
}

/// Instance d'onboarding créée automatiquement lors de l'acceptation d'une candidature
/// Matricule, email professionnel et ProfilRH sont créés dans la même transaction
model OnboardingEmploye {
  id             Int              @id @default(autoincrement())
  candidatureId  Int              @unique  // 1 onboarding par candidature
  profilRHId     Int              @unique  // 1 onboarding par collaborateur
  templateId     Int?             // template source (null si checklist créée manuellement)
  statut         StatutOnboarding @default(EN_COURS)
  dateDebut      DateTime         @default(now())
  dateFinPrevue  DateTime?        // calculée : dateDebut + max(delaiJours des étapes)
  dateCloture    DateTime?        // remplie quand statut → TERMINE ou ANNULE
  progressionPct Int              @default(0)  // mis à jour à chaque changement d'étape
  notes          String?
  createdById    Int              // User.id du RH qui a validé le recrutement

  candidature Candidature         @relation(fields: [candidatureId], references: [id])
  profilRH    ProfilRH            @relation(fields: [profilRHId],    references: [id])
  template    TemplateOnboarding? @relation(fields: [templateId],    references: [id])
  etapes      EtapeOnboarding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([dateDebut])
}

/// Instance d'une étape pour un onboarding spécifique (copiée depuis EtapeTemplate ou créée manuellement)
model EtapeOnboarding {
  id           Int                   @id @default(autoincrement())
  onboardingId Int
  ordre        Int
  titre        String
  description  String?
  type         TypeEtapeOnboarding   @default(AUTRE)
  statut       StatutEtapeOnboarding @default(EN_ATTENTE)
  obligatoire  Boolean               @default(true)

  // Responsable et délai
  responsableId Int?      // User.id de la personne chargée de cette étape
  dateLimite    DateTime?
  dateFaite     DateTime?
  commentaire   String?

  onboarding OnboardingEmploye @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([onboardingId])
  @@index([onboardingId, ordre])
  @@index([statut])
}

// ============================================================
// OGRH — MODULE 9 : DISCIPLINAIRE
// ============================================================

enum TypeSanction {
  AVERTISSEMENT
  BLAME
  MISE_A_PIED
  LICENCIEMENT_CAUSE
  AUTRE
}

enum StatutProcedure {
  OUVERTE
  EN_INSTRUCTION
  CLOTUREE
  ANNULEE
}

model ProcedureDisciplinaire {
  id               Int             @id @default(autoincrement())
  profilRHId       Int
  type             TypeSanction
  motif            String
  faitsReproches   String?
  dateIncident     DateTime
  dateProcedure    DateTime        @default(now())
  statut           StatutProcedure @default(OUVERTE)
  dateConvocation  DateTime?
  reponseCollab    String?
  decision         String?
  dateDecision     DateTime?
  dureeSuspension  Int?            // jours (si mise à pied)
  notes            String?
  traiteParId      Int             // User.id

  profilRH ProfilRH @relation(fields: [profilRHId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profilRHId])
  @@index([statut])
}

// ============================================================
// ENUMS — Module RIA (Réseau des Investisseurs AfriSime)
// ============================================================

enum StatutDepotRIA {
  EN_ATTENTE
  VALIDE
  REJETE
}

enum StatutRetraitRIA {
  EN_ATTENTE
  VALIDE
  PAYE
  REJETE
}

enum StatutFinancementRIA {
  ACTIF
  REMBOURSE
  EN_RETARD
  DEFAUT
  ANNULE
}

enum StatutDistributionRIA {
  PLANIFIE
  EN_ATTENTE_PAIEMENT
  DISTRIBUE
  REINVESTI
}

enum ClasseRisqueRIA {
  A
  B
  C
  D
  E
}

// Étape 3 — Sélection des clients à financer (identification RVC)
enum StatutEligibiliteRIA {
  EN_ATTENTE // évalué, en attente de confirmation RVC
  ELIGIBLE   // validé automatiquement par les règles
  REFUSE     // refusé automatiquement par les règles
  VALIDE     // confirmé par le RVC (affectable par admin/responsableRIA)
  RETIRE     // retiré du vivier RIA
}

enum TypeMouvementRIA {
  DEPOT
  RETRAIT
  FINANCEMENT_CLIENT
  REMBOURSEMENT_CLIENT
  BENEFICE_GENERE
  BENEFICE_DISTRIBUE
  BENEFICE_REINVESTI
  FOND_SECURITE
  AJUSTEMENT
}

enum TypeActionRecouvrement {
  APPEL_TELEPHONIQUE
  VISITE_TERRAIN
  MISE_EN_DEMEURE
  ACCORD_ECHEANCIER
  SAISIE_GARANTIE
  NOTE_INTERNE
}

enum StatutActionRecouvrement {
  EN_COURS
  RESOLU
  SANS_SUITE
}

// Phase d'un dossier de défaillance client RIA (escalade > seuils de retard)
enum PhaseRecouvrementRIA {
  NORMAL          // pas de retard significatif
  PRECONTENTIEUX  // retard installé, recouvrement amiable
  CONTENTIEUX     // mise en demeure / dossier juridique
  PERTE           // créance irrécouvrable
}

// ============================================================
// MODULE RIA — RÉSEAU DES INVESTISSEURS AFRISIME
// ============================================================

model ProfilInvestisseurRIA {
  id               Int     @id @default(autoincrement())
  gestionnaireId   Int     @unique
  numero           String? @unique  // INV-00001 — généré à la création
  profession       String?
  pays             String?
  pieceIdentiteUrl String?
  notes            String?

  gestionnaire      Gestionnaire        @relation(fields: [gestionnaireId], references: [id])
  portefeuilles     PortefeuilleRIA[]
  documentsGeneres  DocumentRIAGenere[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PortefeuilleRIA {
  id          Int     @id @default(autoincrement())
  reference   String  @unique // PF-00001
  profilRIAId Int
  nom         String?
  actif       Boolean @default(true)
  notes       String?

  capitalInvesti    Decimal @default(0)
  capitalDisponible Decimal @default(0)
  capitalEngage     Decimal @default(0)
  capitalRecouvre   Decimal @default(0)
  capitalBloque     Decimal @default(0)

  beneficesGeneres    Decimal @default(0)
  beneficesDistribues Decimal @default(0)
  beneficesReinvestis Decimal @default(0)
  fondSecurite        Decimal @default(0)

  profilRIA     ProfilInvestisseurRIA     @relation(fields: [profilRIAId], references: [id])
  affectations  AffectationClientRIA[]
  financements  OperationFinancementRIA[]
  mouvements    MouvementFondsRIA[]        @relation("MouvementsPF")
  depots        DepotInvestisseur[]
  retraits      RetraitInvestisseur[]
  distributions DistributionBenefice[]
  documents        DocumentInvestisseur[]
  rapports         RapportMensuelRIA[]
  documentsGeneres DocumentRIAGenere[]
  dossiersICExecutes DossierInterCommission[] @relation("DossiersICPortefeuilleExecution")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profilRIAId])
  @@index([actif])
}

model AffectationClientRIA {
  id             Int             @id @default(autoincrement())
  portefeuilleId Int
  clientId       Int
  pourcentage    Decimal
  montantAlloue  Decimal         @default(0)
  classeRisque   ClasseRisqueRIA @default(A)
  actif          Boolean         @default(true)
  dateDebut      DateTime        @default(now())
  dateFin        DateTime?
  notes          String?  

  portefeuille PortefeuilleRIA           @relation(fields: [portefeuilleId], references: [id])
  client       Client                    @relation(fields: [clientId],       references: [id])
  financements OperationFinancementRIA[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([portefeuilleId])
  @@index([clientId])
  @@index([clientId, actif])
}

// Étape 3 — Vivier des clients identifiés par le RVC comme finançables par le RIA.
// Un seul enregistrement courant par client (upsert à chaque réévaluation).
model EligibiliteClientRIA {
  id       Int @id @default(autoincrement())
  clientId Int @unique

  // Montant de crédit sollicité (le « crédit demandé »)
  montantDemande Decimal @default(0)

  // Snapshot des critères au moment de l'évaluation
  ancienneteJours     Int?
  nbAchats            Int?
  volumeAchats        Decimal?
  scoreSolvabilite    Float?
  niveauRisque        NiveauRisque?
  rotationCommerciale Float?

  // Historique crédits & packs (snapshot — nullable, données existantes non impactées)
  nbCredits        Int?      // nombre total de crédits accordés (hors annulés/rejetés)
  nbCreditsRetard  Int?      // crédits actuellement en retard
  volumeCredits    Decimal?  // montant total des crédits accordés
  nbPacks          Int?      // nombre de souscriptions à des packs

  // Résultat de l'évaluation automatique
  scoreEligibilite Float?              @default(0)
  classeRisque     ClasseRisqueRIA     @default(A)
  statut           StatutEligibiliteRIA @default(EN_ATTENTE)
  motifs           String[]            // raisons de refus / alertes
  decisionAuto     Boolean             @default(true)

  // Traçabilité RVC
  identifieParId Int?
  dateDecision   DateTime?
  notes          String?

  client       Client @relation(fields: [clientId], references: [id])
  identifiePar User?  @relation("EligibilitesRIAIdentifiees", fields: [identifieParId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([identifieParId])
}

model DepotInvestisseur {
  id              Int            @id @default(autoincrement())
  reference       String         @unique
  portefeuilleId  Int
  montant         Decimal
  statut          StatutDepotRIA @default(EN_ATTENTE)
  modePaiement    String?
  justificatifUrl String?
  notes           String?
  valideParId     Int?
  dateValidation  DateTime?

  portefeuille PortefeuilleRIA    @relation(fields: [portefeuilleId], references: [id])
  validePar    User?              @relation("DepotsValides",   fields: [valideParId], references: [id])
  mouvement    MouvementFondsRIA? @relation("MouvementDepot")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([portefeuilleId])
  @@index([statut])
}

model RetraitInvestisseur {
  id             Int              @id @default(autoincrement())
  reference      String           @unique
  portefeuilleId Int
  montant        Decimal
  statut         StatutRetraitRIA @default(EN_ATTENTE)
  motif          String?
  modePaiement   String?
  notes          String?
  valideParId    Int?
  dateValidation DateTime?
  datePaiement   DateTime?

  portefeuille PortefeuilleRIA    @relation(fields: [portefeuilleId], references: [id])
  validePar    User?              @relation("RetraitsValides",  fields: [valideParId], references: [id])
  mouvement    MouvementFondsRIA? @relation("MouvementRetrait")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([portefeuilleId])
  @@index([statut])
}

model MouvementFondsRIA {
  id             Int              @id @default(autoincrement())
  type           TypeMouvementRIA
  montant        Decimal
  sens           String
  description    String?
  reference      String?

  portefeuilleId Int
  depotId        Int?  @unique
  retraitId      Int?  @unique
  financementId  Int?
  distributionId Int?

  portefeuille PortefeuilleRIA          @relation("MouvementsPF",          fields: [portefeuilleId], references: [id])
  depot        DepotInvestisseur?        @relation("MouvementDepot",         fields: [depotId],         references: [id])
  retrait      RetraitInvestisseur?      @relation("MouvementRetrait",        fields: [retraitId],        references: [id])
  financement  OperationFinancementRIA? @relation("MouvementsFinancement",  fields: [financementId],   references: [id])
  distribution DistributionBenefice?    @relation("MouvementsDistribution", fields: [distributionId],  references: [id])

  createdAt DateTime @default(now())

  @@index([portefeuilleId])
  @@index([type])
  @@index([createdAt])
  @@index([financementId])
  @@index([distributionId])
}

model OperationFinancementRIA {
  id             Int                  @id @default(autoincrement())
  reference      String               @unique
  portefeuilleId Int
  affectationId  Int?
  clientId       Int
  creditClientId Int?

  montantFinance   Decimal
  montantRembourse Decimal @default(0)
  encours          Decimal

  statut          StatutFinancementRIA @default(ACTIF)
  dateFinancement DateTime             @default(now())
  dateEcheance    DateTime?
  notes           String?

  // ── Suivi de défaillance / escalade (moteur lib/riaRecouvrement.ts) ──────────
  phaseRecouvrement   PhaseRecouvrementRIA @default(NORMAL)
  niveauEscalade      Int                  @default(0)   // 0..5 — dernier palier déjà notifié (idempotence)
  joursRetard         Int                  @default(0)   // jours depuis dateEcheance (recalculé à chaque scan)
  dateDernierEscalade DateTime?                          // dernière fois qu'un palier a été franchi

  portefeuille PortefeuilleRIA        @relation(fields: [portefeuilleId], references: [id])
  affectation  AffectationClientRIA?  @relation(fields: [affectationId],  references: [id])
  client       Client                 @relation("FinancementsRIAClient",  fields: [clientId],        references: [id])
  creditClient CreditClient?          @relation("FinancementsRIACredit",  fields: [creditClientId],  references: [id])

  remboursements      RemboursementRIA[]
  mouvements          MouvementFondsRIA[]     @relation("MouvementsFinancement")
  actionsRecouvrement ActionRecouvrementRIA[]
  missionsAudit       MissionAuditRIA[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([portefeuilleId])
  @@index([clientId])
  @@index([statut])
  @@index([creditClientId])
}

model RemboursementRIA {
  id                    Int     @id @default(autoincrement())
  financementId         Int
  montant               Decimal
  remboursementCreditId Int?

  financement OperationFinancementRIA @relation(fields: [financementId], references: [id])

  createdAt DateTime @default(now())

  @@index([financementId])
}

model DistributionBenefice {
  id             Int @id @default(autoincrement())
  portefeuilleId Int
  mois           Int
  annee          Int

  capitalBase         Decimal
  tauxGenere          Decimal
  tauxDistribue       Decimal
  tauxReinvesti       Decimal
  tauxFondSecurite    Decimal
  montantGenere       Decimal
  montantDistribue    Decimal
  montantReinvesti    Decimal
  montantFondSecurite Decimal

  statut       StatutDistributionRIA @default(PLANIFIE)
  datePaiement DateTime?
  traitePar    Int?
  notes        String?

  portefeuille PortefeuilleRIA     @relation(fields: [portefeuilleId], references: [id])
  mouvements   MouvementFondsRIA[] @relation("MouvementsDistribution")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([portefeuilleId, mois, annee])
  @@index([portefeuilleId])
  @@index([mois, annee])
