// ============================================================
// OGRH — MODULE 2 : PAIE & RÉMUNÉRATION
// ============================================================

enum StatutFichePaie {
  BROUILLON        // Préparation RH — en cours de saisie
  CONTROLE         // soumis au contrôle RH (en cours de contrôle)
  CONTROLE_VALIDE  // contrôlé par le RH — en attente de validation Direction
  VALIDE           // validé par la Direction (admin/superadmin)
  EN_PAIEMENT      // ordre de paiement émis
  PAYE             // versement effectué (archivé)
}

enum TypeComposantSalaire {
  SALAIRE_BASE
  PRIME_PERFORMANCE
  PRIME_ANCIENNETE
  PRIME_TRANSPORT
  PRIME_LOGEMENT
  PRIME_FONCTION
  PRIME_RESPONSABILITE
  HEURES_SUPPLEMENTAIRES
  INDEMNITE_MISSION
  COMMISSION
  BONUS
  PRIME_EXCEPTIONNELLE
  DEDUCTION_ABSENCE
  DEDUCTION_RETARD
  COTISATION_RETRAITE
  COTISATION_SANTE
  IMPOT_REVENU
  AVANCE_SUR_SALAIRE
  REMBOURSEMENT_PRET
  SANCTION_FINANCIERE
  AUTRE_GAIN
  AUTRE_RETENUE
}

enum StatutAvanceSalaire {
  EN_ATTENTE       // demande soumise (attente validation manager)
  VALIDE_MANAGER   // validée par le manager/RH (attente approbation Direction)
  APPROUVE         // approuvée — injectée en paie
  REJETE
  REMBOURSE
  ANNULE           // annulée par le demandeur
}

enum StatutPretEmploye {
  EN_ATTENTE       // demande soumise (attente validation manager)
  VALIDE_MANAGER   // validée par le manager/RH (attente approbation Direction)
  EN_COURS         // approuvé & actif — remboursement injecté en paie
  SOLDE
  EN_DEFAUT
  REJETE
  ANNULE           // annulée par le demandeur
}

model FichePaie {
  id            Int             @id @default(autoincrement())
  profilRHId    Int
  mois          Int             // 1–12
  annee         Int
  salaireBase   Decimal         @default(0)
  totalBrut     Decimal         @default(0)
  totalRetenues Decimal         @default(0)
  netAPayer     Decimal         @default(0)
  statut        StatutFichePaie @default(BROUILLON)
  fichierUrl    String?
  notes         String?
  genereParId   Int             // User.id
  // Workflow
  controleParId        Int?    // User.id
  dateControle         DateTime?
  valideParId          Int?    // User.id
  dateValidation       DateTime?
  misEnPaiementParId   Int?    // User.id
  dateMiseEnPaiement   DateTime?
  modePaiement         String? // VIREMENT | MOBILE_MONEY | ESPECES

  profilRH   ProfilRH           @relation(fields: [profilRHId], references: [id])
  composants ComposantSalaire[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profilRHId, mois, annee])
  @@index([profilRHId])
  @@index([statut])
  @@index([annee, mois])
}

model ComposantSalaire {
  id          Int                  @id @default(autoincrement())
  fichePaieId Int
  type        TypeComposantSalaire
  libelle     String
  montant     Decimal
  isRetenue   Boolean              @default(false)
  ordre       Int                  @default(0) // pour l'affichage du bulletin

  fichePaie FichePaie @relation(fields: [fichePaieId], references: [id], onDelete: Cascade)

  @@index([fichePaieId])
}

// ── Grilles salariales ─────────────────────────────────────

model GrilleSalariale {
  id          Int      @id @default(autoincrement())
  categorie   String   // "Agent", "Superviseur", "Manager"…
  niveau      String   // "N1", "N2", "N3"…
  salaireMin  Decimal
  salaireMax  Decimal
  description String?
  actif       Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categorie, niveau])
}

// ── Types de composants personnalisés (moteur configurable) ─

model TypeComposantPaie {
  id        Int     @id @default(autoincrement())
  code      String  @unique  // ex: "PRIME_SOIR", "COMM_RECOUVREMENT"
  libelle   String
  categorie String  // "PRIME" | "COMMISSION" | "RETENUE" | "INDEMNITE" | "BONUS"
  isRetenue Boolean @default(false)
  actif     Boolean @default(true)

  createdAt DateTime @default(now())
}

// ── Barèmes de commissions ──────────────────────────────────

model BaremeCommission {
  id          Int      @id @default(autoincrement())
  libelle     String
  profilCible String   // rôle gestionnaire ciblé : "COMMERCIAL", "AGENT_TERRAIN"…
  type        String   // "FIXE" | "POURCENTAGE" | "PALIER"
  valeur      Decimal? // montant (FIXE) ou taux % (POURCENTAGE)
  paliers     Json?    // [{min: 1, max: 50, taux: 2}, {min: 51, max: 100, taux: 3}…]
  actif       Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Avances sur salaire ─────────────────────────────────────

model AvanceSalaire {
  id             Int                  @id @default(autoincrement())
  profilRHId     Int
  montant        Decimal
  motif          String?
  echeancesMois  Int                  @default(1)  // nb de mois pour remboursement
  montantRestant Decimal
  statut         StatutAvanceSalaire  @default(EN_ATTENTE)
  commentaire    String?              // motif refus ou note
  // ── Workflow de demande (Collaborateur → Manager → Direction) ──
  demandeParId          Int?          // User.id du collaborateur demandeur (null si créée par admin/RH)
  valideManagerParId    Int?          // User.id du manager/RH validateur niveau 1
  dateValidationManager DateTime?
  approuveParId  Int?                 // User.id (approbation finale Direction/RH)
  dateApprobation DateTime?

  profilRH ProfilRH @relation(fields: [profilRHId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profilRHId])
  @@index([statut])
}

// ── Prêts employés ──────────────────────────────────────────

model PretEmploye {
  id              Int               @id @default(autoincrement())
  profilRHId      Int
  montant         Decimal
  tauxInteret     Decimal           @default(0) // % annuel
  dureesMois      Int               // nombre total d'échéances
  montantMensuel  Decimal           // calculé : (montant + intérêts) / dureesMois
  montantRestant  Decimal
  statut          StatutPretEmploye @default(EN_COURS)
  notes           String?
  motif           String?           // objet de la demande (saisi par le collaborateur)
  commentaire     String?           // motif de refus / note de validation
  // ── Workflow de demande (Collaborateur → Manager → Direction) ──
  demandeParId          Int?        // User.id du collaborateur demandeur (null si créé par admin/RH)
  valideManagerParId    Int?        // User.id du manager/RH validateur niveau 1
  dateValidationManager DateTime?
  approuveParId         Int?        // User.id (approbation finale Direction/RH)
  dateApprobation       DateTime?

  profilRH ProfilRH @relation(fields: [profilRHId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profilRHId])
  @@index([statut])
}

// ============================================================
// OGRH — MODULE 4 : FORMATION & DÉVELOPPEMENT
// ============================================================

enum StatutFormation {
  PLANIFIEE
  EN_COURS
  TERMINEE
  ANNULEE
}

enum TypeFormation {
  INTERNE
  EXTERNE
  ELEARNING
}

enum StatutParticipationFormation {
  INSCRIT
  PRESENT
  ABSENT
  CERTIFIE
}

model Formation {
  id               Int             @id @default(autoincrement())
  titre            String
  type             TypeFormation?
  objectifs        String?
  lieu             String?
  formateur        String?
  dateDebut        DateTime
  dateFin          DateTime?
  dureeHeures      Int?
  cout             Decimal?        // coût réel
  budgetAlloue     Decimal?        // budget prévisionnel
  certificationNom String?         // nom de la certification délivrée
  statut           StatutFormation @default(PLANIFIEE)
  notes            String?
  createdById      Int             // User.id

  participations ParticipationFormation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([type])
  @@index([dateDebut])
}

model ParticipationFormation {
  id            Int                          @id @default(autoincrement())
  formationId   Int
  profilRHId    Int
  statut        StatutParticipationFormation @default(INSCRIT)
  note          Decimal?
  certificatUrl String?
  notes         String?

  formation Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)
  profilRH  ProfilRH  @relation(fields: [profilRHId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([formationId, profilRHId])
  @@index([profilRHId])
  @@index([statut])
}

// ============================================================
// OGRH — MODULE 8 : POINTAGE & PRÉSENCE
// ============================================================

enum StatutPointage {
  PRESENT
  ABSENT
  RETARD
  DEMI_JOURNEE
  CONGE
  MISSION
  FERIE
}

enum SourcePointage {
  MANUEL
  IMPORT
  SELF_SERVICE
}

model Pointage {
  id           Int            @id @default(autoincrement())
  profilRHId   Int
  date         DateTime
  heureArrivee DateTime?
  heureDepart  DateTime?
  statut       StatutPointage @default(PRESENT)
  source       SourcePointage @default(MANUEL)
  notes        String?
  saisieParId  Int            // User.id

  // ── Calculs (remplis automatiquement à la saisie) ──────────
  tempsTotal     Int?  // minutes effectivement travaillées
  retardMinutes  Int?  // minutes de retard vs heure théorique
  heuresSup      Int?  // minutes au-delà de la durée théorique
  justificatif   String?  // motif absence / retard

  // ── Validation ─────────────────────────────────────────────
  valideParId  Int?      // User.id du validateur
  valideA      DateTime? // date de validation

  // ── Annulation (soft delete — aucune suppression définitive, CDC §8) ──
  annule          Boolean   @default(false)
  annuleParId     Int?      // User.id de l'auteur de l'annulation
  annuleA         DateTime?
  motifAnnulation String?

  profilRH ProfilRH @relation(fields: [profilRHId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profilRHId, date])
  @@index([profilRHId])
  @@index([date])
  @@index([statut])
  @@index([annule])
}

/// Horaires de référence utilisés pour calculer retards et heures sup
/// Un profil peut avoir sa propre config ; sinon la config par défaut s'applique
model ConfigHoraire {
  id                   Int      @id @default(autoincrement())
  nom                  String?  // ex: "Bureau 8h-17h", "Terrain 7h-15h"
  heureArrivee         String?  // "08:30" format HH:mm
  heureDepart          String?  // "17:30" format HH:mm
  pauseDejeunnerMinutes Int?    // durée pause déjeuner en minutes (ex: 60)
  dureeJourneeMinutes  Int?     // durée théorique par jour en minutes (ex: 480)
  joursOuvres          Json?    // tableau [1,2,3,4,5] (1=lundi … 7=dimanche)
  toleranceRetardMin   Int?     // minutes de tolérance avant comptage retard (ex: 5)
  estDefaut            Boolean  @default(false)  // config appliquée si aucune perso
  actif                Boolean  @default(true)   // soft delete (CDC §8 — pas de suppression définitive)
  createdById          Int?     // User.id

  collaborateurs ProfilRH[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estDefaut])
  @@index([actif])
}

// ============================================================
// OGRH — MODULE 9 : COMPÉTENCES
// ============================================================

enum TypeCompetence {
  HARD_SKILL
  SOFT_SKILL
}

enum NiveauCompetence {
  DEBUTANT
  INTERMEDIAIRE
  AVANCE
  EXPERT
}

/// Référentiel des compétences de l'entreprise
model Competence {
  id          Int            @id @default(autoincrement())
  nom         String
  description String?
  type        TypeCompetence
  categorie   String?        // ex: "Informatique", "Finance", "Leadership"
  actif       Boolean        @default(true)
  createdById Int?           // User.id

  collaborateurCompetences CollaborateurCompetence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([categorie])
  @@index([actif])
}

/// Compétence d'un collaborateur avec son niveau
model CollaborateurCompetence {
  id              Int              @id @default(autoincrement())
  profilRHId      Int
  competenceId    Int
  niveau          NiveauCompetence
  dateAcquisition DateTime?
  notes           String?
  evalueParId     Int?             // User.id du RH qui a évalué
  actif           Boolean          @default(true)  // soft delete (CDC §8)

  profilRH   ProfilRH   @relation(fields: [profilRHId],   references: [id])
  competence Competence @relation(fields: [competenceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profilRHId, competenceId])
  @@index([profilRHId])
  @@index([competenceId])
  @@index([niveau])
}

// ============================================================
// OGRH — MODULE 10 : AVANTAGES & REMBOURSEMENTS
// ============================================================

enum TypeAvantageRH {
  TRANSPORT
  LOGEMENT
  TELEPHONE
  REPAS
  VEHICULE
  ASSURANCE
  AUTRE
}

enum TypeRemboursementFrais {
  DEPLACEMENT
  REPAS
  HEBERGEMENT
  COMMUNICATION
  MATERIEL
  AUTRE
}

enum StatutRemboursementFrais {
  EN_ATTENTE
  APPROUVE
  REJETE
  PAYE
}

model AvantageRH {
