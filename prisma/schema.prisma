  statut         StatutAvanceSalaire  @default(EN_ATTENTE)
  commentaire    String?              // motif refus ou note
  approuveParId  Int?                 // User.id
  dateApprobation DateTime?

  profilRH ProfilRH @relation(fields: [profilRHId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profilRHId])
  @@index([statut])
}

// ── Prêts employés ──────────────────────────────────────────

model PretEmploye {
  id              Int               @id @default(autoincrement())
  profilRHId      Int
  montant         Decimal
  tauxInteret     Decimal           @default(0) // % annuel
  dureesMois      Int               // nombre total d'échéances
  montantMensuel  Decimal           // calculé : (montant + intérêts) / dureesMois
  montantRestant  Decimal
