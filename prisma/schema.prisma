  @@index([compteId])
}

model JournalValidation {
  id          Int      @id @default(autoincrement())
  entryId     String   @unique
  notes       String?
  valideParId Int
  validePar   User     @relation(fields: [valideParId], references: [id])
  createdAt   DateTime @default(now())

  @@index([entryId])
}

model RapprochementBancaire {
  id                Int                 @id @default(autoincrement())
  periode           String
  soldeBancaireReel Decimal
  soldeComptable    Decimal
  ecart             Decimal
  notes             String?
  statut            StatutRapprochement @default(EN_COURS)
  userId            Int?
  user              User?               @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periode])
  @@index([statut])
}

model DeclarationTVA {
  id            Int       @id @default(autoincrement())
  periode       String
  tvaCollectee  Decimal   @default(0)
  tvaDeductible Decimal   @default(0)
  tvaDue        Decimal   @default(0)
  statut        StatutTVA @default(BROUILLON)
  notes         String?
  userId        Int?
  user          User?     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periode])
}

// ============================================================
// ACTIONNAIRES & ASSEMBLÉES
// ============================================================

model Dividende {
  id             Int             @id @default(autoincrement())
  periode        String
  montantTotal   Decimal
  montantParPart Decimal?
  dateVersement  DateTime?
  statut         StatutDividende @default(PLANIFIE)
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Assemblee {
  id            Int             @id @default(autoincrement())
  titre         String
  description   String?
  type          TypeAssemblee
  statut        StatutAssemblee @default(PLANIFIEE)
  dateAssemblee DateTime
  lieu          String
  ordreJour     String?
  notes         String?

  participants AssembleeParticipant[]
  resolutions  ResolutionAssemblee[]
  procurations ProcurationAssemblee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssembleeParticipant {
  id               Int                 @id @default(autoincrement())
  assembleeId      Int
  gestionnaireId   Int
  statut           StatutParticipation @default(INVITE)
  dateConfirmation DateTime?

  assemblee    Assemblee    @relation(fields: [assembleeId], references: [id], onDelete: Cascade)
  gestionnaire Gestionnaire @relation(fields: [gestionnaireId], references: [id])
  votes        VoteAssemblee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assembleeId, gestionnaireId])
}

model ResolutionAssemblee {
  id          Int              @id @default(autoincrement())
  assembleeId Int
  numero      Int
  titre       String
  description String?
  statut      StatutResolution @default(EN_ATTENTE)

  assemblee Assemblee       @relation(fields: [assembleeId], references: [id], onDelete: Cascade)
  votes     VoteAssemblee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assembleeId, numero])
}

model VoteAssemblee {
  id            Int          @id @default(autoincrement())
  resolutionId  Int
  participantId Int
  decision      DecisionVote
  commentaire   String?

  resolution  ResolutionAssemblee  @relation(fields: [resolutionId], references: [id], onDelete: Cascade)
  participant AssembleeParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([resolutionId, participantId])
}

model ActionnaireProfile {
  id             Int               @id @default(autoincrement())
  gestionnaireId Int               @unique
  statut         StatutActionnaire @default(EN_ATTENTE)
  typeAction     TypeActionDetenue @default(ORDINAIRE)
  nombreActions  Int               @default(0)
  prixUnitaire   Decimal           @default(0)
  dateEntree     DateTime?
  notes          String?

  gestionnaire Gestionnaire      @relation(fields: [gestionnaireId], references: [id])
  mouvements   MouvementAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MouvementAction {
  id           Int                 @id @default(autoincrement())
  profileId    Int
  type         TypeMouvementAction
  quantite     Int
  prixUnitaire Decimal
  montantTotal Decimal
  date         DateTime
  description  String?

  profile ActionnaireProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model ProcurationAssemblee {
  id           Int               @id @default(autoincrement())
  assembleeId  Int
  mandantId    Int
  mandataireId Int
  statut       StatutProcuration @default(EN_ATTENTE)
  notes        String?

  assemblee  Assemblee    @relation(fields: [assembleeId], references: [id], onDelete: Cascade)
  mandant    Gestionnaire @relation("procurationsMandant", fields: [mandantId], references: [id])
  mandataire Gestionnaire @relation("procurationsMandataire", fields: [mandataireId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assembleeId, mandantId])
}

// ============================================================
// BIBLIOTHÈQUE DOCUMENTAIRE
// ============================================================

model DocumentBibliotheque {
  id          Int          @id @default(autoincrement())
  titre       String
  type        TypeDocument
  description String?
  fichierUrl  String?
  fichierNom  String?
  annee       Int?
  estPublic   Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Documents RH stratégiques (CDC §13) — nature E, à l'échelle société ─────────
enum TypeDocumentStrategiqueRH {
  MANUEL_RH
  POLITIQUE_RH
  REGLEMENT_INTERIEUR
  CODE_CONDUITE
  CODE_ETHIQUE
  POLITIQUE_REMUNERATION
  POLITIQUE_DISCIPLINAIRE
  POLITIQUE_RECRUTEMENT
  POLITIQUE_FORMATION
  POLITIQUE_PROMOTION
  POLITIQUE_DIVERSITE
  POLITIQUE_SANTE_SECURITE
  POLITIQUE_CONFIDENTIALITE
  AUTRE
}

enum StatutDocumentStrategique {
  BROUILLON
  EN_VIGUEUR
  ARCHIVE
}

/// Document RH stratégique (manuel, politique, règlement, code) — une instance
/// société, versionnée par type ; une seule version EN_VIGUEUR par type à la fois.
model DocumentStrategiqueRH {
  id          Int                       @id @default(autoincrement())
  type        TypeDocumentStrategiqueRH
  titre       String
  reference   String?
  version     Int                       @default(1)
  description String?
  contenu     String?                   // texte/HTML éditable (optionnel)
  fichierUrl  String?                   // fichier uploadé (optionnel)
  statut      StatutDocumentStrategique @default(BROUILLON)
  dateEffet   DateTime?
  creePar     Int                       // User.id

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([statut])
}

// ============================================================
// SUPER ADMIN — SYSTÈME
// ============================================================

/// Paramètres globaux de la plateforme (clé-valeur)
model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  category  String   @default("platform")
  updatedAt DateTime @updatedAt
  updatedBy Int?
}

/// Journal de sécurité (connexions, tentatives, déconnexions forcées…)
model SecurityLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userEmail String?
  action    String
  ipAddress String?
  userAgent String?
  details   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

/// Permissions personnalisées par utilisateur
model UserPermission {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module     String
  permission String  
  granted    Boolean  @default(true)
  grantedBy  Int?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, module, permission])
  @@index([userId])
}

/// Configuration d'accès aux sections/pages par rôle gestionnaire
model RolePageAccess {
  id        Int              @id @default(autoincrement())
  role      RoleGestionnaire
  pageKey   String
  allowed   Boolean          @default(true)
  updatedBy Int?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([role, pageKey])
  @@index([role])
}

/// RBAC granulaire : permission (action) accordée à un rôle sur un module.
/// action ∈ LECTURE|CREATION|MODIFICATION|VALIDATION|EXPORT|SUPPRESSION_LOGIQUE
/// (cf. lib/permissionsRegistry.ts). Les overrides par utilisateur passent par
/// UserPermission avec permission = "ACTION:<module>:<action>".
model RolePermission {
  id        Int              @id @default(autoincrement())
  role      RoleGestionnaire
  module    String
  action    String
  allowed   Boolean          @default(true)
  updatedBy Int?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([role, module, action])
  @@index([role])
}

/// Modules de la plateforme — activation / désactivation
model SystemModule {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  nom         String
  description String?
  actif       Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  updatedBy   Int?
}

// ============================================================
// FACTURES DE VENTE
// Générées depuis VenteDirecte (comptant/crédit) ou en standalone (pro-forma)
// ============================================================

model FactureVente {
  id     Int                @id @default(autoincrement())
  numero String             @unique // ex: FAC-2026-00001
  type   TypeFactureVente
  statut StatutFactureVente @default(EMISE)

  // Source (optionnel — absent pour pro-forma standalone)
  venteDirecteId  Int?       @unique
  creditClientId  Int?
  receptionPackId Int?

  // PDV (snapshot + relation)
  pointDeVenteId Int?
  pdvNom         String?
  pdvAdresse     String?
  pdvTelephone   String?

  // Client (snapshot pour archivage pérenne)
  clientId        Int?
  clientNom       String
  clientTelephone String?
  clientAdresse   String?

  // Émetteur (snapshot nom + fonction/rôle dans l'entreprise au moment de l'émission)
  emiseParId       Int
  emiseParNom      String
  emiseParFonction String?

  // Montants
  montantHT    Decimal
  montantTVA   Decimal @default(0)
  montantTTC   Decimal
  montantPaye  Decimal @default(0)
  modePaiement String?

  dateEmission DateTime  @default(now())
  dateEcheance DateTime?
  notes        String?
  garantie     String?   // snapshot de la garantie du crédit (si facture issue d'un crédit)

  // Relations
  venteDirecte  VenteDirecte?         @relation("VenteDirecteFacture",  fields: [venteDirecteId],  references: [id])
  creditClient  CreditClient?         @relation("CreditClientFactures", fields: [creditClientId],  references: [id])
  receptionPack ReceptionProduitPack? @relation("ReceptionPackFactures", fields: [receptionPackId], references: [id])
  client        Client?               @relation("FacturesVenteClient",   fields: [clientId],        references: [id])
  pointDeVente  PointDeVente?         @relation("FacturesVentePDV",      fields: [pointDeVenteId],  references: [id])
  emisePar      User                  @relation("FacturesVenteEmises",   fields: [emiseParId],      references: [id])
  lignes        LigneFactureVente[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([emiseParId])
  @@index([clientId])
  @@index([pointDeVenteId])
  @@index([creditClientId])
  @@index([receptionPackId])
  @@index([type])
  @@index([statut])
}

model LigneFactureVente {
  id           Int     @id @default(autoincrement())
  factureId    Int
  designation  String
  unite        String?
  quantite     Float
  prixUnitaire Decimal
  montant      Decimal

  facture FactureVente @relation(fields: [factureId], references: [id], onDelete: Cascade)
}

// ============================================================
// OGRH — MODULE 1 : DOSSIER COLLABORATEUR
// Extension RH du Gestionnaire (nomenclature AfriGes)
// ============================================================

enum StatutCollaborateur {
  ACTIF
  EN_PERIODE_ESSAI
  SUSPENDU
  DEMISSIONNAIRE
  LICENCIE
  RETRAITE
  INACTIF
}

enum TypeContrat {
  CDI
  CDD
  STAGE
  CONSULTANT
  PRESTATAIRE
  FREELANCE
}

enum SituationMatrimoniale {
  CELIBATAIRE
  MARIE
  DIVORCE
  VEUF
  UNION_LIBRE
}

enum NiveauHierarchique {
  DIRECTION
  MANAGER
  SUPERVISEUR
  AGENT
  STAGIAIRE
}

enum TypeDocumentCollaborateur {
  CNI
  PASSEPORT
  DIPLOME
  CERTIFICAT
  CV
  ATTESTATION
  CONTRAT
  PHOTO_IDENTITE
  // Pièces administratives (dossier du personnel — CDC §3)
  LETTRE_MOTIVATION
  ACTE_NAISSANCE
  CASIER_JUDICIAIRE
  CERTIFICAT_MEDICAL
  ATTESTATION_CNSS
  COORDONNEES_BANCAIRES
  CONTACT_URGENCE
  CORRESPONDANCE
  AUTRE
}

/// Profil RH d'un Gestionnaire — données administratives et contractuelles
/// Lié à Gestionnaire (1-1) ; toutes les autres entités OGRH pointent vers ProfilRH.id
model ProfilRH {
  id             Int     @id @default(autoincrement())
  gestionnaireId Int     @unique

  // ── Identité ──────────────────────────────────────────────
  matricule             String                @unique  // ex: MAT-2026-0001 (auto-généré)
  emailProfessionnel    String?               @unique  // ex: prenom.nom@company.com (auto-généré à l'onboarding)
  dateNaissance         DateTime?
  lieuNaissance         String?
  sexe                  Sexe?
  nationalite           String?
  situationMatrimoniale SituationMatrimoniale?
  nbEnfants             Int                   @default(0)
  telephoneSecondaire   String?

  // ── Contrat & poste ───────────────────────────────────────
  typeContrat        TypeContrat?
  dateEmbauche       DateTime?
  dateFin            DateTime?              // CDD uniquement
  fonction           String?
  service            String?
  departement        String?
  niveauHierarchique NiveauHierarchique?
  statut             StatutCollaborateur    @default(ACTIF)
  notes              String?

  // ── Hiérarchie (manager direct = autre ProfilRH) ──────────
  managerId   Int?
  manager     ProfilRH?  @relation("HierarchieRH", fields: [managerId], references: [id])
  subordonnes ProfilRH[] @relation("HierarchieRH")

  // ── Horaires de référence ──────────────────────────────────
  configHoraireId Int?
  configHoraire   ConfigHoraire? @relation(fields: [configHoraireId], references: [id])

  // ── Relations ─────────────────────────────────────────────
  gestionnaire          Gestionnaire             @relation(fields: [gestionnaireId], references: [id])
  documents             DocumentCollaborateur[]
  soldesConges          SoldeConge[]
  demandesConge         DemandeConge[]
  missions              Mission[]                @relation("MissionsCollaborateur")
  missionsValidees      Mission[]                @relation("MissionsValidateurRH")
  documentsGeneres      DocumentRHGenere[]
  fichesPaie              FichePaie[]
  avancesSalaire          AvanceSalaire[]
  pretsEmploye            PretEmploye[]
  participationsFormation ParticipationFormation[]
  pointages               Pointage[]
  avantages               AvantageRH[]
  remboursementsFrais     RemboursementFrais[]
  evaluations             EvaluationRH[]          @relation("EvaluationsCollaborateur")
  evaluationsEffectuees   EvaluationRH[]          @relation("EvaluationsEffectuees")
  procedures              ProcedureDisciplinaire[]
  historiquesPoste        HistoriquePoste[]
  planCarriere            PlanCarriere?
  successions             SuccesseurPotentiel[]
  onboarding              OnboardingEmploye?
  competences             CollaborateurCompetence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([departement])
  @@index([managerId])
}

// ============================================================
// OGRH — MODULE 2 : HISTORIQUE ORGANISATIONNEL
// ============================================================

enum TypeMouvementCarriere {
  PROMOTION
  MUTATION
  EVOLUTION
  RECLASSEMENT
}

enum NiveauReadiness {
  PRET_MAINTENANT
  PRET_SOUS_1_AN
  PRET_1_A_3_ANS
  EN_DEVELOPPEMENT
}

/// Trace chaque changement de poste, de manager ou de département d'un collaborateur
model HistoriquePoste {
  id         Int      @id @default(autoincrement())
  profilRHId Int

  type       TypeMouvementCarriere? // PROMOTION | MUTATION | EVOLUTION | RECLASSEMENT

  // Avant
  ancienManagerId    Int?
  ancienneFonction   String?
  ancienService      String?
  ancienDepartement  String?
  ancienSalaire      Decimal?

  // Après
  nouveauManagerId   Int?
  nouvelleFonction   String?
  nouveauService     String?
  nouveauDepartement String?
  nouveauSalaire     Decimal?

  motif      String?
  modifiePar Int      // User.id de l'auteur du changement

  profilRH ProfilRH @relation(fields: [profilRHId], references: [id])

  createdAt DateTime @default(now())

  @@index([profilRHId])
  @@index([type])
  @@index([createdAt])
}

/// Plan de carrière individuel d'un collaborateur (upsert — 1 par profilRH)
model PlanCarriere {
  id                Int       @id @default(autoincrement())
  profilRHId        Int       @unique
  aspiration        String?
  prochainPosteVise String?
  dateRevision      DateTime?
  actions           String?   // plan d'actions concrètes
  notes             String?

  profilRH ProfilRH @relation(fields: [profilRHId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Poste stratégique nécessitant un plan de succession
model PosteCritique {
  id                  Int     @id @default(autoincrement())
  titre               String
  departement         String?
  description         String?
  nbSuccesseursRequis Int     @default(2)
  actif               Boolean @default(true)

  successeurs SuccesseurPotentiel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([actif])
}

/// Lien collaborateur ↔ poste critique avec niveau de préparation
model SuccesseurPotentiel {
  id              Int             @id @default(autoincrement())
  posteCritiqueId Int
  profilRHId      Int
  readiness       NiveauReadiness
  estTalentCle    Boolean         @default(false)
  notes           String?
  actif           Boolean         @default(true)  // soft delete (CDC §8)

  posteCritique PosteCritique @relation(fields: [posteCritiqueId], references: [id], onDelete: Cascade)
  profilRH      ProfilRH      @relation(fields: [profilRHId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([posteCritiqueId, profilRHId])
  @@index([posteCritiqueId])
  @@index([profilRHId])
  @@index([estTalentCle])
}

/// Documents uploadés pour le dossier d'un collaborateur
/// Jamais supprimés — versionning par compteur
model DocumentCollaborateur {
  id             Int                       @id @default(autoincrement())
  profilRHId     Int
  type           TypeDocumentCollaborateur
  nom            String
  fileUrl        String
  version        Int                       @default(1)
  notes          String?
  dateExpiration DateTime?                 // CNI, passeport, permis… (null = pas d'expiration)
  uploadePar     Int                       // User.id de l'agent qui a uploadé

  profilRH ProfilRH @relation(fields: [profilRHId], references: [id])

