// ============================================================
// UTILISATEURS & AUTH
// ============================================================

model User {
  id           Int          @id @default(autoincrement())
  uuid         String       @unique @default(uuid())
  nom          String
  prenom       String
  email        String       @unique
  photo        String?
  role         Role?
  telephone    String?
  adresse      String?
  passwordHash        String?
  etat                MemberStatus @default(ACTIF)
  tokenVersion        Int          @default(0)
  mustChangePassword  Boolean      @default(false)
  dateAdhesion        DateTime     @default(now())

  // Profil gestionnaire (rôle opérationnel)
  gestionnaire         Gestionnaire?

  // Finances
  wallet               Wallet?
  factures             Facture[]

  // Système
  auditLogs            AuditLog[]
  notifications           Notification[]
  preferenceNotifRH       PreferenceNotificationRH?
  piecesJustificatives    PieceJustificative[]
  userPermissions      UserPermission[]
  securityLogs         SecurityLog[]
  messagesEnvoyes      Message[]            @relation("MessagesEnvoyes")
  messagesRecus        Message[]            @relation("MessagesRecus")

  // Packs & fidélité      
  souscriptionsPacks   SouscriptionPack[]  
  pointsFidelite       PointsFidelite?

  clientsAssignes      Client[]             @relation("ClientAgentTerrain")
  clientAffectations   ClientAgentAffectation[] @relation("ClientAgentAffectations")

  // Collectes journalières
  collectesAgent       CollecteJournaliere[] @relation("CollectesAgent")
  collectesValidees    CollecteJournaliere[] @relation("CollectesValideur")

  // Comptabilité
  cloturesComptables   ClotureComptable[]
  ecrituresComptables  EcritureComptable[]
  rapprochements       RapprochementBancaire[]
  declarationsTVA      DeclarationTVA[]
  journalValidations   JournalValidation[]

  // Points de vente — cet user est RPV d'un PDV (1-1)
  pointDeVenteRPV      PointDeVente?        @relation("RPVPointDeVente")
  // PDV supervisés en tant que chef d'agence (1-N)
  pointsDeVenteChef    PointDeVente[]       @relation("ChefAgencePDV")
  // Affectations opérationnelles à des PDV / dépôts
  affectationsPDV      GestionnaireAffectation[]

  // Opérations stock
  anomaliesSignalees   AnomalieStock[]      @relation("AnomaliesSignalees")
  anomaliesTraitees    AnomalieStock[]      @relation("AnomaliesTraitees")
  receptionsRealisees  ReceptionApprovisionnement[] @relation("ReceptionnaireAppro")
  receptionsValidees   ReceptionApprovisionnement[] @relation("ValidateurAppro")
  transfertsCrees      TransfertStock[]     @relation("CreateurTransfert")
  transfertsValides    TransfertStock[]     @relation("ValidateurTransfert")
  inventairesRealises  InventaireSite[]     @relation("RealisateurInventaire")
  inventairesValides   InventaireSite[]     @relation("ValidateurInventaire")
  commandesInternes    CommandeInterne[]    @relation("DemandeurCommande")
  mouvementsStock      MouvementStock[]     @relation("MouvementsStock")
  bonsSortieCreePar    BonSortie[]          @relation("BonsSortieCreePar")
  bonsSortieValidePar  BonSortie[]          @relation("BonsSortieValidePar")
  demandesAjustement    DemandeAjustementStock[] @relation("DemandesAjustement")
  validationsAjustement DemandeAjustementStock[] @relation("ValidationsAjustement")

  // Caisse
  sessionsCaisseOuvertes CaissePDV[]          @relation("CaissesPDVRPV")
  sessionsCaisse         SessionCaisse[]      @relation("SessionsCaisseCaissier")
  operationsCaisse       OperationCaisse[]    @relation("OperationsCaisse")
  operationsCaissePDV    OperationCaissePDV[] @relation("OperationsCaissePDV")
  transfertsCaisse       TransfertCaisse[]    @relation("TransfertsCaisse")

  // Ventes directes
  ventesDirectes       VenteDirecte[]       @relation("VendeurVente")

  // Contrôle terrain
  visitesControle      VisiteControle[]     @relation("ControleurVisite")

  // Crédits clients
  creditsCreees                CreditClient[]       @relation("CreditCreateur")
  creditsValides               CreditClient[]       @relation("CreditValidateur")
  facturesVenteEmises          FactureVente[]       @relation("FacturesVenteEmises")
  remboursementsEnregistres    RemboursementCredit[]
  lignesSouscriptionTraitees   LigneSouscriptionProduit[] @relation("LignesTraitees")
  lignesCreditTraitees         LigneCreditClient[]        @relation("LignesCreditTraitees")

  // Visites terrain
  visitesEffectuees            VisiteClient[]       @relation("VisitesAgent")

  // Documents clients uploadés par cet utilisateur
  documentsUploades            ClientDocument[]     @relation("DocumentsUploades")
  // Transactions terrain enregistrées par cet agent
  transactionsAgent            ClientTransaction[]  @relation("TransactionsAgent")
  // Scores clients calculés par cet utilisateur
  scoresCalcules               ClientScoreHistorique[] @relation("ScoresCalcules")
  // Clients validés ou rejetés par ce RVC
  clientsValides               Client[]             @relation("ClientValidateur")

  // RIA
  depotsRIAValides             DepotInvestisseur[]      @relation("DepotsValides")
  retraitsRIAValides           RetraitInvestisseur[]    @relation("RetraitsValides")
  actionsRIAEffectuees         ActionRecouvrementRIA[]  @relation("ActionsRIAEffectuees")
  commissionsRIA               CommissionAgentRIA[]     @relation("CommissionsAgent")
  commissionsApprouvees        CommissionAgentRIA[]     @relation("CommissionsApprob")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Profil gestionnaire — rôle opérationnel + actionnaire
model Gestionnaire {
  id       Int              @id @default(autoincrement())
  memberId Int              @unique
  role     RoleGestionnaire
  actif    Boolean          @default(true)
  zone     String?          // Zone géographique de couverture (ex: "Cocody Nord")

  member                  User                   @relation(fields: [memberId], references: [id])
  assemblees              AssembleeParticipant[]
  actionnaireProfile      ActionnaireProfile?
  procurationsMandant     ProcurationAssemblee[] @relation("procurationsMandant")
  procurationsMandataire  ProcurationAssemblee[] @relation("procurationsMandataire")

  // OGRH
  profilRH                ProfilRH?

  // RIA
  profilRIA               ProfilInvestisseurRIA?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// POINTS DE VENTE & DÉPÔTS CENTRAUX
// Un PointDeVente peut être un PDV classique ou un dépôt central
// ============================================================

model PointDeVente {
  id        Int              @id @default(autoincrement())
  type      TypePointDeVente @default(POINT_DE_VENTE)
  code      String           @unique
  nom       String
  adresse   String?
  telephone String?
  actif     Boolean          @default(true)
  notes     String?

  // RPV responsable (type POINT_DE_VENTE uniquement, 1-1)
  rpvId Int?  @unique
  rpv   User? @relation("RPVPointDeVente", fields: [rpvId], references: [id])

  // Chef d'agence superviseur (peut superviser plusieurs PDV)
  chefAgenceId Int?
  chefAgence   User? @relation("ChefAgencePDV", fields: [chefAgenceId], references: [id])

  // Bulk pour clients
  clientsPDV ClientPointDeVente[]
     
  // Relations opérationnelles
  affectations          GestionnaireAffectation[]
  clients               Client[]
  stocks                StockSite[]
  sessionsCaisse        SessionCaisse[]
  caissesPDV            CaissePDV[]
  clotures              ClotureCaisse[]
  inventaires           InventaireSite[]
  mouvementsStock       MouvementStock[]
  ventesDirectes        VenteDirecte[]
  anomaliesStock        AnomalieStock[]
  bonsSortie            BonSortie[]
  transfertsOrigine     TransfertStock[]             @relation("TransfertOrigine")
  transfertsDestination TransfertStock[]             @relation("TransfertDestination")
  receptionsAppro       ReceptionApprovisionnement[]
  receptionsCommeOrigine ReceptionApprovisionnement[] @relation("ReceptionsEnTantQuOrigine")
  commandesInternes     CommandeInterne[]
  visitesControle       VisiteControle[]
  livraisonsPacks            ReceptionProduitPack[]
  collectes                  CollecteJournaliere[]
  demandesAjustement         DemandeAjustementStock[]
  lignesSouscriptionProduits LigneSouscriptionProduit[]
  lignesCreditPDV            LigneCreditClient[]          @relation("LignesCreditPDV")
  facturesVente              FactureVente[]               @relation("FacturesVentePDV")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

// Affectation d'un gestionnaire (caissier, magasinier, agent, etc.) à un PDV ou dépôt
model GestionnaireAffectation {
  id             Int          @id @default(autoincrement())
  userId         Int
  pointDeVenteId Int
  actif          Boolean      @default(true)
  dateDebut      DateTime     @default(now())
  dateFin        DateTime?
  notes          String?

  user         User         @relation(fields: [userId], references: [id])
  pointDeVente PointDeVente @relation(fields: [pointDeVenteId], references: [id])

  // Pas de @@unique : un user peut être ré-affecté au même PDV après une période d'absence
  // L'unicité d'affectation active se gère au niveau applicatif (actif = true)
  @@index([userId])
  @@index([pointDeVenteId])
  @@index([userId, pointDeVenteId, actif])
}

// ============================================================
// CLIENTS
// ============================================================

model Client {
  id                 Int               @id @default(autoincrement())

  // ── Champs legacy (ne pas supprimer) ──────────────────────
  nom                String
  prenom             String
  telephone          String            @unique
  adresse            String?
  etat               MemberStatus      @default(ACTIF)

  // ── Nouveaux champs identité ───────────────────────────────
  codeClient         String?           @unique  // auto-généré (ex: CLI-00042)
  sexe               Sexe?
  dateNaissance      DateTime?
  telephoneSecondaire String?
  quartier           String?
  ville              String?
  photoUrl           String?           // URL stockage photo client
  pieceIdentiteUrl   String?           // URL scan pièce d'identité
  numeroCNI          String?           @unique  // numéro CNI (unique si renseigné)

  // ── Activité & commerce ────────────────────────────────────
  activite           String?           // métier / secteur d'activité
  nomCommerce        String?           // nom de l'entreprise / boutique
  latitude           Float?            // coordonnée GPS latitude
  longitude          Float?            // coordonnée GPS longitude

  // ── Segment ────────────────────────────────────────────────
  segment            SegmentClient     @default(ORDINAIRE)

  // ── Type & crédit ──────────────────────────────────────────
  typeClient         TypeClient?       // COMPTANT ou CREDIT
  limiteCredit       Decimal?          // plafond de crédit accordé
  soldeActuel        Decimal?          @default(0) // solde en cours (mis à jour automatiquement)

  // ── Scoring (calculé automatiquement) ─────────────────────
  niveauRisque       NiveauRisque?     // FAIBLE / MOYEN / ELEVE / CRITIQUE
  scoreSolvabilite   Float?            // score 0–100

  // ── PDV de rattachement (optionnel) ───────────────────────
  pointDeVenteId Int?

  pointDeVente       PointDeVente?      @relation(fields: [pointDeVenteId], references: [id])

  agentTerrainId Int?
  agentTerrain       User?              @relation("ClientAgentTerrain", fields: [agentTerrainId], references: [id])

  agentAffectations  ClientAgentAffectation[]
  pointsDeVente      ClientPointDeVente[]
  tags               ClientTag[]
  souscriptionsPacks SouscriptionPack[]
  pointsFidelite     PointsFidelite?
  ventesDirectes     VenteDirecte[]
  lignesCollecte     LigneCollecte[]
  creditsClients     CreditClient[]
  visites            VisiteClient[]
  documents          ClientDocument[]
  transactions       ClientTransaction[]
  scoreHistorique    ClientScoreHistorique[]
  facturesVente      FactureVente[]           @relation("FacturesVenteClient")

  // ── Validation RVC (tous nullable — données existantes non impactées) ───
  motifRejet       String?    // raison du rejet par le responsable crédit
  validationParId  Int?       // User.id du RVC qui a statué
  validationPar    User?      @relation("ClientValidateur", fields: [validationParId], references: [id])
  dateValidation   DateTime?  // date de la décision (activation ou rejet)

  // RIA
  affectationsRIA  AffectationClientRIA[]
  financementsRIA  OperationFinancementRIA[] @relation("FinancementsRIAClient")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([typeClient])
  @@index([segment])
  @@index([niveauRisque])
  @@index([ville])
}

// ============================================================
// VISITES CLIENTS (tournées agents terrain)
// ============================================================

model VisiteClient {
  id         Int          @id @default(autoincrement())
  agentId    Int
  clientId   Int
  statut     StatutVisite @default(REALISEE)
  latitude   Float?
  longitude  Float?
  dateVisite DateTime     @default(now())
  notes      String?

  agent      User         @relation("VisitesAgent",  fields: [agentId],  references: [id])
  client     Client       @relation(fields: [clientId], references: [id])

  createdAt  DateTime     @default(now())

  @@index([agentId])
  @@index([clientId])
  @@index([dateVisite])
}

// Historique des affectations client ↔ agent terrain
// Permet un calcul de CA juste par période d'affectation (évite le double-comptage lors des réaffectations)
model ClientAgentAffectation {
  id        Int       @id @default(autoincrement())
  clientId  Int
  agentId   Int       // User.id du gestionnaire AGENT_TERRAIN
  dateDebut DateTime  @default(now())
  dateFin   DateTime?
  actif     Boolean   @default(true)
  notes     String?

  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agent     User      @relation("ClientAgentAffectations", fields: [agentId], references: [id])

  createdAt DateTime  @default(now())

  @@index([clientId])
  @@index([agentId])
  @@index([clientId, agentId, actif])
}

model ClientPointDeVente {
  id              Int @id @default(autoincrement())

  clientId        Int
  pointDeVenteId  Int

  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pointDeVente    PointDeVente  @relation(fields: [pointDeVenteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([clientId, pointDeVenteId])
  @@index([clientId])
  @@index([pointDeVenteId])
}

// ============================================================
// TAGS CLIENTS
// ============================================================

model Tag {
  id          Int            @id @default(autoincrement())
  nom         String         @unique
  couleur     String         @default("#6366f1") // hex couleur pour l'UI
  description String?
  segment     SegmentClient? // null = applicable à tous les segments
  actif       Boolean        @default(true)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  clients     ClientTag[]

  @@index([segment])
  @@index([actif])
}

// Table de jonction Client ↔ Tag (many-to-many)
model ClientTag {
  clientId  Int
  tagId     Int
  createdAt DateTime @default(now())

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([clientId, tagId])
  @@index([clientId])
  @@index([tagId])
}

// ============================================================
// DOCUMENTS CLIENTS
// ============================================================

model ClientDocument {
  id             Int                @id @default(autoincrement())
  clientId       Int
  client         Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)

  type           TypeDocumentClient @default(AUTRE)
  nom            String             // nom du fichier
  url            String             // URL de stockage
  uploadthingKey String?            // clé uploadthing si applicable
  taille         Int?               // taille en octets
  description    String?
  expireAt       DateTime?          // date d'expiration (ex : CNI)

  uploadePar     Int
  uploadeUser    User               @relation("DocumentsUploades", fields: [uploadePar], references: [id])

  createdAt      DateTime           @default(now())

  @@index([clientId])
  @@index([clientId, type])
}

// ============================================================
// TRANSACTIONS CLIENTS (historique financier unifié)
// ============================================================

model ClientTransaction {
  id            Int                   @id @default(autoincrement())
  clientId      Int
  client        Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)

  type          TypeTransactionClient
  montant       Decimal
  sens          String                // DEBIT | CREDIT (du point de vue du client)
  reference     String?               // référence de l'opération source
  description   String?

  // Lien polymorphique vers la source (pas de FK Prisma — souplesse maximale)
  sourceType    String?               // VERSEMENT_PACK | REMBOURSEMENT_CREDIT | VENTE_DIRECTE | COLLECTE
  sourceId      Int?

  agentId       Int?
  agent         User?                 @relation("TransactionsAgent", fields: [agentId], references: [id])

  dateOperation DateTime              @default(now())
  createdAt     DateTime              @default(now())

  @@index([clientId])
  @@index([clientId, type])
  @@index([clientId, dateOperation])
  @@index([sourceType, sourceId])
}

// ============================================================
// HISTORIQUE DES SCORES / RISQUE CLIENTS
// ============================================================

model ClientScoreHistorique {
  id               Int          @id @default(autoincrement())
  clientId         Int
  client           Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  niveauRisque     NiveauRisque
  scoreSolvabilite Float
  raison           String?      // REMBOURSEMENT | RETARD | RECALCUL_AUTO | MANUEL | CREATION

  calculePar       Int?
  calculeUser      User?        @relation("ScoresCalcules", fields: [calculePar], references: [id])

  createdAt        DateTime     @default(now())

  @@index([clientId])
  @@index([clientId, createdAt])
}

// ============================================================
// CRÉDITS CLIENTS
// ============================================================

model CreditClient {
  id               Int          @id @default(autoincrement())
  reference        String       @unique // ex: CRD-20260521-001

  clientId         Int
  client           Client       @relation(fields: [clientId], references: [id])

  pointDeVenteId   Int?
  // pas de relation directe ici — PointDeVente n'a pas de backlink crédit (optionnel)

  statut           StatutCredit @default(EN_ATTENTE_VALIDATION)

  // Montants
  montantTotal     Decimal
  montantRembourse Decimal      @default(0)
  soldeRestant     Decimal

  // Échéancier
  dureeJours       Int          // nombre de jours de remboursement
  dateDebut        DateTime     // date à partir de laquelle les remboursements commencent
  dateEcheanceFin  DateTime     // = dateDebut + dureeJours (calculé à la validation)
  montantJournalier Decimal     // = montantTotal / dureeJours (calculé à la validation)

  // Pénalités
  tauxPenalite     Decimal      @default(0) // % par jour de retard

  // Métadonnées
  garantie         String?
  observations     String?

  // Traçabilité
  creeParId        Int
  creePar          User         @relation("CreditCreateur", fields: [creeParId], references: [id])
  valideParId      Int?
  validePar        User?        @relation("CreditValidateur", fields: [valideParId], references: [id])
  dateValidation   DateTime?

  // Consommation crédit via livraisons
  montantConsomme  Decimal      @default(0) // somme des VenteDirecte au statut CREDIT_LIVRE liées

  lignes           LigneCreditClient[]
  echeances        EcheanceCredit[]
  remboursements   RemboursementCredit[]
  livraisons       VenteDirecte[]
  facturesVente    FactureVente[]  @relation("CreditClientFactures")
  financementsRIA  OperationFinancementRIA[] @relation("FinancementsRIACredit")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([statut])
  @@index([pointDeVenteId])
  @@index([dateDebut])
}

model LigneCreditClient {
  id           Int     @id @default(autoincrement())
  creditId     Int
  produitId    Int?    // nullable : produit hors catalogue non encore créé

  // Snapshot au moment de la vente (conservé même si produit modifié)
  produitNom       String
  produitNomSaisi  String?  // saisie libre originale — pour traçabilité si produit substitué
  quantite         Int
  prixUnitaire     Decimal
  remise           Decimal  @default(0)
  montantLigne     Decimal

  // Traçabilité livraison (comme LigneSouscriptionProduit)
  statut            StatutLigneCreditClient @default(EN_ATTENTE)
  estNouveauProduit Boolean                @default(false)
  notes             String?

  // PDV cible — dénormalisé depuis credit.pointDeVenteId pour agrégations logistique
  pointDeVenteId Int?
  pointDeVente   PointDeVente? @relation("LignesCreditPDV", fields: [pointDeVenteId], references: [id])

  // Substitution
  produitSubstitutId Int?
  produitSubstitut   Produit? @relation("LigneCreditSubstitut", fields: [produitSubstitutId], references: [id])

  // Traitement
  traiteParId    Int?
  traitePar      User?     @relation("LignesCreditTraitees", fields: [traiteParId], references: [id])
  dateTraitement DateTime?

  credit  CreditClient @relation(fields: [creditId], references: [id], onDelete: Cascade)
  produit Produit?     @relation("LigneCreditProduit", fields: [produitId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creditId])
  @@index([produitId])
  @@index([pointDeVenteId, statut])
  @@index([statut])
}

model EcheanceCredit {
  id             Int                  @id @default(autoincrement())
  creditId       Int
  numeroEcheance Int                  // 1, 2, 3 … dureeJours
  dateEcheance   DateTime
  montantDu      Decimal
  montantPaye    Decimal              @default(0)
  statut         StatutEcheanceCredit @default(EN_ATTENTE)
  penalite       Decimal              @default(0) // pénalité accumulée si retard

  credit CreditClient @relation(fields: [creditId], references: [id], onDelete: Cascade)

  @@index([creditId])
  @@index([statut])
  @@index([dateEcheance])
  @@index([creditId, statut])
}

model RemboursementCredit {
  id                Int          @id @default(autoincrement())
  creditId          Int
  montant           Decimal
  dateRemboursement DateTime     @default(now())
  modePaiement      TypePaiement @default(ESPECES)
  notes             String?
  // EN_ATTENTE_CAISSIER = enregistré par agent/admin, en attente confirmation caissier
  // CONFIRME           = caissier a encaissé physiquement (effet financier appliqué)
  // REJETE             = caissier a rejeté (erreur de saisie, fraude, etc.)
  statut            String       @default("EN_ATTENTE_CAISSIER")

  enregistreParId   Int
  enregistrePar     User         @relation(fields: [enregistreParId], references: [id])

  credit CreditClient @relation(fields: [creditId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([creditId])
  @@index([statut])
  @@index([dateRemboursement])
}

// ============================================================
// COLLECTES JOURNALIÈRES (terrain)
// ============================================================

// Session de collecte d'un agent pour une journée donnée
model CollecteJournaliere {
  id              Int             @id @default(autoincrement())
  reference       String          @unique  // ex: COL-20260521-001
  agentId         Int                      // User AGENT_TERRAIN
  pointDeVenteId  Int?                     // PDV de rattachement de l'agent
  dateCollecte    DateTime                 // jour de la tournée
  statut          StatutCollecte  @default(EN_COURS)
  montantPrevu    Decimal         @default(0) // somme des montantAttendu des lignes
  montantCollecte Decimal         @default(0) // somme réellement encaissée
  notes           String?

  // Validation admin
  valideParId     Int?
  dateValidation  DateTime?

  agent           User            @relation("CollectesAgent",    fields: [agentId],        references: [id])
  validePar       User?           @relation("CollectesValideur", fields: [valideParId],    references: [id])
  pointDeVente    PointDeVente?   @relation(fields: [pointDeVenteId], references: [id])
  lignes          LigneCollecte[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
  @@index([statut])
  @@index([dateCollecte])
  @@index([pointDeVenteId])
}

// Un encaissement dans une session de collecte → lié à une SouscriptionPack
model LigneCollecte {
  id               Int                  @id @default(autoincrement())
  collecteId       Int
  clientId         Int
  souscriptionId   Int                  // SouscriptionPack concernée
  montantAttendu   Decimal              // montant de l'échéance prévue
  montantCollecte  Decimal              @default(0)
  statut           StatutLigneCollecte  @default(EN_ATTENTE)
  notes            String?

  // Anti-fraude : coordonnées GPS + mode de paiement enregistrés au moment de la collecte
  latitude         Float?
  longitude        Float?
  modePaiement     String?              // ESPECES | MOBILE_MONEY | CHEQUE | VIREMENT

  // Lien vers le VersementPack créé lors de la validation (null avant validation)
  versementPackId  Int?                 @unique

  collecte         CollecteJournaliere  @relation(fields: [collecteId],     references: [id], onDelete: Cascade)
  client           Client               @relation(fields: [clientId],       references: [id])
  souscription     SouscriptionPack     @relation(fields: [souscriptionId], references: [id])
  versementPack    VersementPack?       @relation(fields: [versementPackId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([collecteId])
  @@index([clientId])
  @@index([souscriptionId])
}
  
// ============================================================
// FOURNISSEURS
// ============================================================

model Fournisseur {
  id        Int      @id @default(autoincrement())
  nom       String
  contact   String?
  telephone String?
  email     String?
  adresse   String?
  notes     String?
  actif     Boolean  @default(true)

  receptions ReceptionApprovisionnement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}     

// ============================================================
// PRODUITS & STOCK
// ============================================================

model Produit {
  id           Int     @id @default(autoincrement())
  reference    String? @unique // code interne produit
  nom          String
  description  String?
  categorie    String?
  unite        String? // "kg", "litre", "unité", etc.
  prixUnitaire Decimal
  prixAchat    Decimal?  // 👈 nouveau champ (nullable conseillé)
  alerteStock  Int     @default(0) // seuil d'alerte global
  actif        Boolean @default(true)

  // Stock localisé par site (remplace l'ancien champ global stock)
  stocks               StockSite[]
  mouvements           MouvementStock[]  

  // Packs & fidélité
  lignesReceptionPack  LigneReceptionPack[]
  recompensesFidelite  RecompenseFidelite[]
  packsCibleProduit    Pack[]                    @relation("PackProduitCible")

  // Opérations stock
  anomalies            AnomalieStock[]
  lignesVenteDirecte   LigneVenteDirecte[]
  lignesTransfert      LigneTransfertStock[]
  lignesReceptionAppro LigneReceptionAppro[]
  lignesInventaire     LigneInventaireSite[]
  lignesCommande       LigneCommandeInterne[]
  lignesBonSortie      LigneBonSortie[]

  // Crédits clients
  lignesCreditProduit    LigneCreditClient[] @relation("LigneCreditProduit")
  lignesCreditSubstitut  LigneCreditClient[] @relation("LigneCreditSubstitut")

  // Ajustements stock
  demandesAjustement   DemandeAjustementStock[]

  // Lignes souscription produits
  lignesSouscriptionDemande   LigneSouscriptionProduit[] @relation("LigneProduitDemande")
  lignesSouscriptionSubstitut LigneSouscriptionProduit[] @relation("LigneProduitSubstitut")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Stock d'un produit sur un site précis (PDV ou dépôt central)
model StockSite {
  id             Int          @id @default(autoincrement())
  produitId      Int
  pointDeVenteId Int
  quantite           Int      @default(0)  // 4.1 disponible — physiquement vendable
  quantiteReservee   Int      @default(0)  // 4.2 réservé — engagé (ventes crédit en attente d'approbation)
  quantiteEnTransit  Int      @default(0)  // 4.3 en transit — commandé, non encore réceptionné
  quantiteEndommagee Int      @default(0)  // 4.4 endommagé — non vendable (perte/casse mis de côté)
  // 4.5 stockTheorique = quantite + quantiteReservee + quantiteEnTransit - quantiteEndommagee (calculé)
  alerteStock    Int?         // seuil d'alerte spécifique au site (override global)

  produit      Produit      @relation(fields: [produitId], references: [id])
  pointDeVente PointDeVente @relation(fields: [pointDeVenteId], references: [id])

  @@unique([produitId, pointDeVenteId])
  @@index([pointDeVenteId])
}
  
// Journal de chaque mouvement de stock (entrée / sortie / ajustement)
model MouvementStock {
  id             Int              @id @default(autoincrement())
  produitId      Int
  pointDeVenteId Int?             // PDV ou dépôt concerné (nullable pour rétrocompat)
  type           TypeMouvement
  typeEntree     TypeEntreeStock? // précision si type == ENTREE
  typeSortie     TypeSortieStock? // précision si type == SORTIE
  quantite       Int
  prixUnitaire   Decimal?         // prix de vente au client (renseigné pour les sorties livraison pack)
  motif          String?
  reference      String           @unique
  dateMouvement  DateTime         @default(now())
  operateurId    Int?             // userId de l'opérateur

  // Références aux documents sources (traçabilité)
  receptionApproId Int?
  transfertStockId Int?
  venteDirecteId   Int?
  souscriptionId   Int?  // pour livraison pack
  bonSortieId      Int?  // pour sortie exceptionnelle (perte, casse, don…)

  produit      Produit       @relation(fields: [produitId], references: [id])
  pointDeVente PointDeVente? @relation(fields: [pointDeVenteId], references: [id])
  operateur    User?         @relation("MouvementsStock", fields: [operateurId], references: [id])

  @@index([produitId])
  @@index([pointDeVenteId])
  @@index([type])
  @@index([dateMouvement])
}

// ============================================================
// RÉCEPTIONS D'APPROVISIONNEMENT (Magasinier / Agent Logistique)
// ============================================================

model ReceptionApprovisionnement {
  id        Int                  @id @default(autoincrement())
  reference String               @unique
  type      TypeReceptionAppro
  statut    StatutReceptionAppro @default(BROUILLON)

  // Site qui réceptionne (PDV ou dépôt)
  pointDeVenteId Int
  pointDeVente   PointDeVente @relation(fields: [pointDeVenteId], references: [id])

  // Pour réception FOURNISSEUR
  fournisseurId  Int?
  fournisseur    Fournisseur? @relation(fields: [fournisseurId], references: [id])
  fournisseurNom String?      // si fournisseur non encore enregistré

  // Pour réception INTERNE (depuis un autre dépôt / siège)
  origineId    Int?
  origineNom   String?
  origineDepot PointDeVente? @relation("ReceptionsEnTantQuOrigine", fields: [origineId], references: [id])

  datePrevisionnelle DateTime
  dateReception      DateTime?

  // Contrôle qualité — saisie obligatoire avant mise en stock
  controlQualite Boolean @default(false)
  notesQualite   String?
  notes          String?

  receptionneParId Int
  receptionnePar   User  @relation("ReceptionnaireAppro", fields: [receptionneParId], references: [id])
  valideParId      Int?
  validePar        User? @relation("ValidateurAppro", fields: [valideParId], references: [id])

  lignes LigneReceptionAppro[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([type])   
  @@index([pointDeVenteId])
}   
  
model LigneReceptionAppro {
  id               Int     @id @default(autoincrement())
  receptionId      Int
  produitId        Int   
  quantiteAttendue Int
  quantiteRecue    Int?
  prixUnitaire     Decimal?
  etatQualite      String? // "BON" | "DEFECTUEUX" | "PARTIEL"
  notes            String?

  reception ReceptionApprovisionnement @relation(fields: [receptionId], references: [id], onDelete: Cascade)
  produit   Produit                    @relation(fields: [produitId], references: [id])
}

// ============================================================
// TRANSFERTS DE STOCK (entre PDV et/ou dépôts)
// ============================================================

model TransfertStock {
  id        Int                  @id @default(autoincrement())
  reference String               @unique
  statut    StatutTransfertStock @default(EN_COURS)

  origineId     Int
  origine       PointDeVente @relation("TransfertOrigine", fields: [origineId], references: [id])
  destinationId Int
  destination   PointDeVente @relation("TransfertDestination", fields: [destinationId], references: [id])

  creeParId   Int
  creePar     User  @relation("CreateurTransfert", fields: [creeParId], references: [id])
  valideParId Int?
  validePar   User? @relation("ValidateurTransfert", fields: [valideParId], references: [id])

  dateExpedition DateTime?
  dateReception  DateTime?
  notes          String?

  lignes LigneTransfertStock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([origineId])
  @@index([destinationId])
}

model LigneTransfertStock {
  id          Int      @id @default(autoincrement())
  transfertId Int
  produitId   Int
  quantite    Int
  prixUnit    Decimal?

  transfert TransfertStock @relation(fields: [transfertId], references: [id], onDelete: Cascade)
  produit   Produit        @relation(fields: [produitId], references: [id])
}

// ============================================================
// INVENTAIRES (PDV et dépôts)
// ============================================================

model InventaireSite {
  id             Int              @id @default(autoincrement())
  reference      String           @unique
  statut         StatutInventaire @default(EN_COURS)
  pointDeVenteId Int
  dateInventaire DateTime         @default(now())
  notes          String?

  realiseParId Int
  realisePar   User  @relation("RealisateurInventaire", fields: [realiseParId], references: [id])
  valideParId  Int?
  validePar    User? @relation("ValidateurInventaire", fields: [valideParId], references: [id])

  pointDeVente PointDeVente         @relation(fields: [pointDeVenteId], references: [id])
  lignes       LigneInventaireSite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([pointDeVenteId])
}

model LigneInventaireSite {
  id                Int    @id @default(autoincrement())
  inventaireId      Int
  produitId         Int
  quantiteSysteme   Int    // quantité selon le système
  quantiteConstatee Int    // quantité réelle comptée
  ecart             Int    // = constatée - système

  inventaire InventaireSite @relation(fields: [inventaireId], references: [id], onDelete: Cascade)
  produit    Produit        @relation(fields: [produitId], references: [id])
}

// ============================================================
// COMMANDES INTERNES (réapprovisionnement demandé par un PDV/dépôt)
// ============================================================

model CommandeInterne {
  id             Int                   @id @default(autoincrement())
  reference      String                @unique
  statut         StatutCommandeInterne @default(BROUILLON)
  demandeurId    Int
  demandeur      User                  @relation("DemandeurCommande", fields: [demandeurId], references: [id])
  pointDeVenteId Int
  pointDeVente   PointDeVente          @relation(fields: [pointDeVenteId], references: [id])
  notes          String?

  lignes LigneCommandeInterne[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([pointDeVenteId])
}

model LigneCommandeInterne {
  id               Int    @id @default(autoincrement())
  commandeId       Int
  produitId        Int
  quantiteDemandee Int
  quantiteValidee  Int?

  commande CommandeInterne @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  produit  Produit         @relation(fields: [produitId], references: [id])
}

// ============================================================
// BONS DE SORTIE EXCEPTIONNELS (pertes, casses, dons, conso interne)
// Pour les sorties groupant plusieurs produits — document formel imprimable
// ============================================================

enum StatutBonSortie {
  BROUILLON
  VALIDE
  ANNULE
}

model BonSortie {
  id             Int             @id @default(autoincrement())
  reference      String          @unique
  typeSortie     TypeSortieStock // PERTE, CASSE, DON, CONSOMMATION_INTERNE, LIVRAISON_CLIENT
  statut         StatutBonSortie @default(BROUILLON)
  pointDeVenteId Int
  motif          String
  notes          String?
  creeParId      Int
  valideParId    Int?

  pointDeVente PointDeVente @relation(fields: [pointDeVenteId], references: [id])
  creePar      User         @relation("BonsSortieCreePar", fields: [creeParId], references: [id])
  validePar    User?        @relation("BonsSortieValidePar", fields: [valideParId], references: [id])
  lignes       LigneBonSortie[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([pointDeVenteId])
  @@index([typeSortie])
}

model LigneBonSortie {
  id          Int      @id @default(autoincrement())
  bonSortieId Int
  produitId   Int
  quantite    Int
  prixUnit    Decimal?

  bonSortie BonSortie @relation(fields: [bonSortieId], references: [id], onDelete: Cascade)
  produit   Produit   @relation(fields: [produitId], references: [id])
}

// ============================================================
// ANOMALIES STOCK
// ============================================================

model AnomalieStock {
  id             Int            @id @default(autoincrement())
  reference      String         @unique
  produitId      Int
  pointDeVenteId Int?
  type           TypeAnomalie
  quantite       Int
  description    String
  statut         StatutAnomalie @default(EN_ATTENTE)
  signalePar     Int
  traitePar      Int?
  commentaire    String?

  produit      Produit       @relation(fields: [produitId], references: [id])
  pointDeVente PointDeVente? @relation(fields: [pointDeVenteId], references: [id])
  magasinier   User          @relation("AnomaliesSignalees", fields: [signalePar], references: [id])
  traiteur     User?         @relation("AnomaliesTraitees", fields: [traitePar], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([produitId])
  @@index([statut])
}

// Demande d'ajustement de stock — doit être approuvée par un admin avant application
model DemandeAjustementStock {
  id               Int                      @id @default(autoincrement())
  produitId        Int
  pointDeVenteId   Int
  ancienneQuantite Int
  nouvelleQuantite Int
  justification    String
  statut           StatutDemandeAjustement  @default(EN_ATTENTE)
  source           String                   @default("ADMIN") // "ADMIN" | "MAGAZINIER"

  demandeurId           Int
  validateurId          Int?
  commentaireValidation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  produit      Produit      @relation(fields: [produitId], references: [id])
  pointDeVente PointDeVente @relation(fields: [pointDeVenteId], references: [id])
  demandeur    User         @relation("DemandesAjustement",    fields: [demandeurId],  references: [id])
  validateur   User?        @relation("ValidationsAjustement", fields: [validateurId], references: [id])

  @@index([statut])
  @@index([produitId])
  @@index([pointDeVenteId])
}

// ============================================================
// CAISSE — Grande caisse (Caissier) + Petite caisse RPV
// ============================================================

model SessionCaisse {
  id             Int                 @id @default(autoincrement())
  caissierNom    String
  caissierId     Int                 // FK déclarée ci-dessous
  pointDeVenteId Int?
  fondsCaisse    Decimal             @default(0)
  statut         StatutSessionCaisse @default(OUVERTE)
  dateOuverture  DateTime            @default(now())
  dateFermeture  DateTime?
  notes          String?

  pointDeVente   PointDeVente?    @relation(fields: [pointDeVenteId], references: [id])
  caissier       User             @relation("SessionsCaisseCaissier", fields: [caissierId], references: [id])
  operations     OperationCaisse[]
  transferts     TransfertCaisse[]
  clotures       ClotureCaisse[]
  caissesPDV     CaissePDV[]
  ventesDirectes VenteDirecte[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Petite caisse RPV — liée automatiquement à la grande caisse du caissier
model CaissePDV {
  id              Int                 @id @default(autoincrement())
  nom             String
  rpvId           Int                 // FK déclarée ci-dessous
  pointDeVenteId  Int
  sessionCaisseId Int?                // grande caisse associée
  fondsCaisse     Decimal             @default(0)
  statut          StatutSessionCaisse @default(OUVERTE)
  dateOuverture   DateTime            @default(now())
  dateFermeture   DateTime?
  notes           String?

  pointDeVente  PointDeVente   @relation(fields: [pointDeVenteId], references: [id])
  rpv           User           @relation("CaissesPDVRPV", fields: [rpvId], references: [id])
  sessionCaisse SessionCaisse? @relation(fields: [sessionCaisseId], references: [id])
  operations    OperationCaissePDV[]
  ventesDirectes VenteDirecte[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OperationCaissePDV {
  id           Int                    @id @default(autoincrement())
  caissePDVId  Int
  type         TypeOperationCaisse
  mode         ModePaiement?
  categorie    CategorieDecaissement?
  montant      Decimal
  motif        String
  reference    String                 @unique
  operateurNom String
  operateurId  Int
  createdAt    DateTime               @default(now())

  caissePDV CaissePDV @relation(fields: [caissePDVId], references: [id])
  operateur User      @relation("OperationsCaissePDV", fields: [operateurId], references: [id])
}

model OperationCaisse {
  id           Int                    @id @default(autoincrement())
  sessionId    Int
  type         TypeOperationCaisse
  mode         ModePaiement?
  categorie    CategorieDecaissement?
  montant      Decimal
  motif        String
  reference    String                 @unique
  pieceJointe  String?
  operateurNom String
  operateurId  Int
  createdAt    DateTime               @default(now())

  session   SessionCaisse @relation(fields: [sessionId], references: [id])
  operateur User          @relation("OperationsCaisse", fields: [operateurId], references: [id])
}

model TransfertCaisse {
  id           Int    @id @default(autoincrement())
  sessionId    Int
  origine      String
  destination  String
  montant      Decimal
  motif        String?
  reference    String @unique
  operateurNom String
  operateurId  Int
  createdAt    DateTime @default(now())

  session   SessionCaisse @relation(fields: [sessionId], references: [id])
  operateur User          @relation("TransfertsCaisse", fields: [operateurId], references: [id])
}

model ClotureCaisse {
  id                       Int      @id @default(autoincrement())
  date                     DateTime
  caissierNom              String
  pointDeVenteId           Int?
  totalVentes              Int
  montantTotal             Decimal
  panierMoyen              Decimal
  nbClients                Int
  notes                    String?
  sessionId                Int?
  fondsCaisse              Decimal  @default(0)
  totalEncaissementsAutres Decimal  @default(0)
  totalDecaissements       Decimal  @default(0)
  totalTransferts          Decimal  @default(0)
  soldeTheorique           Decimal  @default(0)
  soldeReel                Decimal?
  ecart                    Decimal?

  pointDeVente PointDeVente?  @relation(fields: [pointDeVenteId], references: [id])
  session      SessionCaisse? @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())

  // Une seule clôture par PDV par session (pas par date brute)
  @@unique([sessionId, pointDeVenteId])
}

// ============================================================
// VENTES DIRECTES (hors packs)
// ============================================================

model VenteDirecte {
  id        Int                @id @default(autoincrement())
  reference String             @unique
  statut    StatutVenteDirecte @default(BROUILLON)

  pointDeVenteId  Int
  vendeurId       Int           // User (RPV, agent terrain, magasinier, admin, etc.)
  modePaiement    ModePaiementVente
  montantTotal    Decimal
  montantPaye     Decimal
  monnaieRendue   Decimal       @default(0)
  notes           String?

  // Client enregistré ou walk-in
  clientId        Int?
  clientNom       String?       // pour les clients non enregistrés
  clientTelephone String?

  // Lien crédit (optionnel — renseigné si modePaiement = CREDIT)
  creditClientId  Int?
  creditClient    CreditClient? @relation(fields: [creditClientId], references: [id])

  // Caisse associée (petite ou grande)
  caissePDVId     Int?          // petite caisse RPV
  sessionCaisseId Int?          // grande caisse caissier

  pointDeVente  PointDeVente   @relation(fields: [pointDeVenteId], references: [id])
  vendeur       User           @relation("VendeurVente", fields: [vendeurId], references: [id])
  client        Client?        @relation(fields: [clientId], references: [id])
  caissePDV     CaissePDV?     @relation(fields: [caissePDVId], references: [id])
  sessionCaisse SessionCaisse? @relation(fields: [sessionCaisseId], references: [id])
  lignes        LigneVenteDirecte[]
  factureVente  FactureVente?        @relation("VenteDirecteFacture")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([pointDeVenteId])
  @@index([vendeurId])
  @@index([creditClientId])
}

model LigneVenteDirecte {
  id           Int     @id @default(autoincrement())
  venteId      Int
  produitId    Int?    // nullable si produit hors catalogue
  produitNom   String? // nom libre saisi par l'agent si hors catalogue
  quantite     Int
  prixUnitaire Decimal
  montant      Decimal

  vente   VenteDirecte @relation(fields: [venteId], references: [id], onDelete: Cascade)
  produit Produit?     @relation(fields: [produitId], references: [id])
}

// ============================================================
// CONTRÔLE TERRAIN
// ============================================================

model VisiteControle {
  id             Int                  @id @default(autoincrement())
  reference      String               @unique
  statut         StatutVisiteControle @default(PLANIFIEE)
  controleurId   Int
  pointDeVenteId Int?                 // PDV visité (null = visite multi-sites)
  datePlanifiee  DateTime
  dateRealise    DateTime?
  objectif       String
  notes          String?

  controleur   User          @relation("ControleurVisite", fields: [controleurId], references: [id])
  pointDeVente PointDeVente? @relation(fields: [pointDeVenteId], references: [id])
  rapports     RapportControle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([controleurId])
}

model RapportControle {
  id              Int     @id @default(autoincrement())
  visiteId        Int
  titre           String
  contenu         String
  recommandations String?
  // Destinataires séparés par virgule: "ADMIN,CHEF_AGENCE"
  destinataires   String?

  visite  VisiteControle  @relation(fields: [visiteId], references: [id], onDelete: Cascade)
  alertes AlerteRapport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AlerteRapport {
  id        Int                  @id @default(autoincrement())
  rapportId Int
  niveau    NiveauAlerteControle
  message   String

  rapport   RapportControle @relation(fields: [rapportId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
}

// ============================================================
// WALLET & TRANSACTIONS
// ============================================================

model Wallet {
  id           Int     @id @default(autoincrement())
  memberId     Int     @unique
  soldeGeneral Decimal @default(0.0)
  soldeTontine Decimal @default(0.0)
  soldeCredit  Decimal @default(0.0)

  member       User               @relation(fields: [memberId], references: [id])
  transactions WalletTransaction[]
  paiements    Paiement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WalletTransaction {
  id          Int             @id @default(autoincrement())
  walletId    Int
  type        TransactionType
  montant     Decimal
  description String?
  reference   String          @unique

  wallet Wallet @relation(fields: [walletId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// FACTURES & PAIEMENTS
// ============================================================

model Facture {
  id        Int           @id @default(autoincrement())
  reference String        @unique
  memberId  Int
  montant   Decimal
  type      TypeFacture
  statut    StatutFacture

  member    User       @relation(fields: [memberId], references: [id])
  paiements Paiement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Paiement {
  id        Int          @id @default(autoincrement())
  factureId Int
  walletId  Int
  montant   Decimal
  type      TypePaiement
  reference String       @unique
  createdAt DateTime     @default(now())

  facture Facture @relation(fields: [factureId], references: [id])
  wallet  Wallet  @relation(fields: [walletId], references: [id])
}

// ============================================================
// PACKS AfriSime
// ============================================================

model Pack {
  id                 Int                @id @default(autoincrement())
  nom                String
  type               TypePack
  description        String?
  actif              Boolean            @default(true)
  dureeJours         Int?
  frequenceVersement FrequenceVersement @default(HEBDOMADAIRE)
  montantVersement   Decimal?
  formuleRevendeur   FormuleRevendeur?
  montantCredit      Decimal?
  montantSeuil       Decimal?
  produitCibleId     Int?
  produitCible       Produit?           @relation("PackProduitCible", fields: [produitCibleId], references: [id])
  bonusPourcentage   Decimal?
  cyclesBonusTrigger Int?
  acomptePercent     Decimal?
  pointsParTranche   Int?
  montantTranche     Decimal?

  souscriptions SouscriptionPack[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
  
model SouscriptionPack {
  id                 Int                 @id @default(autoincrement())
  packId             Int
  pack               Pack                @relation(fields: [packId], references: [id])
  userId             Int?
  user               User?               @relation(fields: [userId], references: [id])
  clientId           Int?
  client             Client?             @relation(fields: [clientId], references: [id])
  statut             StatutSouscription  @default(EN_ATTENTE)
  formuleRevendeur   FormuleRevendeur?
  frequenceVersement FrequenceVersement?
  dateDebut          DateTime            @default(now())
  dateFin            DateTime?   
  dateCloture        DateTime?
  montantTotal       Decimal
  montantVerse       Decimal             @default(0)
  montantRestant     Decimal
  numeroCycle        Int                 @default(1)
  bonusObtenu        Boolean             @default(false)
  notes              String?
  enregistrePar      String?

  versements     VersementPack[]
  echeances      EcheancePack[]
  receptions     ReceptionProduitPack[]
  lignesCollecte LigneCollecte[]
  lignesProduits LigneSouscriptionProduit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VersementPack {
  id             Int                 @id @default(autoincrement())
  souscriptionId Int
  souscription   SouscriptionPack    @relation(fields: [souscriptionId], references: [id])
  type           TypeVersement
  montant        Decimal
  statut         StatutVersementPack @default(PAYE)
  datePrevue     DateTime?
  datePaiement   DateTime            @default(now())
  reference      String?             @unique
  notes          String?
  encaisseParId  Int?
  encaisseParNom String?

  ligneCollecte  LigneCollecte?  // relation inverse (1 versement ↔ 1 ligne collecte max)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EcheancePack {
  id             Int                 @id @default(autoincrement())
  souscriptionId Int
  souscription   SouscriptionPack    @relation(fields: [souscriptionId], references: [id])
  numero         Int
  montant        Decimal
  datePrevue     DateTime
  datePaiement   DateTime?
  statut         StatutVersementPack @default(EN_ATTENTE)
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([souscriptionId, numero])
}

model ReceptionProduitPack {
  id             Int                 @id @default(autoincrement())
  souscriptionId Int
  souscription   SouscriptionPack    @relation(fields: [souscriptionId], references: [id])
  statut         StatutReceptionPack @default(PLANIFIEE)
  datePrevisionnelle DateTime
  dateLivraison  DateTime?
  livreurNom     String?
  notes          String?

  // PDV cible : détermine quel magasinier doit confirmer la sortie stock
  pointDeVenteId Int?
  pointDeVente   PointDeVente? @relation(fields: [pointDeVenteId], references: [id])

  lignes        LigneReceptionPack[]
  facturesVente FactureVente[]       @relation("ReceptionPackFactures")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pointDeVenteId])
}

model LigneReceptionPack {
  id           Int                  @id @default(autoincrement())
  receptionId  Int
  reception    ReceptionProduitPack @relation(fields: [receptionId], references: [id], onDelete: Cascade)
  produitId    Int
  produit      Produit              @relation(fields: [produitId], references: [id])
  quantite     Int
  prixUnitaire Decimal
}

// ============================================================
// LIGNES PRODUITS SOUSCRIPTION
// ============================================================

model LigneSouscriptionProduit {
  id             Int              @id @default(autoincrement())
  souscriptionId Int
  souscription   SouscriptionPack @relation(fields: [souscriptionId], references: [id], onDelete: Cascade)

  // Produit lié (null si nouveau produit non encore créé dans le catalogue)
  produitId      Int?
  produit        Produit?         @relation("LigneProduitDemande", fields: [produitId], references: [id])

  // Saisie libre — toujours renseignée pour traçabilité
  produitNomSaisi  String
  categorieSaisie  String?
  uniteSaisie      String?

  quantite         Int
  quantiteParCycle Int?     // pour packs récurrents : qté à chaque cycle
  prixEstime       Decimal? // estimation agent terrain

  statut            StatutLigneSouscription @default(EN_ATTENTE)
  estNouveauProduit Boolean                @default(false)

  // PDV cible — dénormalisé depuis client.pointDeVenteId pour les agrégations logistique
  // (évite une double jointure souscription → client → pdv à chaque requête prévision)
  pointDeVenteId Int?
  pointDeVente   PointDeVente? @relation(fields: [pointDeVenteId], references: [id])

  // Traitement admin
  notes              String?
  produitSubstitutId Int?
  produitSubstitut   Produit? @relation("LigneProduitSubstitut", fields: [produitSubstitutId], references: [id])
  traiteParId        Int?
  traitePar          User?    @relation("LignesTraitees", fields: [traiteParId], references: [id])
  dateTraitement     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([souscriptionId])
  @@index([statut])
  @@index([pointDeVenteId, statut]) // index composite pour les agrégations prévisions
}

// ============================================================
// FIDÉLITÉ
// ============================================================

model PointsFidelite {
  id           Int  @id @default(autoincrement())
  solde        Int  @default(0)
  totalGagne   Int  @default(0)
  totalUtilise Int  @default(0)
  userId       Int? @unique
  clientId     Int? @unique

  user     User?   @relation(fields: [userId], references: [id])
  client   Client? @relation(fields: [clientId], references: [id])

  mouvements   MouvementPoints[]
  utilisations UtilisationRecompense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MouvementPoints {
  id               Int                 @id @default(autoincrement())
  pointsFideliteId Int
  pointsFidelite   PointsFidelite      @relation(fields: [pointsFideliteId], references: [id])
  type             TypeMouvementPoints
  points           Int
  description      String?
  referenceId      Int?
  referenceType    String?

  createdAt DateTime @default(now())
}

model RecompenseFidelite {
  id             Int            @id @default(autoincrement())
  nom            String
  description    String?
  type           TypeRecompense
  coutPoints     Int
  valeur         Decimal?
  produitId      Int?
  produit        Produit?       @relation(fields: [produitId], references: [id])
  actif          Boolean        @default(true)
  dateExpiration DateTime?

  utilisations UtilisationRecompense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}  

model UtilisationRecompense {
  id               Int              @id @default(autoincrement())
  recompenseId     Int
  recompense       RecompenseFidelite @relation(fields: [recompenseId], references: [id])
  pointsFideliteId Int
  pointsFidelite   PointsFidelite   @relation(fields: [pointsFideliteId], references: [id])
  pointsUtilises   Int
  statut           StatutRecompense @default(DISPONIBLE)
  dateUtilisation  DateTime?
  notes            String?

  createdAt DateTime @default(now())
}

// ============================================================
// MESSAGERIE
// ============================================================

model Message {
  id             Int       @id @default(autoincrement())
  expediteurId   Int
  destinataireId Int
  sujet          String
  contenu        String
  lu             Boolean   @default(false)
  dateLecture    DateTime?
  parentId       Int?

  expediteur   User      @relation("MessagesEnvoyes", fields: [expediteurId], references: [id])
  destinataire User      @relation("MessagesRecus", fields: [destinataireId], references: [id])
  parent       Message?  @relation("Reponses", fields: [parentId], references: [id])
  reponses     Message[] @relation("Reponses")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// PIÈCES JUSTIFICATIVES
// ============================================================

model PieceJustificative {
  id             Int      @id @default(autoincrement())
  nom            String
  url            String
  uploadthingKey String
  type           String
  taille         Int
  // Association polymorphique
  sourceType     String   // VERSEMENT_PACK | OPERATION_CAISSE | MOUVEMENT_STOCK | CLOTURE_COMPTABLE | RECEPTION_APPRO | TRANSFERT_STOCK
  sourceId       Int
  description    String?
  uploadePar     Int
  uploadeUser    User     @relation(fields: [uploadePar], references: [id])
  archiverJusquau DateTime
  createdAt      DateTime @default(now())

  @@index([sourceType, sourceId])
}

// ============================================================
// AUDIT & NOTIFICATIONS
// ============================================================

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  entite    String
  entiteId  Int?
  details   Json?    // snapshot avant/après ou données contextuelles
  ip        String?  // adresse IP de l'auteur
  userAgent String?  // navigateur / appareil
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entite, entiteId])
  @@index([createdAt])
}

model Notification {
  id          Int                  @id @default(autoincrement())
  uuid        String               @unique @default(uuid())
  userId      Int
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  titre       String
  message     String
  priorite    PrioriteNotification @default(NORMAL)
  lue         Boolean              @default(false)
  dateLecture DateTime?
  actionUrl   String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([userId, lue])
  @@index([userId, createdAt])
}

model Parametre {
  cle    String @id
  valeur String
}

/// Préférences de notification RH par utilisateur
/// (canaux activés + déclencheurs souhaités)
model PreferenceNotificationRH {
  id               Int     @id @default(autoincrement())
  userId           Int     @unique

  // ── Canaux ──────────────────────────────────────────────────
  canalApp         Boolean @default(true)   // notification in-app (toujours activé)
  canalEmail       Boolean @default(false)  // envoi email

  // ── Déclencheurs ────────────────────────────────────────────
  finContrat       Boolean @default(true)   // CDD expirant J-30 et J-7
  validationConge  Boolean @default(true)   // congé approuvé / refusé
  evaluationProg   Boolean @default(true)   // évaluation programmée (J-7)
  formationAsuivre Boolean @default(true)   // formation inscrite qui démarre (J-3)
  documentExpirant Boolean @default(true)   // document collaborateur expirant (J-30)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
  @@index([userId])
}

// ============================================================
// COMPTABILITÉ SYSCOHADA
// ============================================================

model ClotureComptable {
  id          Int      @id @default(autoincrement())
  annee       Int
  mois        Int
  notes       String?
  cloturePar  Int
  clotureUser User     @relation(fields: [cloturePar], references: [id])
  createdAt   DateTime @default(now())

  @@unique([annee, mois])
}

model CompteComptable {
  id             Int              @id @default(autoincrement())
  numero         String           @unique
  libelle        String
  classe         Int
  type           TypeCompte
  nature         NatureCompte     @default(DETAIL)
  sens           SensCompte       @default(DEBITEUR)
  actif          Boolean          @default(true)
  compteParentId Int?
  compteParent   CompteComptable?  @relation("HierarchieComptes", fields: [compteParentId], references: [id])
  sousComptes    CompteComptable[] @relation("HierarchieComptes")
  tiersType      String?
  tiersNom       String?
  lignesEcriture LigneEcriture[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([classe])
  @@index([type])
  @@index([nature])
}

model EcritureComptable {
  id        Int                  @id @default(autoincrement())
  reference String               @unique
  date      DateTime
  libelle   String
  journal   TypeJournalComptable
  statut    StatutEcriture       @default(BROUILLON)
  notes     String?
  userId    Int?
  user      User?                @relation(fields: [userId], references: [id])
  lignes    LigneEcriture[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([journal])
  @@index([statut])
  @@index([date])
}

model LigneEcriture {
  id         Int               @id @default(autoincrement())
  ecritureId Int
  ecriture   EcritureComptable @relation(fields: [ecritureId], references: [id], onDelete: Cascade)
  compteId   Int
  compte     CompteComptable   @relation(fields: [compteId], references: [id])
  libelle    String
  debit      Decimal           @default(0)
  credit     Decimal           @default(0)
  isTva      Boolean           @default(false)
  tauxTva    Decimal?
  montantTva Decimal?

  @@index([ecritureId])
  @@index([compteId])
}

model JournalValidation {
  id          Int      @id @default(autoincrement())
  entryId     String   @unique
  notes       String?
  valideParId Int
  validePar   User     @relation(fields: [valideParId], references: [id])
  createdAt   DateTime @default(now())

  @@index([entryId])
}

model RapprochementBancaire {
  id                Int                 @id @default(autoincrement())
  periode           String
  soldeBancaireReel Decimal
  soldeComptable    Decimal
  ecart             Decimal
  notes             String?
  statut            StatutRapprochement @default(EN_COURS)
  userId            Int?
  user              User?               @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periode])
  @@index([statut])
}

model DeclarationTVA {
  id            Int       @id @default(autoincrement())
  periode       String
  tvaCollectee  Decimal   @default(0)
  tvaDeductible Decimal   @default(0)
  tvaDue        Decimal   @default(0)
  statut        StatutTVA @default(BROUILLON)
  notes         String?
  userId        Int?
  user          User?     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periode])
}

// ============================================================
// ACTIONNAIRES & ASSEMBLÉES
// ============================================================

model Dividende {
  id             Int             @id @default(autoincrement())
  periode        String
  montantTotal   Decimal
  montantParPart Decimal?
  dateVersement  DateTime?
  statut         StatutDividende @default(PLANIFIE)
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Assemblee {
  id            Int             @id @default(autoincrement())
  titre         String
  description   String?
  type          TypeAssemblee
  statut        StatutAssemblee @default(PLANIFIEE)
  dateAssemblee DateTime
  lieu          String
  ordreJour     String?
  notes         String?

  participants AssembleeParticipant[]
  resolutions  ResolutionAssemblee[]
  procurations ProcurationAssemblee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssembleeParticipant {
  id               Int                 @id @default(autoincrement())
  assembleeId      Int
  gestionnaireId   Int
  statut           StatutParticipation @default(INVITE)
  dateConfirmation DateTime?

  assemblee    Assemblee    @relation(fields: [assembleeId], references: [id], onDelete: Cascade)
  gestionnaire Gestionnaire @relation(fields: [gestionnaireId], references: [id])
  votes        VoteAssemblee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assembleeId, gestionnaireId])
}

model ResolutionAssemblee {
  id          Int              @id @default(autoincrement())
  assembleeId Int
  numero      Int
  titre       String
  description String?
  statut      StatutResolution @default(EN_ATTENTE)

  assemblee Assemblee       @relation(fields: [assembleeId], references: [id], onDelete: Cascade)
  votes     VoteAssemblee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assembleeId, numero])
}

model VoteAssemblee {
  id            Int          @id @default(autoincrement())
  resolutionId  Int
  participantId Int
  decision      DecisionVote
  commentaire   String?

  resolution  ResolutionAssemblee  @relation(fields: [resolutionId], references: [id], onDelete: Cascade)
  participant AssembleeParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([resolutionId, participantId])
}

model ActionnaireProfile {
  id             Int               @id @default(autoincrement())
  gestionnaireId Int               @unique
  statut         StatutActionnaire @default(EN_ATTENTE)
  typeAction     TypeActionDetenue @default(ORDINAIRE)
  nombreActions  Int               @default(0)
  prixUnitaire   Decimal           @default(0)
  dateEntree     DateTime?
  notes          String?

  gestionnaire Gestionnaire      @relation(fields: [gestionnaireId], references: [id])
  mouvements   MouvementAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MouvementAction {
  id           Int                 @id @default(autoincrement())
  profileId    Int
  type         TypeMouvementAction
  quantite     Int
  prixUnitaire Decimal
  montantTotal Decimal
  date         DateTime
  description  String?

  profile ActionnaireProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model ProcurationAssemblee {
  id           Int               @id @default(autoincrement())
  assembleeId  Int
  mandantId    Int
  mandataireId Int
  statut       StatutProcuration @default(EN_ATTENTE)
  notes        String?

  assemblee  Assemblee    @relation(fields: [assembleeId], references: [id], onDelete: Cascade)
  mandant    Gestionnaire @relation("procurationsMandant", fields: [mandantId], references: [id])
  mandataire Gestionnaire @relation("procurationsMandataire", fields: [mandataireId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assembleeId, mandantId])
}

// ============================================================
// BIBLIOTHÈQUE DOCUMENTAIRE
// ============================================================

model DocumentBibliotheque {
  id          Int          @id @default(autoincrement())
  titre       String
  type        TypeDocument
  description String?
  fichierUrl  String?
  fichierNom  String?
  annee       Int?
  estPublic   Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// SUPER ADMIN — SYSTÈME
// ============================================================

/// Paramètres globaux de la plateforme (clé-valeur)
model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  category  String   @default("platform")
  updatedAt DateTime @updatedAt
  updatedBy Int?
}

/// Journal de sécurité (connexions, tentatives, déconnexions forcées…)
model SecurityLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userEmail String?
  action    String
  ipAddress String?
  userAgent String?
  details   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

/// Permissions personnalisées par utilisateur
model UserPermission {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module     String
  permission String  
  granted    Boolean  @default(true)
  grantedBy  Int?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, module, permission])
  @@index([userId])
}

/// Configuration d'accès aux sections/pages par rôle gestionnaire
model RolePageAccess {
  id        Int              @id @default(autoincrement())
  role      RoleGestionnaire
  pageKey   String
  allowed   Boolean          @default(true)
  updatedBy Int?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([role, pageKey])
  @@index([role])
}

/// Modules de la plateforme — activation / désactivation
model SystemModule {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  nom         String
  description String?
  actif       Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  updatedBy   Int?
}

// ============================================================
// FACTURES DE VENTE
// Générées depuis VenteDirecte (comptant/crédit) ou en standalone (pro-forma)
// ============================================================

model FactureVente {
  id     Int                @id @default(autoincrement())
  numero String             @unique // ex: FAC-2026-00001
  type   TypeFactureVente
  statut StatutFactureVente @default(EMISE)

  // Source (optionnel — absent pour pro-forma standalone)
  venteDirecteId  Int?       @unique
  creditClientId  Int?
  receptionPackId Int?

  // PDV (snapshot + relation)
  pointDeVenteId Int?
  pdvNom         String?
  pdvAdresse     String?
  pdvTelephone   String?

  // Client (snapshot pour archivage pérenne)
  clientId        Int?
  clientNom       String
  clientTelephone String?
  clientAdresse   String?

  // Émetteur (snapshot nom)
  emiseParId  Int
  emiseParNom String

  // Montants
  montantHT    Decimal
  montantTVA   Decimal @default(0)
  montantTTC   Decimal
  montantPaye  Decimal @default(0)
  modePaiement String?

  dateEmission DateTime  @default(now())
  dateEcheance DateTime?
  notes        String?

  // Relations
  venteDirecte  VenteDirecte?         @relation("VenteDirecteFacture",  fields: [venteDirecteId],  references: [id])
  creditClient  CreditClient?         @relation("CreditClientFactures", fields: [creditClientId],  references: [id])
  receptionPack ReceptionProduitPack? @relation("ReceptionPackFactures", fields: [receptionPackId], references: [id])
  client        Client?               @relation("FacturesVenteClient",   fields: [clientId],        references: [id])
  pointDeVente  PointDeVente?         @relation("FacturesVentePDV",      fields: [pointDeVenteId],  references: [id])
  emisePar      User                  @relation("FacturesVenteEmises",   fields: [emiseParId],      references: [id])
  lignes        LigneFactureVente[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([emiseParId])
  @@index([clientId])
  @@index([pointDeVenteId])
  @@index([creditClientId])
  @@index([receptionPackId])
  @@index([type])
  @@index([statut])
}

model LigneFactureVente {
  id           Int     @id @default(autoincrement())
  factureId    Int
  designation  String
  unite        String?
  quantite     Int
  prixUnitaire Decimal
  montant      Decimal

  facture FactureVente @relation(fields: [factureId], references: [id], onDelete: Cascade)
}

// ============================================================
// OGRH — MODULE 1 : DOSSIER COLLABORATEUR
// Extension RH du Gestionnaire (nomenclature AfriGes)
// ============================================================

enum StatutCollaborateur {
  ACTIF
  EN_PERIODE_ESSAI
  SUSPENDU
  DEMISSIONNAIRE
  LICENCIE
  RETRAITE
  INACTIF
}

enum TypeContrat {
  CDI
  CDD
  STAGE
  CONSULTANT
  PRESTATAIRE
  FREELANCE
}

enum SituationMatrimoniale {
  CELIBATAIRE
  MARIE
  DIVORCE
  VEUF
  UNION_LIBRE
}

enum NiveauHierarchique {
  DIRECTION
  MANAGER
  SUPERVISEUR
  AGENT
  STAGIAIRE
}

enum TypeDocumentCollaborateur {
  CNI
  PASSEPORT
  DIPLOME
  CERTIFICAT
  CV
  ATTESTATION
  CONTRAT
  PHOTO_IDENTITE
  AUTRE
}

/// Profil RH d'un Gestionnaire — données administratives et contractuelles
/// Lié à Gestionnaire (1-1) ; toutes les autres entités OGRH pointent vers ProfilRH.id
model ProfilRH {
  id             Int     @id @default(autoincrement())
  gestionnaireId Int     @unique

  // ── Identité ──────────────────────────────────────────────
  matricule             String                @unique  // ex: MAT-2026-0001 (auto-généré)
  emailProfessionnel    String?               @unique  // ex: prenom.nom@company.com (auto-généré à l'onboarding)
  dateNaissance         DateTime?
  lieuNaissance         String?
  sexe                  Sexe?
  nationalite           String?
  situationMatrimoniale SituationMatrimoniale?
  nbEnfants             Int                   @default(0)
  telephoneSecondaire   String?

  // ── Contrat & poste ───────────────────────────────────────
  typeContrat        TypeContrat?
  dateEmbauche       DateTime?
  dateFin            DateTime?              // CDD uniquement
  fonction           String?
  service            String?
  departement        String?
  niveauHierarchique NiveauHierarchique?
  statut             StatutCollaborateur    @default(ACTIF)
  notes              String?

  // ── Hiérarchie (manager direct = autre ProfilRH) ──────────
  managerId   Int?
  manager     ProfilRH?  @relation("HierarchieRH", fields: [managerId], references: [id])
  subordonnes ProfilRH[] @relation("HierarchieRH")

  // ── Horaires de référence ──────────────────────────────────
  configHoraireId Int?
  configHoraire   ConfigHoraire? @relation(fields: [configHoraireId], references: [id])

  // ── Relations ─────────────────────────────────────────────
  gestionnaire          Gestionnaire             @relation(fields: [gestionnaireId], references: [id])
  documents             DocumentCollaborateur[]
  soldesConges          SoldeConge[]
  demandesConge         DemandeConge[]
  missions              Mission[]                @relation("MissionsCollaborateur")
  missionsValidees      Mission[]                @relation("MissionsValidateurRH")
  documentsGeneres      DocumentRHGenere[]
  fichesPaie              FichePaie[]
  avancesSalaire          AvanceSalaire[]
  pretsEmploye            PretEmploye[]
  participationsFormation ParticipationFormation[]
  pointages               Pointage[]
  avantages               AvantageRH[]
  remboursementsFrais     RemboursementFrais[]
  evaluations             EvaluationRH[]          @relation("EvaluationsCollaborateur")
  evaluationsEffectuees   EvaluationRH[]          @relation("EvaluationsEffectuees")
  procedures              ProcedureDisciplinaire[]
  historiquesPoste        HistoriquePoste[]
  planCarriere            PlanCarriere?
  successions             SuccesseurPotentiel[]
  onboarding              OnboardingEmploye?
  competences             CollaborateurCompetence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([departement])
  @@index([managerId])
}

// ============================================================
// OGRH — MODULE 2 : HISTORIQUE ORGANISATIONNEL
// ============================================================

enum TypeMouvementCarriere {
  PROMOTION
  MUTATION
  EVOLUTION
  RECLASSEMENT
}

enum NiveauReadiness {
  PRET_MAINTENANT
  PRET_SOUS_1_AN
  PRET_1_A_3_ANS
  EN_DEVELOPPEMENT
}

/// Trace chaque changement de poste, de manager ou de département d'un collaborateur
model HistoriquePoste {
  id         Int      @id @default(autoincrement())
  profilRHId Int

  type       TypeMouvementCarriere? // PROMOTION | MUTATION | EVOLUTION | RECLASSEMENT

  // Avant
  ancienManagerId    Int?
  ancienneFonction   String?
  ancienService      String?
  ancienDepartement  String?
  ancienSalaire      Decimal?

  // Après
  nouveauManagerId   Int?
  nouvelleFonction   String?
  nouveauService     String?
  nouveauDepartement String?
  nouveauSalaire     Decimal?

  motif      String?
  modifiePar Int      // User.id de l'auteur du changement

  profilRH ProfilRH @relation(fields: [profilRHId], references: [id])

  createdAt DateTime @default(now())

  @@index([profilRHId])
  @@index([type])
  @@index([createdAt])
}

/// Plan de carrière individuel d'un collaborateur (upsert — 1 par profilRH)
model PlanCarriere {
  id                Int       @id @default(autoincrement())
  profilRHId        Int       @unique
  aspiration        String?
  prochainPosteVise String?
  dateRevision      DateTime?
  actions           String?   // plan d'actions concrètes
  notes             String?

  profilRH ProfilRH @relation(fields: [profilRHId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Poste stratégique nécessitant un plan de succession
model PosteCritique {
  id                  Int     @id @default(autoincrement())
  titre               String
  departement         String?
  description         String?
  nbSuccesseursRequis Int     @default(2)
  actif               Boolean @default(true)

  successeurs SuccesseurPotentiel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([actif])
}

/// Lien collaborateur ↔ poste critique avec niveau de préparation
model SuccesseurPotentiel {
  id              Int             @id @default(autoincrement())
  posteCritiqueId Int
  profilRHId      Int
  readiness       NiveauReadiness
  estTalentCle    Boolean         @default(false)
  notes           String?

  posteCritique PosteCritique @relation(fields: [posteCritiqueId], references: [id], onDelete: Cascade)
  profilRH      ProfilRH      @relation(fields: [profilRHId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([posteCritiqueId, profilRHId])
  @@index([posteCritiqueId])
  @@index([profilRHId])
  @@index([estTalentCle])
}

/// Documents uploadés pour le dossier d'un collaborateur
/// Jamais supprimés — versionning par compteur
model DocumentCollaborateur {
  id             Int                       @id @default(autoincrement())
  profilRHId     Int
  type           TypeDocumentCollaborateur
  nom            String
  fileUrl        String
  version        Int                       @default(1)
  notes          String?
  dateExpiration DateTime?                 // CNI, passeport, permis… (null = pas d'expiration)
  uploadePar     Int                       // User.id de l'agent qui a uploadé

  profilRH ProfilRH @relation(fields: [profilRHId], references: [id])

  createdAt DateTime @default(now())

  @@index([profilRHId])
  @@index([type])
  @@index([dateExpiration])
}

// ============================================================
// OGRH — MODULE 6 : CONGÉS & ABSENCES
// ============================================================

enum TypeConge {
  ANNUEL
  MALADIE
  EXCEPTIONNEL
  PERMISSION
  FORMATION
  MATERNITE
  PATERNITE
  SANS_SOLDE
}

enum StatutDemandeConge {
  EN_ATTENTE         // soumis par le collaborateur
  VALIDE_MANAGER     // approuvé par le manager direct
  VALIDE_RH          // approuvé par le RH
  APPROUVE           // décision finale favorable
  REJETE             // refusé (à n'importe quelle étape)
  ANNULE             // annulé par le collaborateur
}

/// Règles de congé par type — configurables par le RH sans dev
model PolitiqueConge {
  id             Int       @id @default(autoincrement())
  type           TypeConge @unique
  joursParAn     Int       @default(0)
  reportable     Boolean   @default(false)
  joursMaxReport Int       @default(0)
  actif          Boolean   @default(true)
  description    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Solde de congés par collaborateur, par type et par année calendaire
model SoldeConge {
  id         Int       @id @default(autoincrement())
  profilRHId Int
  type       TypeConge
  annee      Int
  totalDroit Int       @default(0)
  pris       Int       @default(0)   // calculé à chaque validation
  reporte    Int       @default(0)
  restant    Int       @default(0)   // totalDroit + reporte - pris

  profilRH ProfilRH @relation(fields: [profilRHId], references: [id])

  @@unique([profilRHId, type, annee])
  @@index([profilRHId])
}

/// Demande de congé avec workflow d'approbation à 2 niveaux
model DemandeConge {
  id         Int                @id @default(autoincrement())
  profilRHId Int
  type       TypeConge
  dateDebut  DateTime
  dateFin    DateTime
  nbJours    Int
  motif      String?
  statut     StatutDemandeConge @default(EN_ATTENTE)

  // Workflow
  managerId           Int?       // ProfilRH.gestionnaireId du manager
  rhId                Int?       // User.id du responsable RH
  commentaireRefus    String?
  dateValidationMgr   DateTime?
  dateValidationRH    DateTime?
  dateDecisionFinale  DateTime?

  profilRH ProfilRH @relation(fields: [profilRHId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profilRHId])
  @@index([statut])
  @@index([dateDebut, dateFin])
}

// ============================================================
// OGRH — MODULE 7 : MISSIONS & DÉPLACEMENTS
// ============================================================

enum StatutMission {
  CREE
  VALIDE
  EN_COURS
  CLOTURE
  ANNULE
}

model Mission {
  id              Int           @id @default(autoincrement())
  reference       String        @unique  // ex: MSN-2026-0001
  titre           String
  objectifs       String?
  livrables       String?
  destination     String?
  dateDepart      DateTime
  dateRetour      DateTime?
  dateRetourReel  DateTime?
  statut          StatutMission @default(CREE)
  rapport         String?       // texte de compte-rendu ou URL fichier
  notes           String?

  collaborateurId Int            // ProfilRH.id
  valideParId     Int?           // ProfilRH.id du validateur

  collaborateur ProfilRH  @relation("MissionsCollaborateur", fields: [collaborateurId], references: [id])
  validePar     ProfilRH? @relation("MissionsValidateurRH",  fields: [valideParId],     references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([collaborateurId])
  @@index([statut])
  @@index([dateDepart])
}

// ============================================================
// OGRH — MODULE 12 : DOCUMENTS RH GÉNÉRÉS
// PDF produits automatiquement par le système (attestations, lettres…)
// Jamais supprimés — archivage + versionning obligatoire
// ============================================================

enum TypeDocumentRHGenere {
  ATTESTATION_TRAVAIL
  CERTIFICAT_PRESENCE
  DECISION_AFFECTATION
  LETTRE_MISSION
  AUTRE
}

model DocumentRHGenere {
  id         Int                  @id @default(autoincrement())
  profilRHId Int
  type       TypeDocumentRHGenere
  titre      String
  version    Int                  @default(1)
  fileUrl    String?              // null tant que le PDF n'est pas encore généré
  contenu    String?              // HTML généré automatiquement par le système
  generePar  Int                  // User.id du RH ou admin qui a déclenché la génération
  notes      String?
  archive    Boolean              @default(false)

  profilRH ProfilRH @relation(fields: [profilRHId], references: [id])

  createdAt DateTime @default(now())

  @@index([profilRHId])
  @@index([type])
}

// ============================================================
// OGRH — MODULE 2 : PAIE & RÉMUNÉRATION
// ============================================================

enum StatutFichePaie {
  BROUILLON      // en cours de saisie
  CONTROLE       // soumis au contrôle RH
  VALIDE         // validé par la direction
  EN_PAIEMENT    // ordre de paiement émis
  PAYE           // versement effectué
}

enum TypeComposantSalaire {
  SALAIRE_BASE
  PRIME_PERFORMANCE
  PRIME_ANCIENNETE
  PRIME_TRANSPORT
  PRIME_LOGEMENT
  PRIME_FONCTION
  PRIME_RESPONSABILITE
  HEURES_SUPPLEMENTAIRES
  INDEMNITE_MISSION
  COMMISSION
  BONUS
  PRIME_EXCEPTIONNELLE
  DEDUCTION_ABSENCE
  DEDUCTION_RETARD
  COTISATION_RETRAITE
  COTISATION_SANTE
  IMPOT_REVENU
  AVANCE_SUR_SALAIRE
  REMBOURSEMENT_PRET
  SANCTION_FINANCIERE
  AUTRE_GAIN
  AUTRE_RETENUE
}

enum StatutAvanceSalaire {
  EN_ATTENTE
  APPROUVE
  REJETE
  REMBOURSE
}

enum StatutPretEmploye {
  EN_COURS
  SOLDE
  EN_DEFAUT
}

model FichePaie {
  id            Int             @id @default(autoincrement())
  profilRHId    Int
  mois          Int             // 1–12
  annee         Int
  salaireBase   Decimal         @default(0)
  totalBrut     Decimal         @default(0)
  totalRetenues Decimal         @default(0)
  netAPayer     Decimal         @default(0)
  statut        StatutFichePaie @default(BROUILLON)
  fichierUrl    String?
  notes         String?
  genereParId   Int             // User.id
  // Workflow
  controleParId        Int?    // User.id
  dateControle         DateTime?
  valideParId          Int?    // User.id
  dateValidation       DateTime?
  misEnPaiementParId   Int?    // User.id
  dateMiseEnPaiement   DateTime?
  modePaiement         String? // VIREMENT | MOBILE_MONEY | ESPECES

  profilRH   ProfilRH           @relation(fields: [profilRHId], references: [id])
  composants ComposantSalaire[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profilRHId, mois, annee])
  @@index([profilRHId])
  @@index([statut])
  @@index([annee, mois])
}

model ComposantSalaire {
