  message     String
  priorite    PrioriteNotification @default(NORMAL)
  lue         Boolean              @default(false)
  dateLecture DateTime?
  actionUrl   String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([userId, lue])
  @@index([userId, createdAt])
}

model Parametre {
  cle    String @id
  valeur String
}

/// Préférences de notification RH par utilisateur
/// (canaux activés + déclencheurs souhaités)
model PreferenceNotificationRH {
  id               Int     @id @default(autoincrement())
  userId           Int     @unique

  // ── Canaux ──────────────────────────────────────────────────
  canalApp         Boolean @default(true)   // notification in-app (toujours activé)
  canalEmail       Boolean @default(false)  // envoi email

  // ── Déclencheurs ────────────────────────────────────────────
  finContrat       Boolean @default(true)   // CDD expirant J-30 et J-7
  validationConge  Boolean @default(true)   // congé approuvé / refusé
  evaluationProg   Boolean @default(true)   // évaluation programmée (J-7)
  formationAsuivre Boolean @default(true)   // formation inscrite qui démarre (J-3)
  documentExpirant Boolean @default(true)   // document collaborateur expirant (J-30)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
  @@index([userId])
}

// ============================================================
// COMPTABILITÉ SYSCOHADA
// ============================================================

model ClotureComptable {
