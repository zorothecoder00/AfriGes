// ============================================================
// OGRH — MODULE 8 : POINTAGE & PRÉSENCE
// ============================================================

enum StatutPointage {
  PRESENT
  ABSENT
  RETARD
  DEMI_JOURNEE
  CONGE
  MISSION
  FERIE
}

enum SourcePointage {
  MANUEL
  IMPORT
  SELF_SERVICE
}

model Pointage {
  id           Int            @id @default(autoincrement())
  profilRHId   Int
  date         DateTime
  heureArrivee DateTime?
  heureDepart  DateTime?
  statut       StatutPointage @default(PRESENT)
  source       SourcePointage @default(MANUEL)
  notes        String?
  saisieParId  Int            // User.id

  // ── Calculs (remplis automatiquement à la saisie) ──────────
  tempsTotal     Int?  // minutes effectivement travaillées
  retardMinutes  Int?  // minutes de retard vs heure théorique
  heuresSup      Int?  // minutes au-delà de la durée théorique
  justificatif   String?  // motif absence / retard

  // ── Validation ─────────────────────────────────────────────
  valideParId  Int?      // User.id du validateur
  valideA      DateTime? // date de validation

  profilRH ProfilRH @relation(fields: [profilRHId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profilRHId, date])
  @@index([profilRHId])
  @@index([date])
  @@index([statut])
}

/// Horaires de référence utilisés pour calculer retards et heures sup
/// Un profil peut avoir sa propre config ; sinon la config par défaut s'applique
model ConfigHoraire {
  id                   Int      @id @default(autoincrement())
  nom                  String?  // ex: "Bureau 8h-17h", "Terrain 7h-15h"
  heureArrivee         String?  // "08:30" format HH:mm
  heureDepart          String?  // "17:30" format HH:mm
  pauseDejeunnerMinutes Int?    // durée pause déjeuner en minutes (ex: 60)
  dureeJourneeMinutes  Int?     // durée théorique par jour en minutes (ex: 480)
  joursOuvres          Json?    // tableau [1,2,3,4,5] (1=lundi … 7=dimanche)
  toleranceRetardMin   Int?     // minutes de tolérance avant comptage retard (ex: 5)
  estDefaut            Boolean  @default(false)  // config appliquée si aucune perso
  createdById          Int?     // User.id

  collaborateurs ProfilRH[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estDefaut])
}

