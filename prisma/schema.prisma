// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema     

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
   
generator client {
  provider = "prisma-client-js"                                                                      
}                                                       
                        
datasource db {                                
  provider = "postgresql"              
}                           
                      
enum Role {         
  SUPER_ADMIN                  
  ADMIN                 
  USER                          
}          
   
model User {
  id                  Int               @id @default(autoincrement())
  uuid                String            @unique @default(uuid())
  nom                 String    
  prenom              String                     
  email               String            @unique   
  photo               String? // 👈 NextAuth (image / photo)
  role                Role?                
  telephone           String?                    
  adresse             String?            
  passwordHash        String?
  etat                MemberStatus      @default(ACTIF)            
  dateAdhesion        DateTime          @default(now())      

  wallet              Wallet?
  gestionnaire        Gestionnaire?
  factures            Facture[] // ✅ AJOUTÉ
  auditLogs           AuditLog[] // ✅ (pour erreur suivante)
  notifications       Notification[]
  souscriptionsPacks  SouscriptionPack[]
  pointsFidelite      PointsFidelite?
  messagesEnvoyes     Message[]         @relation("MessagesEnvoyes")
  messagesRecus       Message[]         @relation("MessagesRecus")
  cloturesComptables      ClotureComptable[]
  piecesJustificatives    PieceJustificative[]
  anomaliesSignalees      AnomalieStock[]     @relation("AnomaliesSignalees")
  anomaliesTraitees       AnomalieStock[]     @relation("AnomaliesTraitees")
  bonsSortieCreés         BonSortie[]         @relation("BonsSortieCreés")
  bonsSortieValidés       BonSortie[]         @relation("BonsSortieValidés")
  ecrituresComptables     EcritureComptable[]
  rapprochements          RapprochementBancaire[]
  declarationsTVA         DeclarationTVA[]

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

enum MemberStatus {
  ACTIF
  INACTIF
  SUSPENDU
}

model Client {
  id                  Int               @id @default(autoincrement())
  nom                 String
  prenom              String
  telephone           String            @unique
  adresse             String?
  etat                MemberStatus      @default(ACTIF)
  souscriptionsPacks  SouscriptionPack[]
  pointsFidelite      PointsFidelite?

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}  

model Wallet {
  id                  Int               @id @default(autoincrement())
  memberId            Int               @unique
  soldeGeneral        Decimal           @default(0.0)
  soldeTontine        Decimal           @default(0.0)
  soldeCredit         Decimal           @default(0.0)

  member              User              @relation(fields: [memberId], references: [id])
  transactions        WalletTransaction[]
  paiements           Paiement[] // ✅ AJOUTÉ pour relation inverse

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model WalletTransaction {
  id                  Int               @id @default(autoincrement())
  walletId            Int
  type                TransactionType
  montant             Decimal
  description         String?
  reference           String            @unique

  wallet              Wallet            @relation(fields: [walletId], references: [id])

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

enum TransactionType {         
  DEPOT
  RETRAIT
  COTISATION  
  TONTINE
  REMBOURSEMENT_CREDIT
  CREDIT
  ACHAT
  ANNULATION
}

model Gestionnaire {
  id                  Int               @id @default(autoincrement())
  memberId            Int               @unique
  role                RoleGestionnaire
  actif               Boolean           @default(true)

  member              User              @relation(fields: [memberId], references: [id])
  assemblees          AssembleeParticipant[]

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

enum RoleGestionnaire {
  SUPER_ADMIN
  ADMIN
  RESPONSABLE_POINT_DE_VENTE
  RESPONSABLE_COMMUNAUTE
  REVENDEUR
  AGENT_LOGISTIQUE_APPROVISIONNEMENT
  MAGAZINIER
  CAISSIER
  COMMERCIAL
  COMPTABLE  
  AUDITEUR_INTERNE
  RESPONSABLE_VENTE_CREDIT
  CONTROLEUR_TERRAIN
  AGENT_TERRAIN
  RESPONSABLE_ECONOMIQUE
  RESPONSABLE_MARKETING
  ACTIONNAIRE
}

/**
 * ========= STOCK (facultatif mais prêt) ==========
 */

model Produit {
  id                  Int                  @id @default(autoincrement())
  nom                 String
  description         String?
  prixUnitaire        Decimal
  stock               Int                  @default(0)
  alerteStock         Int                  @default(0)

  mouvements          MouvementStock[]
  livraisonsLignes    LivraisonLigne[]
  lignesReceptionPack LigneReceptionPack[]
  recompensesFidelite RecompenseFidelite[]
  packsCibleProduit   Pack[]               @relation("PackProduitCible")
  anomalies           AnomalieStock[]
  lignesBonSortie     LigneBonSortie[]

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model MouvementStock {
  id                  Int                  @id @default(autoincrement())
  produitId           Int
  type                TypeMouvement
  quantite            Int
  motif               String?
  reference           String               @unique
  dateMouvement       DateTime             @default(now())

  produit             Produit              @relation(fields: [produitId], references: [id])
}

enum TypeMouvement {    
  ENTREE
  SORTIE
  AJUSTEMENT
}

model Paiement {
  id                  Int                  @id @default(autoincrement())
  factureId           Int
  walletId            Int
  montant             Decimal
  type                TypePaiement // Ex: WALLET_GENERAL, WALLET_TONTINE, WALLET_CREDIT, EXTERNE
  reference           String               @unique
  createdAt           DateTime             @default(now())

  facture             Facture              @relation(fields: [factureId], references: [id])
  wallet              Wallet               @relation(fields: [walletId], references: [id])
}

enum TypePaiement {
  WALLET_GENERAL
  WALLET_TONTINE
  WALLET_CREDIT
  EXTERNE
}

enum TypeFacture {
  COTISATION
  TONTINE
  CREDIT
  CREDIT_ALIMENTAIRE
  ACHAT
}

enum StatutFacture {
  BROUILLON
  PAYEE
  ANNULEE
}

model Facture {
  id                  Int                   @id @default(autoincrement())
  reference           String                @unique
  memberId            Int
  montant             Decimal
  type                TypeFacture
  statut              StatutFacture

  member              User                  @relation(fields: [memberId], references: [id])
  paiements           Paiement[] // ✅ AJOUTÉ pour relation inverse

  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
}

model AuditLog {
  id                  Int                   @id @default(autoincrement())
  userId              Int?
  action              String
  entite              String
  entiteId            Int?
  createdAt           DateTime              @default(now())

  user                User?                 @relation(fields: [userId], references: [id])
}

model Parametre {
  cle                 String                @id
  valeur              String
}

// ── Livraisons (gérées par le Responsable PDV) ──────────────────────────────

enum TypeLivraison {
  RECEPTION   // Entrée de marchandises (fournisseur → PDV)
  EXPEDITION  // Sortie / livraison (PDV → client ou autre PDV)
}

enum StatutLivraison {
  EN_ATTENTE
  EN_COURS
  LIVREE
  ANNULEE
}

model Livraison {
  id                 Int             @id @default(autoincrement())
  reference          String          @unique
  type               TypeLivraison
  statut             StatutLivraison @default(EN_ATTENTE)
  fournisseurNom     String?
  destinataireNom    String?
  datePrevisionnelle DateTime
  dateLivraison      DateTime?
  notes              String?
  planifiePar        String

  lignes             LivraisonLigne[]

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model LivraisonLigne {
  id              Int      @id @default(autoincrement())
  livraisonId     Int
  produitId       Int
  quantitePrevue  Int
  quantiteRecue   Int?

  livraison       Livraison @relation(fields: [livraisonId], references: [id], onDelete: Cascade)
  produit         Produit   @relation(fields: [produitId], references: [id])
}

// ── Gestion de caisse ─────────────────────────────────────────────────────────

enum StatutSessionCaisse {
  OUVERTE
  SUSPENDUE
  FERMEE
}

enum ModePaiement {
  ESPECES
  VIREMENT
  CHEQUE
}

enum TypeOperationCaisse {
  ENCAISSEMENT
  DECAISSEMENT
}

enum CategorieDecaissement {
  SALAIRE
  AVANCE
  FOURNISSEUR
  AUTRE
}

model SessionCaisse {
  id            Int                 @id @default(autoincrement())
  caissierNom   String
  caissierId    Int
  fondsCaisse   Decimal             @default(0)
  statut        StatutSessionCaisse @default(OUVERTE)
  dateOuverture DateTime            @default(now())
  dateFermeture DateTime?
  notes         String?
  operations    OperationCaisse[]
  transferts    TransfertCaisse[]
  clotures      ClotureCaisse[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model OperationCaisse {
  id           Int                    @id @default(autoincrement())
  sessionId    Int
  session      SessionCaisse          @relation(fields: [sessionId], references: [id])
  type         TypeOperationCaisse
  mode         ModePaiement?
  categorie    CategorieDecaissement?
  montant      Decimal
  motif        String
  reference    String                 @unique
  pieceJointe  String?
  operateurNom String
  operateurId  Int
  createdAt    DateTime               @default(now())
}

model TransfertCaisse {
  id           Int           @id @default(autoincrement())
  sessionId    Int
  session      SessionCaisse @relation(fields: [sessionId], references: [id])
  origine      String
  destination  String
  montant      Decimal
  motif        String?
  reference    String        @unique
  operateurNom String
  operateurId  Int
  createdAt    DateTime      @default(now())
}

// ── Clôture de caisse ────────────────────────────────────────────────────────

model ClotureCaisse {
  id                       Int            @id @default(autoincrement())
  date                     DateTime       @unique
  caissierNom              String
  totalVentes              Int
  montantTotal             Decimal
  panierMoyen              Decimal
  nbClients                Int
  notes                    String?
  // Champs session (nullable pour rétrocompatibilité)
  sessionId                Int?
  session                  SessionCaisse? @relation(fields: [sessionId], references: [id])
  fondsCaisse              Decimal        @default(0)
  totalEncaissementsAutres Decimal        @default(0)
  totalDecaissements       Decimal        @default(0)
  totalTransferts          Decimal        @default(0)
  soldeTheorique           Decimal        @default(0)
  soldeReel                Decimal?
  ecart                    Decimal?
  createdAt                DateTime       @default(now())
}
  
// ── Clôture comptable mensuelle ───────────────────────────────────────────────

model ClotureComptable {
  id          Int      @id @default(autoincrement())
  annee       Int                          // ex: 2025
  mois        Int                          // 1-12
  notes       String?
  cloturePar  Int
  clotureUser User     @relation(fields: [cloturePar], references: [id])
  createdAt   DateTime @default(now())

  @@unique([annee, mois])
}

model Notification {
  id                  Int                   @id @default(autoincrement())
  uuid                String                @unique @default(uuid())
  
  // Relation avec l'utilisateur
  userId              Int
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Informations de base   
  titre               String
  message             String
  priorite            PrioriteNotification  @default(NORMAL)
  
  // État de la notification
  lue                 Boolean               @default(false)
  dateLecture         DateTime?
  
  // Action associée
  actionUrl           String?               // URL vers la page de détail
  
  // Dates
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  
  // Index pour optimiser les requêtes
  @@index([userId, lue])
  @@index([userId, createdAt]) 
}

enum PrioriteNotification {
  URGENT       // Rouge - Action immédiate requise
  HAUTE        // Orange - Important
  NORMAL       // Gris - Standard
  BASSE        // Bleu - Info
}

// ── Actionnaires ──────────────────────────────────────────────────────────────

enum StatutDividende {
  PLANIFIE
  EN_COURS
  VERSE
  ANNULE
}

model Dividende {
  id              Int             @id @default(autoincrement())
  periode         String          // "T1 2026", "Annuel 2025"
  montantTotal    Decimal
  montantParPart  Decimal?
  dateVersement   DateTime?
  statut          StatutDividende @default(PLANIFIE)
  notes           String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

enum TypeAssemblee {
  AGO  // Assemblée Générale Ordinaire
  AGE  // Assemblée Générale Extraordinaire   
  CS   // Comité Stratégique
  CA   // Conseil d'Administration
}

enum StatutAssemblee {
  PLANIFIEE
  EN_COURS
  TERMINEE
  ANNULEE
}

enum StatutParticipation {
  INVITE
  CONFIRME
  ABSENT
  PRESENT
}

enum StatutResolution {
  EN_ATTENTE
  APPROUVEE
  REJETEE
}

enum DecisionVote {
  POUR
  CONTRE
  ABSTENTION
}

model Assemblee {
  id              Int                   @id @default(autoincrement())
  titre           String
  description     String?
  type            TypeAssemblee
  statut          StatutAssemblee       @default(PLANIFIEE)
  dateAssemblee   DateTime
  lieu            String
  ordreJour       String?
  notes           String?

  participants    AssembleeParticipant[]
  resolutions     ResolutionAssemblee[]

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

model AssembleeParticipant {
  id                   Int                  @id @default(autoincrement())
  assembleeId          Int
  gestionnaireId       Int
  statut               StatutParticipation  @default(INVITE)
  dateConfirmation     DateTime?

  assemblee            Assemblee            @relation(fields: [assembleeId], references: [id], onDelete: Cascade)
  gestionnaire         Gestionnaire         @relation(fields: [gestionnaireId], references: [id])
  votes                VoteAssemblee[]

  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@unique([assembleeId, gestionnaireId])
}

model ResolutionAssemblee {
  id              Int                  @id @default(autoincrement())
  assembleeId     Int
  numero          Int
  titre           String
  description     String?
  statut          StatutResolution     @default(EN_ATTENTE)

  assemblee       Assemblee            @relation(fields: [assembleeId], references: [id], onDelete: Cascade)
  votes           VoteAssemblee[]

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([assembleeId, numero])
}

model VoteAssemblee {
  id              Int                   @id @default(autoincrement())
  resolutionId    Int
  participantId   Int
  decision        DecisionVote
  commentaire     String?

  resolution      ResolutionAssemblee   @relation(fields: [resolutionId], references: [id], onDelete: Cascade)
  participant     AssembleeParticipant  @relation(fields: [participantId], references: [id], onDelete: Cascade)

  createdAt       DateTime              @default(now())

  @@unique([resolutionId, participantId])
}

// ── Architecture Packs AfriSime ────────────────────────────────────────────────

enum TypePack {
  ALIMENTAIRE       // Cotisation 15 ou 30 jours → produit alimentaire (particuliers)
  REVENDEUR         // 2 formules: (1) 50% upfront + tontine hebdo, (2) crédit total 16j max
  FAMILIAL          // Panier mensuel, bonus 10% après 3 cycles complets
  URGENCE           // 25% upfront, livraison immédiate, remboursement 7-10 jours
  EPARGNE_PRODUIT   // Épargne progressive quotidienne/hebdo → seuil → produit (renouvelable)
  FIDELITE          // Points par achat/remboursement → réductions/produits gratuits
}

enum FormuleRevendeur {
  FORMULE_1   // 50% upfront + cotisation tontine hebdomadaire jusqu'à solde
  FORMULE_2   // Crédit total, remboursement quotidien sur 16 jours maximum
}

enum FrequenceVersement {
  QUOTIDIEN
  HEBDOMADAIRE
  BIMENSUEL
  MENSUEL
}

enum StatutSouscription {
  EN_ATTENTE    // Créée mais pas encore activée
  ACTIF         // En cours
  SUSPENDU      // Temporairement suspendu
  COMPLETE      // Cycle terminé avec succès
  ANNULE        // Annulé
}

enum TypeVersement {
  COTISATION_INITIALE   // Premier versement / acompte (ex: 25% urgence, 50% revendeur)
  VERSEMENT_PERIODIQUE  // Versement régulier (tontine, épargne, cotisation)
  REMBOURSEMENT         // Remboursement crédit (formule 2 ou urgence)
  BONUS                 // Bonus fidélité ou bonus fin de cycle
  AJUSTEMENT            // Ajustement administratif
}

enum StatutVersementPack {
  EN_ATTENTE
  PAYE
  ANNULE
  EN_RETARD
}

enum StatutReceptionPack {
  PLANIFIEE
  LIVREE
  ANNULEE
}

enum TypeMouvementPoints {
  GAIN          // Points gagnés (achat, remboursement ponctuel)
  UTILISATION   // Points utilisés pour une récompense
  EXPIRATION    // Points expirés automatiquement
  AJUSTEMENT    // Ajustement administratif
}

enum TypeRecompense {
  REDUCTION         // Pourcentage de réduction sur prochain achat
  PRODUIT_GRATUIT   // Produit offert du catalogue
  CASHBACK          // Remboursement en cash
}

enum StatutRecompense {
  DISPONIBLE
  UTILISEE
  EXPIREE
}

// Template de configuration pour chaque type de pack
model Pack {
  id                  Int                @id @default(autoincrement())
  nom                 String
  type                TypePack
  description         String?
  actif               Boolean            @default(true)

  // Configuration commune
  dureeJours          Int?               // Durée du cycle (15 ou 30 pour ALIMENTAIRE, 16 pour REVENDEUR F2)
  frequenceVersement  FrequenceVersement @default(HEBDOMADAIRE)
  montantVersement    Decimal?           // Montant du versement périodique standard

  // Pack REVENDEUR
  formuleRevendeur    FormuleRevendeur?  // null si type != REVENDEUR
  montantCredit       Decimal?           // Montant total du crédit (REVENDEUR F2)

  // Pack EPARGNE_PRODUIT
  montantSeuil        Decimal?           // Seuil d'épargne à atteindre
  produitCibleId      Int?               // Produit à délivrer quand le seuil est atteint
  produitCible        Produit?           @relation("PackProduitCible", fields: [produitCibleId], references: [id])

  // Pack FAMILIAL
  bonusPourcentage    Decimal?           // Ex: 10.0 pour 10% de bonus
  cyclesBonusTrigger  Int?               // Nb de cycles consécutifs pour bonus (ex: 3)

  // Pack URGENCE
  acomptePercent      Decimal?           // Ex: 25.0 pour 25% d'acompte obligatoire

  // Pack FIDELITE
  pointsParTranche    Int?               // Points gagnés par tranche d'achat
  montantTranche      Decimal?           // Montant d'achat correspondant à la tranche

  souscriptions       SouscriptionPack[]

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}
  
// Souscription d'un client/membre à un pack
model SouscriptionPack { 
  id                  Int                @id @default(autoincrement())
  packId              Int
  pack                Pack               @relation(fields: [packId], references: [id])

  // Abonné : User (membre) ou Client externe, un seul des deux
  userId              Int?
  user                User?              @relation(fields: [userId], references: [id])
  clientId            Int?
  client              Client?            @relation(fields: [clientId], references: [id])

  statut              StatutSouscription @default(EN_ATTENTE)
  formuleRevendeur    FormuleRevendeur?  // Précision pour pack REVENDEUR
  frequenceVersement  FrequenceVersement? // Override de la fréquence du pack (ex: FAMILIAL)

  dateDebut           DateTime           @default(now())
  dateFin             DateTime?          // Date de fin prévue du cycle
  dateCloture         DateTime?          // Date de clôture effective

  // Suivi financier
  montantTotal        Decimal            // Montant total attendu sur le cycle
  montantVerse        Decimal            @default(0)  // Total versé jusqu'ici
  montantRestant      Decimal            // montantTotal - montantVerse (mis à jour à chaque versement)

  // Cycle (pour FAMILIAL : suivi des cycles consécutifs)
  numeroCycle         Int                @default(1)
  bonusObtenu         Boolean            @default(false)

  notes               String?
  enregistrePar       String?            // Nom du caissier/RPV qui a créé la souscription

  versements          VersementPack[]
  echeances           EcheancePack[]
  receptions          ReceptionProduitPack[]

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

// Versement individuel dans le cadre d'une souscription
model VersementPack {
  id                  Int                  @id @default(autoincrement())
  souscriptionId      Int
  souscription        SouscriptionPack     @relation(fields: [souscriptionId], references: [id])

  type                TypeVersement
  montant             Decimal
  statut              StatutVersementPack  @default(PAYE)
  datePrevue          DateTime?
  datePaiement        DateTime             @default(now())
  reference           String?              @unique

  notes               String?
  encaisseParId       Int?                 // userId du caissier
  encaisseParNom      String?              // Nom affiché du caissier

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

// Échéancier de remboursement (REVENDEUR F2 et URGENCE)
model EcheancePack {
  id                  Int                  @id @default(autoincrement())
  souscriptionId      Int
  souscription        SouscriptionPack     @relation(fields: [souscriptionId], references: [id])

  numero              Int                  // N° de l'échéance (1, 2, 3…)
  montant             Decimal
  datePrevue          DateTime
  datePaiement        DateTime?
  statut              StatutVersementPack  @default(EN_ATTENTE)
  notes               String?

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([souscriptionId, numero])
}

// Réception / livraison du produit au client à la fin d'un cycle
model ReceptionProduitPack {
  id                  Int                  @id @default(autoincrement())
  souscriptionId      Int
  souscription        SouscriptionPack     @relation(fields: [souscriptionId], references: [id])

  statut              StatutReceptionPack  @default(PLANIFIEE)
  datePrevisionnelle  DateTime
  dateLivraison       DateTime?
  livreurNom          String?
  notes               String?

  lignes              LigneReceptionPack[]

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

// Lignes de produits dans une réception pack
model LigneReceptionPack {
  id                  Int                  @id @default(autoincrement())
  receptionId         Int
  reception           ReceptionProduitPack @relation(fields: [receptionId], references: [id], onDelete: Cascade)
  produitId           Int
  produit             Produit              @relation(fields: [produitId], references: [id])

  quantite            Int
  prixUnitaire        Decimal              // Prix au moment de la réception
}

// Solde de points fidélité (1 par User ou Client)
model PointsFidelite {
  id                  Int                  @id @default(autoincrement())
  solde               Int                  @default(0)
  totalGagne          Int                  @default(0)
  totalUtilise        Int                  @default(0)

  userId              Int?                 @unique
  user                User?                @relation(fields: [userId], references: [id])
  clientId            Int?                 @unique
  client              Client?              @relation(fields: [clientId], references: [id])

  mouvements          MouvementPoints[]
  utilisations        UtilisationRecompense[]

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

// Historique des mouvements de points
model MouvementPoints {
  id                  Int                  @id @default(autoincrement())
  pointsFideliteId    Int
  pointsFidelite      PointsFidelite       @relation(fields: [pointsFideliteId], references: [id])

  type                TypeMouvementPoints
  points              Int                  // Positif = gain, négatif = utilisation
  description         String?
  referenceId         Int?                 // ID de la vente, souscription, etc.
  referenceType       String?              // "SouscriptionPack", "VenteCreditAlimentaire"…

  createdAt           DateTime             @default(now())
}

// Catalogue des récompenses disponibles
model RecompenseFidelite {
  id                  Int                  @id @default(autoincrement())
  nom                 String
  description         String?
  type                TypeRecompense
  coutPoints          Int                  // Points nécessaires pour obtenir la récompense
  valeur              Decimal?             // % de réduction ou montant cashback (selon type)

  produitId           Int?                 // Pour PRODUIT_GRATUIT
  produit             Produit?             @relation(fields: [produitId], references: [id])

  actif               Boolean              @default(true)
  dateExpiration      DateTime?

  utilisations        UtilisationRecompense[]

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

// Utilisation d'une récompense par un client/membre
model UtilisationRecompense {
  id                  Int                  @id @default(autoincrement())
  recompenseId        Int
  recompense          RecompenseFidelite   @relation(fields: [recompenseId], references: [id])
  pointsFideliteId    Int
  pointsFidelite      PointsFidelite       @relation(fields: [pointsFideliteId], references: [id])

  pointsUtilises      Int
  statut              StatutRecompense     @default(DISPONIBLE)
  dateUtilisation     DateTime?
  notes               String?

  createdAt           DateTime             @default(now())
}

// ── Messagerie Admin ↔ Gestionnaires ─────────────────────────────────────────

model Message {
  id             Int       @id @default(autoincrement())
  expediteurId   Int  
  destinataireId Int
  sujet          String
  contenu        String
  lu             Boolean   @default(false)
  dateLecture    DateTime?
  parentId       Int?      // null = message original, renseigné = réponse

  expediteur     User      @relation("MessagesEnvoyes",  fields: [expediteurId],   references: [id])
  destinataire   User      @relation("MessagesRecus",    fields: [destinataireId], references: [id])
  parent         Message?  @relation("Reponses",         fields: [parentId],       references: [id])
  reponses       Message[] @relation("Reponses")

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ── Pièces justificatives ──────────────────────────────────────────────────

model PieceJustificative {
  id              Int      @id @default(autoincrement())
  nom             String                   // nom original du fichier
  url             String                   // URL publique UploadThing
  uploadthingKey  String                   // clé UploadThing (pour suppression)
  type            String                   // MIME type (application/pdf, image/jpeg…)
  taille          Int                      // taille en octets
  // Association polymorphique avec les écritures comptables
  sourceType      String                   // VERSEMENT_PACK | OPERATION_CAISSE | MOUVEMENT_STOCK | CLOTURE_COMPTABLE
  sourceId        Int
  // Métadonnées
  description     String?                  // note optionnelle du comptable
  uploadePar      Int
  uploadeUser     User     @relation(fields: [uploadePar], references: [id])
  // Archivage longue durée (10 ans réglementaires)
  archiverJusquau DateTime
  createdAt       DateTime @default(now())

  @@index([sourceType, sourceId])
}

// ── Anomalies Stock (magasinier) ─────────────────────────────────────────────

enum TypeAnomalie {
  MANQUANT
  SURPLUS
  DEFECTUEUX
}

enum StatutAnomalie {
  EN_ATTENTE
  EN_COURS
  TRAITEE
  TRANSMISE
}

model AnomalieStock {
  id            Int            @id @default(autoincrement())
  reference     String         @unique
  produitId     Int
  type          TypeAnomalie
  quantite      Int
  description   String
  statut        StatutAnomalie @default(EN_ATTENTE)
  signalePar    Int            // userId du magasinier
  traitePar     Int?           // userId qui a traité
  commentaire   String?        // commentaire lors du traitement

  produit       Produit        @relation(fields: [produitId], references: [id])
  magasinier    User           @relation("AnomaliesSignalees", fields: [signalePar], references: [id])
  traiteur      User?          @relation("AnomaliesTraitees", fields: [traitePar], references: [id])

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([produitId])
  @@index([statut])
}

// ── Bons de Sortie Stock (magasinier) ────────────────────────────────────────

enum TypeBonSortie {
  PDV           // vers Point de Vente
  PERTE
  CASSE
  DON
  COMMANDE_INTERNE
}

enum StatutBonSortie {
  EN_COURS
  EXPEDIE
  RECU
  ANNULE
}

model BonSortie {
  id            Int             @id @default(autoincrement())
  reference     String          @unique
  type          TypeBonSortie
  statut        StatutBonSortie @default(EN_COURS)
  destinataire  String?         // nom du point de vente ou bénéficiaire
  motif         String
  creePar       Int             // userId du magasinier
  validePar     Int?            // userId qui a validé (réception)
  notes         String?

  lignes        LigneBonSortie[]
  magasinier    User            @relation("BonsSortieCreés", fields: [creePar], references: [id])
  valideur      User?           @relation("BonsSortieValidés", fields: [validePar], references: [id])

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([statut])
  @@index([type])
}

model LigneBonSortie {
  id          Int       @id @default(autoincrement())
  bonSortieId Int
  produitId   Int
  quantite    Int
  prixUnit    Decimal

  bonSortie   BonSortie @relation(fields: [bonSortieId], references: [id], onDelete: Cascade)
  produit     Produit   @relation(fields: [produitId], references: [id])
}

// ── COMPTABILITÉ SYSCOHADA ───────────────────────────────────────────────────

enum TypeCompte {
  ACTIF
  PASSIF
  CHARGES
  PRODUITS
  TRESORERIE
}

enum NatureCompte {
  DETAIL        // compte de détail (saisissable)
  REGROUPEMENT  // compte de regroupement (non saisissable)
  AUXILIAIRE    // compte de tiers (clients, fournisseurs, employés)
}

enum SensCompte {
  DEBITEUR
  CREDITEUR
}

enum TypeJournalComptable {
  CAISSE
  BANQUE
  VENTES
  ACHATS
  OD        // Opérations Diverses
  PAIE
}

enum StatutEcriture {
  BROUILLON
  VALIDE
  CLOTURE
}

enum StatutRapprochement {
  EN_COURS
  VALIDE
}

enum StatutTVA {
  BROUILLON
  VALIDE
}

model CompteComptable {
  id             Int           @id @default(autoincrement())
  numero         String        @unique  // ex: "411", "521", "7011"
  libelle        String
  classe         Int           // 1 à 9 (SYSCOHADA)
  type           TypeCompte
  nature         NatureCompte  @default(DETAIL)
  sens           SensCompte    @default(DEBITEUR)
  actif          Boolean       @default(true)
  // Hiérarchie
  compteParentId Int?
  compteParent   CompteComptable?  @relation("HierarchieComptes", fields: [compteParentId], references: [id])
  sousComptes    CompteComptable[] @relation("HierarchieComptes")
  // Tiers (pour comptes auxiliaires)
  tiersType      String?       // "CLIENT" | "FOURNISSEUR" | "EMPLOYE"
  tiersNom       String?
  // Relations
  lignesEcriture LigneEcriture[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([classe])
  @@index([type])
  @@index([nature])
}

model EcritureComptable {
  id          Int                  @id @default(autoincrement())
  reference   String               @unique
  date        DateTime
  libelle     String
  journal     TypeJournalComptable
  statut      StatutEcriture       @default(BROUILLON)
  notes       String?
  // Auteur
  userId      Int?
  user        User?                @relation(fields: [userId], references: [id])
  // Lignes (débit/crédit)
  lignes      LigneEcriture[]

  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([journal])
  @@index([statut])
  @@index([date])
}

model LigneEcriture {
  id            Int               @id @default(autoincrement())
  ecritureId    Int
  ecriture      EcritureComptable @relation(fields: [ecritureId], references: [id], onDelete: Cascade)
  compteId      Int
  compte        CompteComptable   @relation(fields: [compteId], references: [id])
  libelle       String
  debit         Decimal           @default(0)
  credit        Decimal           @default(0)
  // TVA
  isTva         Boolean           @default(false)
  tauxTva       Decimal?          // 18 pour 18%
  montantTva    Decimal?

  @@index([ecritureId])
  @@index([compteId])
}

model RapprochementBancaire {
  id                  Int                 @id @default(autoincrement())
  periode             String              // format "YYYY-MM"
  soldeBancaireReel   Decimal
  soldeComptable      Decimal
  ecart               Decimal
  notes               String?
  statut              StatutRapprochement @default(EN_COURS)
  userId              Int?
  user                User?               @relation(fields: [userId], references: [id])

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([periode])
  @@index([statut])
}

model DeclarationTVA {
  id              Int        @id @default(autoincrement())
  periode         String     // format "YYYY-MM"
  tvaCollectee    Decimal    @default(0)  // TVA sur ventes
  tvaDeductible   Decimal    @default(0)  // TVA sur achats
  tvaDue          Decimal    @default(0)  // = collectée - déductible
  statut          StatutTVA  @default(BROUILLON)
  notes           String?
  userId          Int?
  user            User?      @relation(fields: [userId], references: [id])

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([periode])
}