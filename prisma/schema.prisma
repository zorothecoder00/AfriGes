// OGRH — MODULE 5 : RECRUTEMENT
// ============================================================

enum StatutPoste {
  BROUILLON  // créé, en attente de validation interne
  OUVERT     // validé et publié
  EN_COURS   // recrutement actif
  POURVU     // poste occupé
  ANNULE
}

enum StatutCandidature {
  RECU
  PRE_QUALIFICATION // premier filtre téléphonique ou écrit
  SHORTLISTE
  ENTRETIEN
  TEST              // test technique / pratique
  VALIDATION        // validation RH / direction
  OFFRE
  INTEGRATION       // processus d'onboarding en cours
  ACCEPTE
  REJETE
}

model PosteOuvert {
  id                  Int         @id @default(autoincrement())
  reference           String?     @unique // ex: REC-2026-0001 (auto-généré)
  titre               String
  departement         String?
  service             String?
  lieu                String?
  typeContrat         TypeContrat?
  description         String?
  exigences           String?     // profil requis (ex-competencesRequises)
  competencesRequises String?     // conservé pour compatibilité
  experienceMin       Int?        // années d'expérience minimum
  nbPostes            Int         @default(1)
  salaireMini         Int?        // FCFA
  salaireMaxi         Int?        // FCFA
  budgetPoste         Int?        // budget total alloué au recrutement (FCFA)
  dateOuverture       DateTime    @default(now())
  dateLimite          DateTime?
  statut              StatutPoste @default(OUVERT)
  validateurId        Int?        // User.id du validateur interne
  dateValidation      DateTime?   // date de validation interne
  notes               String?
  createdById         Int         // User.id

  candidatures Candidature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([createdById])
}

model Candidature {
  id               Int               @id @default(autoincrement())
  posteId          Int
  nomCandidat      String
  prenomCandidat   String
  email            String?
  telephone        String?
  cvUrl            String?
  lettreUrl        String?
  statut           StatutCandidature @default(RECU)
  scoreCandidat    Int?              // score global /100 (calculé ou saisi)
  noteEntretien    Decimal?          // note /5 après entretien
  noteTest         Decimal?          // note /20 après test technique
  dateEntretien    DateTime?
  dateTest         DateTime?
  commentaire      String?
  notes            String?
  competences      String?           // tags CSV ex: "React,TypeScript,Node.js"
  formation        String?           // ex: "Bac+5 Informatique"
  experienceAnnees Int?              // nb années d'expérience déclarées
  sourceCandidat   String?           // ex: "LinkedIn", "Recommandation", "Site web"
  dateCandidature  DateTime          @default(now())

  poste      PosteOuvert        @relation(fields: [posteId], references: [id], onDelete: Cascade)
  onboarding OnboardingEmploye?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([posteId])
  @@index([statut])
  @@index([scoreCandidat])
}

// ============================================================
// OGRH — MODULE 4 : ONBOARDING
// Déclenché automatiquement à l'acceptation d'une candidature.
// Crée en une transaction : matricule + email pro + ProfilRH + checklist.
// ============================================================

enum StatutOnboarding {
  EN_COURS   // onboarding lancé, étapes en progression
  TERMINE    // toutes les étapes obligatoires sont FAIT
  SUSPENDU   // mis en pause (ex: délai de prise de poste)
  ANNULE     // collaborateur n'a finalement pas rejoint
}

enum TypeEtapeOnboarding {
  SIGNATURE_CONTRAT  // signature du contrat de travail
  REMISE_MATERIEL    // remise ordinateur, badge, téléphone…
  FORMATION          // session de formation d'intégration
  AFFECTATION        // affectation au PDV / service / manager
  ACCES_SYSTEME      // création des accès informatiques
  PRESENTATION       // présentation à l'équipe
  AUTRE
}

enum StatutEtapeOnboarding {
  EN_ATTENTE  // pas encore traitée
  FAIT        // complétée
  IGNORE      // volontairement ignorée (non applicable)
}

/// Template de checklist réutilisable — 1 template par profil de poste ou type de contrat
model TemplateOnboarding {
  id          Int     @id @default(autoincrement())
  nom         String  // ex: "Intégration Commercial", "Onboarding Tech"
  description String?
  actif       Boolean @default(true)
  createdById Int     // User.id du RH qui a créé le template

  etapes      EtapeTemplate[]
  onboardings OnboardingEmploye[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([actif])
}

/// Étape d'un template — ordonnée, copiée vers EtapeOnboarding à la création de l'instance
model EtapeTemplate {
  id          Int                 @id @default(autoincrement())
  templateId  Int
  ordre       Int                 // position dans la checklist (1, 2, 3…)
  titre       String
  description String?
  type        TypeEtapeOnboarding @default(AUTRE)
  delaiJours  Int                 @default(0)   // délai max en jours depuis le début de l'onboarding
  obligatoire Boolean             @default(true) // si false : peut être IGNORE sans bloquer la progression

  template TemplateOnboarding @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([templateId, ordre])
}

/// Instance d'onboarding créée automatiquement lors de l'acceptation d'une candidature
/// Matricule, email professionnel et ProfilRH sont créés dans la même transaction
model OnboardingEmploye {
  id             Int              @id @default(autoincrement())
  candidatureId  Int              @unique  // 1 onboarding par candidature
  profilRHId     Int              @unique  // 1 onboarding par collaborateur
  templateId     Int?             // template source (null si checklist créée manuellement)
  statut         StatutOnboarding @default(EN_COURS)
  dateDebut      DateTime         @default(now())
  dateFinPrevue  DateTime?        // calculée : dateDebut + max(delaiJours des étapes)
  dateCloture    DateTime?        // remplie quand statut → TERMINE ou ANNULE
  progressionPct Int              @default(0)  // mis à jour à chaque changement d'étape
  notes          String?
  createdById    Int              // User.id du RH qui a validé le recrutement

  candidature Candidature         @relation(fields: [candidatureId], references: [id])
  profilRH    ProfilRH            @relation(fields: [profilRHId],    references: [id])
  template    TemplateOnboarding? @relation(fields: [templateId],    references: [id])
  etapes      EtapeOnboarding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([dateDebut])
}

/// Instance d'une étape pour un onboarding spécifique (copiée depuis EtapeTemplate ou créée manuellement)
model EtapeOnboarding {
  id           Int                   @id @default(autoincrement())
  onboardingId Int
  ordre        Int
  titre        String
  description  String?
  type         TypeEtapeOnboarding   @default(AUTRE)
  statut       StatutEtapeOnboarding @default(EN_ATTENTE)
  obligatoire  Boolean               @default(true)

  // Responsable et délai
  responsableId Int?      // User.id de la personne chargée de cette étape
  dateLimite    DateTime?
  dateFaite     DateTime?
  commentaire   String?

  onboarding OnboardingEmploye @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([onboardingId])
  @@index([onboardingId, ordre])
  @@index([statut])
}

