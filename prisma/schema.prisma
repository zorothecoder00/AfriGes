// ============================================================
// UTILISATEURS & AUTH
// ============================================================

model User {
  id           Int          @id @default(autoincrement())
  uuid         String       @unique @default(uuid())
  nom          String
  prenom       String
  email        String       @unique
  photo        String?
  role         Role?
  telephone    String?
  adresse      String?
  passwordHash        String?
  etat                MemberStatus @default(ACTIF)
  tokenVersion        Int          @default(0)
  mustChangePassword  Boolean      @default(false)
  dateAdhesion        DateTime     @default(now())

  // Jeton opaque pour l'accès SANS login à la tournée/objectifs du jour de l'agent
  // (QR « capability URL » — le jeton EST la clé). Régénérable pour invalider un QR.
  scanTokenTournee    String?      @unique

  // Profil gestionnaire (rôle opérationnel)
  gestionnaire         Gestionnaire?

  // Finances
  wallet               Wallet?
  factures             Facture[]

  // Système
  auditLogs            AuditLog[]
  notifications           Notification[]
  preferenceNotifRH       PreferenceNotificationRH?
  piecesJustificatives    PieceJustificative[]
  userPermissions      UserPermission[]
  securityLogs         SecurityLog[]
  messagesEnvoyes      Message[]            @relation("MessagesEnvoyes")
  messagesRecus        Message[]            @relation("MessagesRecus")

  // Packs & fidélité      
  souscriptionsPacks   SouscriptionPack[]  
  pointsFidelite       PointsFidelite?

  clientsAssignes      Client[]             @relation("ClientAgentTerrain")
  clientAffectations   ClientAgentAffectation[] @relation("ClientAgentAffectations")

  // Collectes journalières
  collectesAgent       CollecteJournaliere[] @relation("CollectesAgent")
  collectesValidees    CollecteJournaliere[] @relation("CollectesValideur")

  // Comptabilité
  cloturesComptables   ClotureComptable[]
  ecrituresComptables  EcritureComptable[]
  rapprochements       RapprochementBancaire[]
  declarationsTVA      DeclarationTVA[]
  journalValidations   JournalValidation[]

  // Points de vente — cet user est RPV d'un PDV (1-1)
  pointDeVenteRPV      PointDeVente?        @relation("RPVPointDeVente")
  // PDV supervisés en tant que chef d'agence (1-N)
  pointsDeVenteChef    PointDeVente[]       @relation("ChefAgencePDV")
  // Affectations opérationnelles à des PDV / dépôts
  affectationsPDV      GestionnaireAffectation[]

  // Opérations stock
  anomaliesSignalees   AnomalieStock[]      @relation("AnomaliesSignalees")
  anomaliesTraitees    AnomalieStock[]      @relation("AnomaliesTraitees")
  receptionsRealisees  ReceptionApprovisionnement[] @relation("ReceptionnaireAppro")
  receptionsValidees   ReceptionApprovisionnement[] @relation("ValidateurAppro")
  transfertsCrees      TransfertStock[]     @relation("CreateurTransfert")
  transfertsValides    TransfertStock[]     @relation("ValidateurTransfert")
  inventairesRealises  InventaireSite[]     @relation("RealisateurInventaire")
  inventairesValides   InventaireSite[]     @relation("ValidateurInventaire")
  commandesInternes    CommandeInterne[]    @relation("DemandeurCommande")
  mouvementsStock      MouvementStock[]     @relation("MouvementsStock")
  changementsPrix      HistoriquePrixProduit[] @relation("HistoriquePrixCreateur")
  bonsSortieCreePar    BonSortie[]          @relation("BonsSortieCreePar")
  bonsSortieValidePar  BonSortie[]          @relation("BonsSortieValidePar")
  demandesAjustement    DemandeAjustementStock[] @relation("DemandesAjustement")
  validationsAjustement DemandeAjustementStock[] @relation("ValidationsAjustement")

  // Caisse
  sessionsCaisseOuvertes CaissePDV[]          @relation("CaissesPDVRPV")
  sessionsCaisse         SessionCaisse[]      @relation("SessionsCaisseCaissier")
  operationsCaisse       OperationCaisse[]    @relation("OperationsCaisse")
  operationsCaissePDV    OperationCaissePDV[] @relation("OperationsCaissePDV")
  transfertsCaisse       TransfertCaisse[]    @relation("TransfertsCaisse")

  // Ventes directes
  ventesDirectes       VenteDirecte[]       @relation("VendeurVente")

  // Contrôle terrain
  visitesControle      VisiteControle[]     @relation("ControleurVisite")

  // Crédits clients
  creditsCreees                CreditClient[]       @relation("CreditCreateur")
  creditsValides               CreditClient[]       @relation("CreditValidateur")
  creditsGeres                 CreditClient[]       @relation("CreditGestionnaire")
  facturesVenteEmises          FactureVente[]       @relation("FacturesVenteEmises")
  remboursementsEnregistres    RemboursementCredit[]      @relation("RemboursementEnregistrePar")
  remboursementsCollectes      RemboursementCredit[]      @relation("RemboursementAgentCollecteur")
  lignesSouscriptionTraitees   LigneSouscriptionProduit[] @relation("LignesTraitees")
  lignesCreditTraitees         LigneCreditClient[]        @relation("LignesCreditTraitees")

  // Visites terrain
  visitesEffectuees            VisiteClient[]       @relation("VisitesAgent")

  // Documents clients uploadés par cet utilisateur
  documentsUploades            ClientDocument[]     @relation("DocumentsUploades")
  // Transactions terrain enregistrées par cet agent
  transactionsAgent            ClientTransaction[]  @relation("TransactionsAgent")
  // Scores clients calculés par cet utilisateur
  scoresCalcules               ClientScoreHistorique[] @relation("ScoresCalcules")
  // Clients validés ou rejetés par ce RVC
  clientsValides               Client[]             @relation("ClientValidateur")

  // RIA
  depotsRIAValides             DepotInvestisseur[]      @relation("DepotsValides")
  retraitsRIAValides           RetraitInvestisseur[]    @relation("RetraitsValides")
  actionsRIAEffectuees         ActionRecouvrementRIA[]  @relation("ActionsRIAEffectuees")
  eligibilitesRIAIdentifiees   EligibiliteClientRIA[]   @relation("EligibilitesRIAIdentifiees")
  commissionsRIA               CommissionAgentRIA[]     @relation("CommissionsAgent")
  commissionsApprouvees        CommissionAgentRIA[]     @relation("CommissionsApprob")
  documentsRIAGeneres          DocumentRIAGenere[]      @relation("DocumentsRIAGeneres")
  membresCommissionRIA         MembreCommissionRIA[]    @relation("MembresCommissionRIA")
  reunionsOrganisees           ReunionCommissionRIA[]   @relation("ReunionsOrganisees")
  resolutionsResponsable       ResolutionCommRIA[]      @relation("ResolutionsResponsable")
  plansActionResponsable       PlanActionCommRIA[]      @relation("PlansActionResponsable")

  // Gouvernance RIA — extensions CDC
  compteRendusValides          CompteRenduReunionRIA[]  @relation("CRValidesPar")
  dossiersICCrees              DossierInterCommission[] @relation("DossiersICCrees")
  dossiersICValides            DossierInterCommission[] @relation("DossiersICValides")
  versionsDossiersIC           VersionDossierIC[]       @relation("VersionsDossiersIC")
  echangesICAuteur             EchangeInterCommission[] @relation("EchangesICAuteur")
  observationsCommRIA          ObservationCommissionRIA[] @relation("ObservationsCommRIA")
  rapportsCommRediges          RapportCommissionRIA[]   @relation("RapportsCommRediges")
  rapportsCommValides          RapportCommissionRIA[]   @relation("RapportsCommValides")
  anomaliesRIAResolues         AnomalieGouvRIA[]        @relation("AnomaliesRIAResolues")
  missionsAuditRIA             MissionAuditRIA[]        @relation("MissionsAuditRIAAuditeur")
  analysesOptimisationRIA      AnalyseOptimisationRIA[] @relation("AnalysesOptimisationRIAAnalyste")

  // Comptes courants clients (module Compte Courant)
  comptesCourantsCrees         CompteCourant[]          @relation("CCCreateur")
  mouvementsCompteCourant      MouvementCompteCourant[] @relation("CCMouvementUser")
  mouvementsCCApportes         MouvementCompteCourant[] @relation("CCMouvementAgentApporteur")
  membresCCAjoutes             MembreCompteCourant[]    @relation("MembreCCAjoutePar")
  plansEpargneCrees            PlanEpargne[]            @relation("PlanEpargneCreePar")
  prelevementsAutoCrees        AutorisationPrelevement[] @relation("PrelevementAutoCreePar")
  transactionsFideliteCreees   TransactionFidelite[]    @relation("TransactionFideliteCreePar")
  blocagesEpargneCrees         BlocageEpargne[]         @relation("BlocageEpargneCreePar")
  prixProduitsCrees            PrixProduit[]            @relation("PrixProduitCreePar")
  demandesPrixSoumises         DemandeChangementPrix[]  @relation("DemandePrixDemandeur")
  demandesPrixValidees         DemandeChangementPrix[]  @relation("DemandePrixValideur")
  promotionsCreees             Promotion[]              @relation("PromotionCreePar")
  lotsProduitsCrees            LotProduit[]             @relation("LotProduitCreePar")
  mouvementsLot                MouvementLot[]           @relation("MouvementLotOperateur")
  produitsSubstitutsCrees      ProduitSubstitut[]       @relation("ProduitSubstitutCreePar")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Profil gestionnaire — rôle opérationnel + actionnaire
model Gestionnaire {
  id       Int              @id @default(autoincrement())
  memberId Int              @unique
  role     RoleGestionnaire
  actif    Boolean          @default(true)
  zone     String?          // Zone géographique de couverture (ex: "Cocody Nord")

  member                  User                   @relation(fields: [memberId], references: [id])
  assemblees              AssembleeParticipant[]
  actionnaireProfile      ActionnaireProfile?
  procurationsMandant     ProcurationAssemblee[] @relation("procurationsMandant")
  procurationsMandataire  ProcurationAssemblee[] @relation("procurationsMandataire")

  // OGRH
  profilRH                ProfilRH?

  // RIA
  profilRIA               ProfilInvestisseurRIA?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// POINTS DE VENTE & DÉPÔTS CENTRAUX
// Un PointDeVente peut être un PDV classique ou un dépôt central
// ============================================================

model PointDeVente {
  id        Int              @id @default(autoincrement())
  type      TypePointDeVente @default(POINT_DE_VENTE)
  code      String           @unique
  nom       String
  adresse   String?
  telephone String?
  actif     Boolean          @default(true)
  notes     String?

  // RPV responsable (type POINT_DE_VENTE uniquement, 1-1)
  rpvId Int?  @unique
  rpv   User? @relation("RPVPointDeVente", fields: [rpvId], references: [id])

  // Chef d'agence superviseur (peut superviser plusieurs PDV)
  chefAgenceId Int?
  chefAgence   User? @relation("ChefAgencePDV", fields: [chefAgenceId], references: [id])

  // Bulk pour clients
  clientsPDV ClientPointDeVente[]
     
  // Relations opérationnelles
  affectations          GestionnaireAffectation[]
  clients               Client[]
  stocks                StockSite[]
  sessionsCaisse        SessionCaisse[]
  caissesPDV            CaissePDV[]
  clotures              ClotureCaisse[]
  inventaires           InventaireSite[]
  mouvementsStock       MouvementStock[]
  ventesDirectes        VenteDirecte[]
  anomaliesStock        AnomalieStock[]
  bonsSortie            BonSortie[]
  transfertsOrigine     TransfertStock[]             @relation("TransfertOrigine")
  transfertsDestination TransfertStock[]             @relation("TransfertDestination")
  receptionsAppro       ReceptionApprovisionnement[]
  receptionsCommeOrigine ReceptionApprovisionnement[] @relation("ReceptionsEnTantQuOrigine")
  commandesInternes     CommandeInterne[]
  visitesControle       VisiteControle[]
  livraisonsPacks            ReceptionProduitPack[]
  collectes                  CollecteJournaliere[]
  demandesAjustement         DemandeAjustementStock[]
  lignesSouscriptionProduits LigneSouscriptionProduit[]
  lignesCreditPDV            LigneCreditClient[]          @relation("LignesCreditPDV")
  facturesVente              FactureVente[]               @relation("FacturesVentePDV")
  prixProduits               PrixProduit[]                @relation("PrixProduitPDV")
  promotions                 Promotion[]                  @relation("PromotionPDV")
  lots                       LotProduit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

// Affectation d'un gestionnaire (caissier, magasinier, agent, etc.) à un PDV ou dépôt
model GestionnaireAffectation {
  id             Int          @id @default(autoincrement())
  userId         Int
  pointDeVenteId Int
  actif          Boolean      @default(true)
  dateDebut      DateTime     @default(now())
  dateFin        DateTime?
  notes          String?

  user         User         @relation(fields: [userId], references: [id])
  pointDeVente PointDeVente @relation(fields: [pointDeVenteId], references: [id])

  // Pas de @@unique : un user peut être ré-affecté au même PDV après une période d'absence
  // L'unicité d'affectation active se gère au niveau applicatif (actif = true)
  @@index([userId])
  @@index([pointDeVenteId])
  @@index([userId, pointDeVenteId, actif])
}

// ============================================================
// CLIENTS
// ============================================================

model Client {
  id                 Int               @id @default(autoincrement())

  // ── Champs legacy (ne pas supprimer) ──────────────────────
  nom                String
  prenom             String
  telephone          String            @unique
  adresse            String?
  etat               MemberStatus      @default(ACTIF)

  // ── Nouveaux champs identité ───────────────────────────────
  codeClient         String?           @unique  // auto-généré (ex: CLI-00042)
  sexe               Sexe?
  dateNaissance      DateTime?
  telephoneSecondaire String?
  quartier           String?
  ville              String?
  commune            String?           // commune de rattachement (texte libre)
  photoUrl           String?           // URL stockage photo client
  pieceIdentiteUrl   String?           // URL scan pièce d'identité
  numeroCNI          String?           @unique  // numéro CNI (unique si renseigné)
  numeroCarteAfrisime String?          // N° carte client physique AfriSime

  // ── Activité & commerce ────────────────────────────────────
  activite           String?           // métier / secteur d'activité
  nomCommerce        String?           // nom de l'entreprise / boutique
  latitude           Float?            // coordonnée GPS latitude
  longitude          Float?            // coordonnée GPS longitude

  // ── Segment ────────────────────────────────────────────────
  segment            SegmentClient     @default(ORDINAIRE)

  // ── Type & crédit ──────────────────────────────────────────
  typeClient         TypeClient?       // COMPTANT ou CREDIT
  limiteCredit       Decimal?          // plafond de crédit accordé
  soldeActuel        Decimal?          @default(0) // solde en cours (mis à jour automatiquement)

  // ── Scoring (calculé automatiquement) ─────────────────────
  niveauRisque       NiveauRisque?     // FAIBLE / MOYEN / ELEVE / CRITIQUE
  scoreSolvabilite   Float?            // score 0–100

  // ── PDV de rattachement (optionnel) ───────────────────────
  pointDeVenteId Int?

  pointDeVente       PointDeVente?      @relation(fields: [pointDeVenteId], references: [id])

  agentTerrainId Int?
  agentTerrain       User?              @relation("ClientAgentTerrain", fields: [agentTerrainId], references: [id])

  agentAffectations  ClientAgentAffectation[]
  pointsDeVente      ClientPointDeVente[]
  tags               ClientTag[]
  souscriptionsPacks SouscriptionPack[]
  pointsFidelite     PointsFidelite?
  ventesDirectes     VenteDirecte[]
  lignesCollecte     LigneCollecte[]
  creditsClients     CreditClient[]
  visites            VisiteClient[]
  documents          ClientDocument[]
  transactions       ClientTransaction[]
  scoreHistorique    ClientScoreHistorique[]
  facturesVente      FactureVente[]           @relation("FacturesVenteClient")
  comptesCourants    CompteCourant[]                                   // titulaire principal (individuel ou collectif) — CDC §19.A
  membreDeComptesCC  MembreCompteCourant[]    @relation("MembreCC")    // comptes collectifs dont ce client est membre
  compteFidelite     CompteFidelite?                                   // programme de fidélité (CDC §19.D)

  // ── Validation RVC (tous nullable — données existantes non impactées) ───
  motifRejet       String?    // raison du rejet par le responsable crédit
  validationParId  Int?       // User.id du RVC qui a statué
  validationPar    User?      @relation("ClientValidateur", fields: [validationParId], references: [id])
  dateValidation   DateTime?  // date de la décision (activation ou rejet)

  // RIA
  affectationsRIA  AffectationClientRIA[]
  financementsRIA  OperationFinancementRIA[] @relation("FinancementsRIAClient")
  eligibiliteRIA   EligibiliteClientRIA?

  // Promotions ciblant nommément ce client (Catalogue §9) — Phase 5
  promotions       Promotion[]               @relation("PromotionClient")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([typeClient])
  @@index([segment])
  @@index([niveauRisque])
  @@index([ville])
  @@index([commune])
}

// ============================================================
// VISITES CLIENTS (tournées agents terrain)
// ============================================================

model VisiteClient {
  id         Int          @id @default(autoincrement())
  agentId    Int
  clientId   Int
  statut     StatutVisite @default(REALISEE)
  latitude   Float?
  longitude  Float?
  dateVisite DateTime     @default(now())
  notes      String?

  agent      User         @relation("VisitesAgent",  fields: [agentId],  references: [id])
  client     Client       @relation(fields: [clientId], references: [id])

  createdAt  DateTime     @default(now())

  @@index([agentId])
  @@index([clientId])
  @@index([dateVisite])
}

// Historique des affectations client ↔ agent terrain
// Permet un calcul de CA juste par période d'affectation (évite le double-comptage lors des réaffectations)
model ClientAgentAffectation {
  id        Int       @id @default(autoincrement())
  clientId  Int
  agentId   Int       // User.id du gestionnaire AGENT_TERRAIN
  dateDebut DateTime  @default(now())
  dateFin   DateTime?
  actif     Boolean   @default(true)
  notes     String?

  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agent     User      @relation("ClientAgentAffectations", fields: [agentId], references: [id])

  createdAt DateTime  @default(now())

  @@index([clientId])
  @@index([agentId])
  @@index([clientId, agentId, actif])
}

model ClientPointDeVente {
  id              Int @id @default(autoincrement())

  clientId        Int
  pointDeVenteId  Int

  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pointDeVente    PointDeVente  @relation(fields: [pointDeVenteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([clientId, pointDeVenteId])
  @@index([clientId])
  @@index([pointDeVenteId])
}

// ============================================================
// TAGS CLIENTS
// ============================================================

model Tag {
  id          Int            @id @default(autoincrement())
  nom         String         @unique
  couleur     String         @default("#6366f1") // hex couleur pour l'UI
  description String?
  segment     SegmentClient? // null = applicable à tous les segments
  actif       Boolean        @default(true)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  clients     ClientTag[]

  @@index([segment])
  @@index([actif])
}

// Table de jonction Client ↔ Tag (many-to-many)
model ClientTag {
  clientId  Int
  tagId     Int
  createdAt DateTime @default(now())

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([clientId, tagId])
  @@index([clientId])
  @@index([tagId])
}

// ============================================================
// DOCUMENTS CLIENTS
// ============================================================

model ClientDocument {
  id             Int                @id @default(autoincrement())
  clientId       Int
  client         Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)

  type           TypeDocumentClient @default(AUTRE)
  nom            String             // nom du fichier
  url            String             // URL de stockage
  uploadthingKey String?            // clé uploadthing si applicable
  taille         Int?               // taille en octets
  description    String?
  expireAt       DateTime?          // date d'expiration (ex : CNI)

  uploadePar     Int
  uploadeUser    User               @relation("DocumentsUploades", fields: [uploadePar], references: [id])

  createdAt      DateTime           @default(now())

  @@index([clientId])
  @@index([clientId, type])
}

// ============================================================
// TRANSACTIONS CLIENTS (historique financier unifié)
// ============================================================

model ClientTransaction {
  id            Int                   @id @default(autoincrement())
  clientId      Int
  client        Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)

  type          TypeTransactionClient
  montant       Decimal
  sens          String                // DEBIT | CREDIT (du point de vue du client)
  reference     String?               // référence de l'opération source
  description   String?

  // Lien polymorphique vers la source (pas de FK Prisma — souplesse maximale)
  sourceType    String?               // VERSEMENT_PACK | REMBOURSEMENT_CREDIT | VENTE_DIRECTE | COLLECTE
  sourceId      Int?

  agentId       Int?
  agent         User?                 @relation("TransactionsAgent", fields: [agentId], references: [id])

  dateOperation DateTime              @default(now())
  createdAt     DateTime              @default(now())

  @@index([clientId])
  @@index([clientId, type])
  @@index([clientId, dateOperation])
  @@index([sourceType, sourceId])
}

// ============================================================
// HISTORIQUE DES SCORES / RISQUE CLIENTS
// ============================================================

model ClientScoreHistorique {
  id               Int          @id @default(autoincrement())
  clientId         Int
  client           Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  niveauRisque     NiveauRisque
  scoreSolvabilite Float
  raison           String?      // REMBOURSEMENT | RETARD | RECALCUL_AUTO | MANUEL | CREATION

  calculePar       Int?
  calculeUser      User?        @relation("ScoresCalcules", fields: [calculePar], references: [id])

  createdAt        DateTime     @default(now())

  @@index([clientId])
  @@index([clientId, createdAt])
}

// ============================================================
// CRÉDITS CLIENTS
// ============================================================

model CreditClient {
  id               Int          @id @default(autoincrement())
  reference        String       @unique // ex: CRD-20260521-001

  clientId         Int
  client           Client       @relation(fields: [clientId], references: [id])

  pointDeVenteId   Int?
  // pas de relation directe ici — PointDeVente n'a pas de backlink crédit (optionnel)

  statut           StatutCredit @default(EN_ATTENTE_VALIDATION)

  // Formule commerciale (module POPC). Obligatoire pour les nouveaux crédits ;
  // détermine la durée (QUINZAINE → 16 échéances, TRENTAINE → 31), la dernière
  // échéance étant la collecte de rémunération (« 16ème » / « 31ème »).
  formule          FormuleCredit?

  // Montants
  montantTotal     Decimal
  montantRembourse Decimal      @default(0)
  soldeRestant     Decimal
  apportCompteCourant Decimal   @default(0) // part de l'achat réglée via le compte courant à la création (CDC §8)

  // Échéancier
  dureeJours       Int          // nombre de jours de remboursement
  dateDebut        DateTime     // date à partir de laquelle les remboursements commencent
  dateEcheanceFin  DateTime     // = dateDebut + dureeJours (calculé à la validation)
  montantJournalier Decimal     // = montantTotal / dureeJours (calculé à la validation)

  // Frais & intérêts (décomposition du montant total)
  fraisDossier     Decimal      @default(0)
  reductionFideliteFrais Decimal @default(0) // réduction des frais de dossier accordée via la fidélité (CDC §19.D)
  assurance        Decimal      @default(0)
  autresFrais      Decimal      @default(0)
  fraisLivraison   Decimal      @default(0)
  tauxInteret      Decimal      @default(0) // % appliqué sur la valeur des produits
  montantInteret   Decimal      @default(0) // = valeurProduits × tauxInteret / 100

  // Pénalités
  tauxPenalite     Decimal      @default(0) // % par jour de retard
  delaiGraceJours  Int          @default(0) // jours de grâce avant application des pénalités

  // Métadonnées
  garantie         String?
  // Garant structuré (bordereau — section Garantie)
  garantNom           String?
  garantTelephone     String?
  garantAdresse       String?
  garantTypeGarantie  String?   // caution, gage, hypothèque, aval…
  garantValeurEstimee Decimal   @default(0)
  observations     String?
  // Gestionnaire du crédit (bordereau) : User choisi manuellement ; fallback = RVC du PDV → validePar → creePar
  gestionnaireCreditId Int?
  gestionnaireCredit   User? @relation("CreditGestionnaire", fields: [gestionnaireCreditId], references: [id])

  // Traçabilité
  creeParId        Int
  creePar          User         @relation("CreditCreateur", fields: [creeParId], references: [id])
  valideParId      Int?
  validePar        User?        @relation("CreditValidateur", fields: [valideParId], references: [id])
  dateValidation   DateTime?

  // Consommation crédit via livraisons
  montantConsomme  Decimal      @default(0) // somme des VenteDirecte au statut CREDIT_LIVRE liées

  lignes           LigneCreditClient[]
  echeances        EcheanceCredit[]
  remboursements   RemboursementCredit[]
  livraisons       VenteDirecte[]
  facturesVente    FactureVente[]  @relation("CreditClientFactures")
  financementsRIA  OperationFinancementRIA[] @relation("FinancementsRIACredit")
  autorisationPrelevement AutorisationPrelevement?  // prélèvement automatique CC (CDC §19.C)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([statut])
  @@index([pointDeVenteId])
  @@index([dateDebut])
}

model LigneCreditClient {
  id           Int     @id @default(autoincrement())
  creditId     Int
  produitId    Int?    // nullable : produit hors catalogue non encore créé

  // Snapshot au moment de la vente (conservé même si produit modifié)
  produitNom       String
  produitNomSaisi  String?  // saisie libre originale — pour traçabilité si produit substitué
  quantite         Float    // décimal autorisé (ex: 0.5 = demi-quantité pour clients fragiles)
  prixUnitaire     Decimal
  remise           Decimal  @default(0)
  montantLigne     Decimal

  // Traçabilité livraison (comme LigneSouscriptionProduit)
  statut            StatutLigneCreditClient @default(EN_ATTENTE)
  estNouveauProduit Boolean                @default(false)
  notes             String?

  // PDV cible — dénormalisé depuis credit.pointDeVenteId pour agrégations logistique
  pointDeVenteId Int?
  pointDeVente   PointDeVente? @relation("LignesCreditPDV", fields: [pointDeVenteId], references: [id])

  // Substitution
  produitSubstitutId Int?
  produitSubstitut   Produit? @relation("LigneCreditSubstitut", fields: [produitSubstitutId], references: [id])

  // Traitement
  traiteParId    Int?
  traitePar      User?     @relation("LignesCreditTraitees", fields: [traiteParId], references: [id])
  dateTraitement DateTime?

  credit  CreditClient @relation(fields: [creditId], references: [id], onDelete: Cascade)
  produit Produit?     @relation("LigneCreditProduit", fields: [produitId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creditId])
  @@index([produitId])
  @@index([pointDeVenteId, statut])
  @@index([statut])
}

model EcheanceCredit {
  id             Int                  @id @default(autoincrement())
  creditId       Int
  numeroEcheance Int                  // 1, 2, 3 … dureeJours
  dateEcheance   DateTime
  montantDu      Decimal
  montantPaye    Decimal              @default(0)
  statut         StatutEcheanceCredit @default(EN_ATTENTE)
  penalite       Decimal              @default(0) // pénalité accumulée si retard

  credit CreditClient @relation(fields: [creditId], references: [id], onDelete: Cascade)

  @@index([creditId])
  @@index([statut])
  @@index([dateEcheance])
  @@index([creditId, statut])
}

model RemboursementCredit {
  id                Int          @id @default(autoincrement())
  creditId          Int
  montant           Decimal      // montant encaissé (saisi par l'utilisateur)
  dateRemboursement DateTime     @default(now()) // date de collecte (date réelle)
  modePaiement      TypePaiement @default(ESPECES)
  notes             String?      // observation / commentaire
  // EN_ATTENTE_CAISSIER = enregistré par agent/admin, en attente confirmation caissier
  // CONFIRME           = caissier a encaissé physiquement (effet financier appliqué)
  // REJETE             = caissier a rejeté (erreur de saisie, fraude, etc.)
  statut            String       @default("EN_ATTENTE_CAISSIER")

  // Encaissement journalier (nullable — données existantes non impactées)
  numeroJour        Int?         // N° de jour de la collecte (1..dureeJours)
  montantAttendu    Decimal?     // montant attendu = échéance du jour (calcul auto)
  agentCollecteurId Int?         // agent ayant physiquement collecté
  agentCollecteur   User?        @relation("RemboursementAgentCollecteur", fields: [agentCollecteurId], references: [id])

  enregistreParId   Int
  enregistrePar     User         @relation("RemboursementEnregistrePar", fields: [enregistreParId], references: [id])

  credit CreditClient @relation(fields: [creditId], references: [id], onDelete: Cascade)

  dateConfirmation  DateTime?    // date où le caissier a confirmé (statut → CONFIRME)

  createdAt DateTime @default(now())

  @@index([creditId])
  @@index([statut])
  @@index([dateRemboursement])
  @@index([dateConfirmation])
  @@index([agentCollecteurId])
}

// ============================================================
// COLLECTES JOURNALIÈRES (terrain)
// ============================================================

// Session de collecte d'un agent pour une journée donnée
model CollecteJournaliere {
  id              Int             @id @default(autoincrement())
  reference       String          @unique  // ex: COL-20260521-001
  agentId         Int                      // User AGENT_TERRAIN
  pointDeVenteId  Int?                     // PDV de rattachement de l'agent
  dateCollecte    DateTime                 // jour de la tournée
  statut          StatutCollecte  @default(EN_COURS)
  montantPrevu    Decimal         @default(0) // somme des montantAttendu des lignes
  montantCollecte Decimal         @default(0) // somme réellement encaissée
  notes           String?

  // Validation admin
  valideParId     Int?
  dateValidation  DateTime?

  agent           User            @relation("CollectesAgent",    fields: [agentId],        references: [id])
  validePar       User?           @relation("CollectesValideur", fields: [valideParId],    references: [id])
  pointDeVente    PointDeVente?   @relation(fields: [pointDeVenteId], references: [id])
  lignes          LigneCollecte[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
  @@index([statut])
  @@index([dateCollecte])
  @@index([pointDeVenteId])
}

// Un encaissement dans une session de collecte → lié à une SouscriptionPack
model LigneCollecte {
  id               Int                  @id @default(autoincrement())
  collecteId       Int
  clientId         Int
  souscriptionId   Int                  // SouscriptionPack concernée
  montantAttendu   Decimal              // montant de l'échéance prévue
  montantCollecte  Decimal              @default(0)
  statut           StatutLigneCollecte  @default(EN_ATTENTE)
  notes            String?

  // Anti-fraude : coordonnées GPS + mode de paiement enregistrés au moment de la collecte
  latitude         Float?
  longitude        Float?
  modePaiement     String?              // ESPECES | MOBILE_MONEY | CHEQUE | VIREMENT

  // Lien vers le VersementPack créé lors de la validation (null avant validation)
  versementPackId  Int?                 @unique

  collecte         CollecteJournaliere  @relation(fields: [collecteId],     references: [id], onDelete: Cascade)
  client           Client               @relation(fields: [clientId],       references: [id])
  souscription     SouscriptionPack     @relation(fields: [souscriptionId], references: [id])
  versementPack    VersementPack?       @relation(fields: [versementPackId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([collecteId])
  @@index([clientId])
  @@index([souscriptionId])
}
  
// ============================================================
// FOURNISSEURS
// ============================================================

model Fournisseur {
  id        Int      @id @default(autoincrement())
  nom       String
  contact   String?
  telephone String?
  email     String?
  adresse   String?
  notes     String?
  actif     Boolean  @default(true)

  receptions ReceptionApprovisionnement[]
  produits   Produit[]                        // catalogue : produits dont il est le fournisseur principal (Catalogue §3)
  lots       LotProduit[]                     // lots réceptionnés de ce fournisseur (Catalogue Ent.#5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// CATALOGUE — RÉFÉRENTIELS (Catalogue §2, §3) — Phase 1
// ============================================================

// Statut de commercialisation d'un produit (Catalogue §14, §21).
enum StatutProduit {
  ACTIF        // commercialisé normalement
  EN_ATTENTE   // créé, en attente de validation / complétion
  SUSPENDU     // temporairement retiré de la vente
  MASQUE       // masqué des vues (non visible au catalogue) mais conservé
  ARCHIVE      // archivé (fin de vie), conservé pour l'historique
}

model FamilleProduit {
  id           Int                  @id @default(autoincrement())
  nom          String               @unique
  description  String?
  actif        Boolean              @default(true)
  sousFamilles SousFamilleProduit[]
  produits     Produit[]
  promotions   Promotion[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model SousFamilleProduit {
  id        Int            @id @default(autoincrement())
  nom       String
  familleId Int
  famille   FamilleProduit @relation(fields: [familleId], references: [id], onDelete: Cascade)
  actif     Boolean        @default(true)
  produits  Produit[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([familleId, nom])
  @@index([familleId])
}

model CategorieProduit {
  id             Int                    @id @default(autoincrement())
  nom            String                 @unique
  description    String?
  actif          Boolean                @default(true)
  sousCategories SousCategorieProduit[]
  produits       Produit[]
  promotions     Promotion[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model SousCategorieProduit {
  id          Int              @id @default(autoincrement())
  nom         String
  categorieId Int
  categorie   CategorieProduit @relation(fields: [categorieId], references: [id], onDelete: Cascade)
  actif       Boolean          @default(true)
  produits    Produit[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([categorieId, nom])
  @@index([categorieId])
}

model MarqueProduit {
  id        Int       @id @default(autoincrement())
  nom        String      @unique
  logoUrl    String?
  actif      Boolean     @default(true)
  produits   Produit[]
  promotions Promotion[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

// Unité de mesure (vente ou achat) : "Kilogramme" (kg), "Carton", "Pièce"…
model UniteProduit {
  id             Int       @id @default(autoincrement())
  nom            String    @unique
  symbole        String?
  actif          Boolean   @default(true)
  produitsVente  Produit[] @relation("ProduitUniteVente")
  produitsAchat  Produit[] @relation("ProduitUniteAchat")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ============================================================
// PRODUITS & STOCK
// ============================================================

model Produit {
  id           Int     @id @default(autoincrement())
  reference    String? @unique // référence interne (saisie manuelle)
  nom          String
  description  String?
  categorie    String? // legacy (texte libre) — conservé ; classification structurée ci-dessous
  unite        String? // legacy ("kg", "litre"…) — conservé ; unités structurées ci-dessous
  prixUnitaire Decimal
  prixAchat    Decimal?  // 👈 nouveau champ (nullable conseillé)
  alerteStock  Int     @default(0) // seuil d'alerte global
  actif        Boolean @default(true)

  // ── Catalogue §3 : identification enrichie ───────────────────────────────
  codeProduit    String?       @unique  // code produit auto-généré (ex: PRD-000001)
  codeBarre      String?       @unique  // code-barres (EAN/UPC)
  qrCode         String?                // contenu/URL encodé dans le QR
  nomCommercial  String?
  statut         StatutProduit @default(ACTIF)

  // ── Catalogue §3 : classification structurée ─────────────────────────────
  familleId          Int?
  famille            FamilleProduit?       @relation(fields: [familleId], references: [id])
  sousFamilleId      Int?
  sousFamille        SousFamilleProduit?   @relation(fields: [sousFamilleId], references: [id])
  categorieId        Int?
  categorieProduit   CategorieProduit?     @relation(fields: [categorieId], references: [id])
  sousCategorieId    Int?
  sousCategorie      SousCategorieProduit? @relation(fields: [sousCategorieId], references: [id])
  marqueId           Int?
  marque             MarqueProduit?        @relation(fields: [marqueId], references: [id])
  fournisseurPrincipalId Int?
  fournisseurPrincipal   Fournisseur?      @relation(fields: [fournisseurPrincipalId], references: [id])
  paysOrigine        String?

  // ── Catalogue §3 : caractéristiques ──────────────────────────────────────
  poids           Decimal?   // en kg
  volume          Decimal?   // en litres
  dimensions      String?    // ex: "30x20x10 cm"
  couleur         String?
  saveur          String?
  conditionnement String?    // ex: "Carton de 12"
  uniteVenteId    Int?
  uniteVente      UniteProduit? @relation("ProduitUniteVente", fields: [uniteVenteId], references: [id])
  uniteAchatId    Int?
  uniteAchat      UniteProduit? @relation("ProduitUniteAchat", fields: [uniteAchatId], references: [id])

  // ── Catalogue §3 : images & documents ────────────────────────────────────
  imagePrincipaleUrl String?
  imagesSecondaires  String[]  // URLs / data-URIs (Postgres array)
  ficheTechniqueUrl  String?
  videoUrl           String?

  // Stock localisé par site (remplace l'ancien champ global stock)
  stocks               StockSite[]
  mouvements           MouvementStock[]
  historiquePrix       HistoriquePrixProduit[]

  // Packs & fidélité
  lignesReceptionPack  LigneReceptionPack[]
  recompensesFidelite  RecompenseFidelite[]
  packsCibleProduit    Pack[]                    @relation("PackProduitCible")

  // Opérations stock
  anomalies            AnomalieStock[]
  lignesVenteDirecte   LigneVenteDirecte[]
  lignesTransfert      LigneTransfertStock[]
  lignesReceptionAppro LigneReceptionAppro[]
  lignesInventaire     LigneInventaireSite[]
  lignesCommande       LigneCommandeInterne[]
  lignesBonSortie      LigneBonSortie[]

  // Crédits clients
  lignesCreditProduit    LigneCreditClient[] @relation("LigneCreditProduit")
  lignesCreditSubstitut  LigneCreditClient[] @relation("LigneCreditSubstitut")

  // Ajustements stock
  demandesAjustement   DemandeAjustementStock[]

  // Lignes souscription produits
  lignesSouscriptionDemande   LigneSouscriptionProduit[] @relation("LigneProduitDemande")
  lignesSouscriptionSubstitut LigneSouscriptionProduit[] @relation("LigneProduitSubstitut")

  prix         PrixProduit[]  // tarification multiple (Catalogue §4) — Phase 2
  demandesPrix DemandeChangementPrix[]  // demandes de changement de prix (Catalogue §15) — Phase 4
  promotions   Promotion[]    @relation("PromotionProduit")  // promotions ciblant ce produit (Catalogue §9) — Phase 5
  lots         LotProduit[]   // lots & péremption FEFO (Catalogue Ent.#5) — Phase 10
  substituts     ProduitSubstitut[] @relation("ProduitSubstituts")      // équivalents proposés pour CE produit (Ent.#4) — Phase 11
  estSubstitutDe ProduitSubstitut[] @relation("ProduitEstSubstitutDe")  // produits dont CE produit est l'équivalent

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([familleId])
  @@index([categorieId])
  @@index([marqueId])
  @@index([fournisseurPrincipalId])
}

// ============================================================
// CATALOGUE — TARIFICATION FLEXIBLE (Catalogue §4, Ent.#1/#2/#6) — Phase 2
// ============================================================

// Type / profil de prix. Un même produit peut avoir plusieurs prix simultanés,
// éventuellement spécifiques à une agence, une ville ou une région (Ent.#1),
// ou associés à un profil de client (Ent.#2).
enum TypePrix {
  ACHAT          // prix d'achat
  FOURNISSEUR    // prix fournisseur (avant négociation/frais)
  REVIENT        // prix de revient (calculé : achat + frais logistiques)
  GROS           // prix de gros / grossiste
  DETAIL         // prix de détail (= prix comptant public)
  COMMUNAUTE     // prix Communauté AfriSime
  VIP            // prix VIP
  PROMOTION      // prix promotionnel (piloté aussi par le module Promotions)
  PERSONNEL      // prix personnel (employés)
  PARTENAIRE     // prix partenaire
  REVENDEUR      // prix revendeur
  CREDIT         // prix spécifique vente à crédit
  NOUVEAU_CLIENT // profil fidélité : nouveau client
  FIDELE         // profil fidélité : client fidèle
}

// Portée géographique d'un prix (Ent.#1 — tarification géographique).
enum PorteePrix {
  GLOBAL   // s'applique partout (défaut)
  AGENCE   // spécifique à un point de vente
  VILLE    // spécifique à une ville
  REGION   // spécifique à une région
}

// Ligne de prix d'un produit. La combinaison (produit, type, portée, cible) est
// unique parmi les lignes actives — l'unicité fine est gérée applicativement.
model PrixProduit {
  id           Int         @id @default(autoincrement())
  produitId    Int
  produit      Produit     @relation(fields: [produitId], references: [id], onDelete: Cascade)
  type         TypePrix
  montant      Decimal
  devise       String      @default("XOF")

  portee       PorteePrix  @default(GLOBAL)
  pointDeVenteId Int?                       // si portee = AGENCE
  pointDeVente PointDeVente? @relation("PrixProduitPDV", fields: [pointDeVenteId], references: [id])
  ville        String?                      // si portee = VILLE
  region       String?                      // si portee = REGION

  // Origine du prix : MANUEL (saisi) ou AUTO (moteur de prix). Ent.#6.
  auto         Boolean     @default(false)
  actif        Boolean     @default(true)
  dateDebut    DateTime?                    // début de validité (optionnel)
  dateFin      DateTime?                    // fin de validité (optionnel)

  creeParId    Int?
  creePar      User?       @relation("PrixProduitCreePar", fields: [creeParId], references: [id])

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([produitId])
  @@index([type])
  @@index([produitId, type, portee])
  @@index([pointDeVenteId])
}

// Paramétrage du moteur de prix automatique (Ent.#6) — enregistrement unique id=1.
// prixVente = arrondi( (coûtAchat + fraisLogistiques) × (1 + margeCible%) ).
model ParametragePrixAuto {
  id                 Int      @id @default(1)
  actif              Boolean  @default(false) // le recalcul auto n'écrase rien tant que désactivé
  margeCiblePct      Decimal  @default(20)    // marge cible par défaut (% sur le prix de revient)
  fraisLogistiquePct Decimal  @default(0)     // frais logistiques ajoutés au coût (% de l'achat)
  arrondi            Int      @default(0)     // arrondir le prix au multiple de N (0 = pas d'arrondi)
  appliquerSurCredit Boolean  @default(false) // recalcule aussi le prix CREDIT (avec marge crédit)
  margeCreditPct     Decimal  @default(0)     // marge additionnelle appliquée au prix crédit
  // Gouvernance des prix (Catalogue §15) : si activé, tout changement de prix de
  // vente/achat doit passer par une demande validée (Chef d'agence/Admin/Resp. Marketing).
  validationPrixObligatoire Boolean @default(false)
  updatedAt          DateTime @updatedAt
}

// Statut d'une demande de changement de prix (Catalogue §15).
enum StatutDemandePrix {
  EN_ATTENTE
  APPROUVE
  REJETE
}

// Base de prix visée par une demande (les deux prix « socle » du produit).
enum ChampPrixDemande {
  VENTE   // prix de vente (Produit.prixUnitaire)
  ACHAT   // prix d'achat (Produit.prixAchat)
}

// Demande de changement de prix soumise à validation (Catalogue §5, §15).
model DemandeChangementPrix {
  id           Int               @id @default(autoincrement())
  produitId    Int
  produit      Produit           @relation(fields: [produitId], references: [id], onDelete: Cascade)
  champ        ChampPrixDemande
  ancienPrix   Decimal?
  nouveauPrix  Decimal
  motif        String
  statut       StatutDemandePrix @default(EN_ATTENTE)

  // Traçabilité complète (Catalogue §15)
  demandeParId Int
  demandePar   User              @relation("DemandePrixDemandeur", fields: [demandeParId], references: [id])
  ip           String?
  agence       String?
  createdAt    DateTime          @default(now())

  valideParId  Int?
  validePar    User?             @relation("DemandePrixValideur", fields: [valideParId], references: [id])
  valideAt     DateTime?
  motifRejet   String?

  @@index([produitId])
  @@index([statut])
}

// ============================================================
// CATALOGUE — PROMOTIONS (Catalogue §9) — Phase 5
// ============================================================

// Nature de la remise appliquée par une promotion (§9 : fixe / % / lot).
enum TypeRemisePromotion {
  POURCENTAGE // remise en % du prix (ex : -15 %)
  MONTANT     // remise d'un montant fixe (ex : -500 XOF)
  LOT         // offre par lot (ex : acheté N, payé M)
}

// Périmètre produit d'une promotion : sur quoi elle porte (§9).
enum CiblePromotion {
  PRODUIT   // un produit précis
  CATEGORIE // toute une catégorie
  FAMILLE   // toute une famille
  MARQUE    // toute une marque
  TOUS      // tout le catalogue
}

// Promotion commerciale (Catalogue §9). Une promo porte sur un périmètre produit
// (produit/catégorie/famille/marque/tous) et peut être restreinte à une agence,
// un segment (communauté) ou un client précis, sur une période donnée.
model Promotion {
  id          Int    @id @default(autoincrement())
  code        String @unique // auto : PROMO-000001
  nom         String
  description String?

  // ── Périmètre produit (Catalogue §9) ─────────────────────────────────────
  cible       CiblePromotion    @default(PRODUIT)
  produitId   Int?
  produit     Produit?          @relation("PromotionProduit", fields: [produitId], references: [id])
  categorieId Int?
  categorie   CategorieProduit? @relation(fields: [categorieId], references: [id])
  familleId   Int?
  famille     FamilleProduit?   @relation(fields: [familleId], references: [id])
  marqueId    Int?
  marque      MarqueProduit?    @relation(fields: [marqueId], references: [id])

  // ── Nature de la remise (fixe / % / lot) ─────────────────────────────────
  typeRemise TypeRemisePromotion
  valeur     Decimal             @default(0) // % (POURCENTAGE) ou montant XOF (MONTANT)
  lotAchete  Int?                            // LOT : quantité à acheter
  lotPaye    Int?                            // LOT : quantité facturée

  // ── Restrictions bénéficiaires (agence / communauté / client) ────────────
  pointDeVenteId Int?
  pointDeVente   PointDeVente?  @relation("PromotionPDV", fields: [pointDeVenteId], references: [id])
  segment        SegmentClient? // limite à un segment (communauté) — null = tous
  clientId       Int?
  client         Client?        @relation("PromotionClient", fields: [clientId], references: [id])

  // ── Période & activation ─────────────────────────────────────────────────
  dateDebut DateTime
  dateFin   DateTime
  actif     Boolean  @default(true)
  priorite  Int      @default(0) // départage si plusieurs promos matchent (plus haut = prioritaire)

  creeParId Int?
  creePar   User?    @relation("PromotionCreePar", fields: [creeParId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([actif, dateDebut, dateFin])
  @@index([cible])
  @@index([produitId])
  @@index([categorieId])
  @@index([familleId])
  @@index([marqueId])
  @@index([pointDeVenteId])
}

// ============================================================
// CATALOGUE — LOTS & PÉREMPTION (FEFO) (Enterprise #5) — Phase 10
// ============================================================

// Cycle de vie d'un lot.
enum StatutLot {
  ACTIF  // en stock, vendable
  EPUISE // quantité épuisée
  PERIME // DLC dépassée, retiré de la vente
  RETIRE // retiré manuellement (rappel, casse, don…)
}

// Nature d'un mouvement de lot (traçabilité FEFO).
enum TypeMouvementLot {
  ENTREE     // réception / création du lot
  SORTIE     // déstockage (vente/livraison) — FEFO
  AJUSTEMENT // correction de quantité
  PEREMPTION // retrait pour péremption
  RETRAIT    // retrait manuel (rappel, casse)
}

// Lot d'un produit sur un site : quantité tracée avec date de péremption (DLC)
// et/ou durabilité minimale (DLUO). Le déstockage suit le principe FEFO
// (First Expired, First Out) : on consomme d'abord le lot qui périme le plus tôt.
model LotProduit {
  id               Int          @id @default(autoincrement())
  numeroLot        String
  produitId        Int
  produit          Produit      @relation(fields: [produitId], references: [id], onDelete: Cascade)
  pointDeVenteId   Int
  pointDeVente     PointDeVente @relation(fields: [pointDeVenteId], references: [id])

  quantiteInitiale Int
  quantite         Int          @default(0) // quantité restante dans le lot
  dlc              DateTime?    // date limite de consommation (péremption stricte)
  dluo             DateTime?    // date de durabilité minimale (qualité optimale)
  dateReception    DateTime     @default(now())
  prixAchat        Decimal?
  statut           StatutLot    @default(ACTIF)

  fournisseurId    Int?
  fournisseur      Fournisseur? @relation(fields: [fournisseurId], references: [id])
  receptionApproId Int?         // réception d'appro à l'origine du lot (traçabilité)
  receptionAppro   ReceptionApprovisionnement? @relation(fields: [receptionApproId], references: [id])
  notes            String?

  creeParId        Int?
  creePar          User?        @relation("LotProduitCreePar", fields: [creeParId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  mouvements       MouvementLot[]
  lignesReception  LigneReceptionAppro[]

  @@unique([produitId, pointDeVenteId, numeroLot])
  @@index([produitId, pointDeVenteId, statut])
  @@index([dlc])
  @@index([statut])
  @@index([receptionApproId])
}

// Journal des mouvements d'un lot (entrées / sorties FEFO / ajustements).
model MouvementLot {
  id          Int              @id @default(autoincrement())
  lotId       Int
  lot         LotProduit       @relation(fields: [lotId], references: [id], onDelete: Cascade)
  type        TypeMouvementLot
  quantite    Int              // valeur positive ; le sens dépend du type
  motif       String?
  operateurId Int?
  operateur   User?            @relation("MouvementLotOperateur", fields: [operateurId], references: [id])
  createdAt   DateTime         @default(now())

  @@index([lotId])
  @@index([type])
}

// ============================================================
// CATALOGUE — PRODUITS DE SUBSTITUTION (Enterprise #4) — Phase 11
// ============================================================

// Lien de substitution : `substitut` est un équivalent proposé pour `produit`
// (typiquement quand `produit` est en rupture). Relation dirigée + option
// `bidirectionnel` pour proposer aussi l'inverse. Priorité = ordre de préférence.
model ProduitSubstitut {
  id             Int      @id @default(autoincrement())
  produitId      Int
  produit        Produit  @relation("ProduitSubstituts", fields: [produitId], references: [id], onDelete: Cascade)
  substitutId    Int
  substitut      Produit  @relation("ProduitEstSubstitutDe", fields: [substitutId], references: [id], onDelete: Cascade)
  priorite       Int      @default(0)    // ordre de préférence (décroissant)
  bidirectionnel Boolean  @default(true) // si vrai, l'inverse est aussi un substitut
  note           String?
  creeParId      Int?
  creePar        User?    @relation("ProduitSubstitutCreePar", fields: [creeParId], references: [id])
  createdAt      DateTime @default(now())

  @@unique([produitId, substitutId])
  @@index([produitId])
  @@index([substitutId])
}

// ============================================================
// CATALOGUE — VUES PERSONNALISÉES (Catalogue §21-24) — Phase 12
// ============================================================

// Mode d'affichage du stock dans une vue (§21.H : le client ne voit jamais la
// quantité exacte, seulement un palier).
enum ModeStockVue {
  EXACT  // quantité exacte (personnel interne)
  PALIER // tranche « Plus de 50 / Disponible / Stock limité / Sur commande »
  AUCUN  // stock masqué
}

// Configuration d'une vue catalogue par profil/rôle (§22 — moteur de vues).
// Décrit, pour un rôle (Admin, Caissier, Client, Visiteur…), quels CHAMPS du
// produit sont visibles, comment le stock est affiché, et des filtres par
// défaut. Distinct du RBAC d'actions : ici on pilote la VISIBILITÉ des données.
// La configuration est centralisée (source unique) → cohérence entre surfaces
// mobile / web / borne / QR (§24 synchro).
model VueCatalogue {
  id             Int          @id @default(autoincrement())
  cle            String       @unique // ADMIN, CAISSIER, CLIENT, VISITEUR, ...
  nom            String
  description    String?
  champsVisibles String[]             // clés de champs visibles (voir lib/vuesCatalogue)
  modeStock      ModeStockVue @default(EXACT)
  filtres        Json?                // filtres par défaut (statut, famille, agence…) — §23
  actif          Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Stock d'un produit sur un site précis (PDV ou dépôt central)
model StockSite {
  id             Int          @id @default(autoincrement())
  produitId      Int
  pointDeVenteId Int
  quantite           Float    @default(0)  // 4.1 disponible — physiquement vendable (décimal : demi-quantités crédit)
  quantiteReservee   Float    @default(0)  // 4.2 réservé — engagé (ventes crédit en attente d'approbation)
  quantiteEnTransit  Int      @default(0)  // 4.3 en transit — commandé, non encore réceptionné
  quantiteEndommagee Int      @default(0)  // 4.4 endommagé — non vendable (perte/casse mis de côté)
  // 4.5 stockTheorique = quantite + quantiteReservee + quantiteEnTransit - quantiteEndommagee (calculé)
  alerteStock    Int?         // seuil d'alerte spécifique au site (override global)

  // ── Catalogue §6 : paramétrage par agence — Phase 3 ──────────────────────
  disponible     Boolean      @default(true)  // produit commercialisé (Oui/Non) sur cette agence
  stockMin       Int?         // stock minimum (déclenche le réapprovisionnement)
  stockMax       Int?         // stock maximum (capacité cible)
  seuilCritique  Int?         // seuil de rupture imminente (rouge) — sous ce niveau = critique
  rayon          String?      // emplacement : rayon
  etagere        String?      // emplacement : étagère
  allee          String?      // emplacement : allée

  produit      Produit      @relation(fields: [produitId], references: [id])
  pointDeVente PointDeVente @relation(fields: [pointDeVenteId], references: [id])

  @@unique([produitId, pointDeVenteId])
  @@index([pointDeVenteId])
  @@index([produitId])
}
  
// Journal de chaque mouvement de stock (entrée / sortie / ajustement)
model MouvementStock {
  id             Int              @id @default(autoincrement())
  produitId      Int
  pointDeVenteId Int?             // PDV ou dépôt concerné (nullable pour rétrocompat)
  type           TypeMouvement
  typeEntree     TypeEntreeStock? // précision si type == ENTREE
  typeSortie     TypeSortieStock? // précision si type == SORTIE
  quantite       Int
  prixUnitaire   Decimal?         // prix de vente au client (renseigné pour les sorties livraison pack)
  motif          String?
  reference      String           @unique
  dateMouvement  DateTime         @default(now())
  operateurId    Int?             // userId de l'opérateur

  // Références aux documents sources (traçabilité)
  receptionApproId Int?
  transfertStockId Int?
  venteDirecteId   Int?
  souscriptionId   Int?  // pour livraison pack
  bonSortieId      Int?  // pour sortie exceptionnelle (perte, casse, don…)

  produit      Produit       @relation(fields: [produitId], references: [id])
  pointDeVente PointDeVente? @relation(fields: [pointDeVenteId], references: [id])
  operateur    User?         @relation("MouvementsStock", fields: [operateurId], references: [id])

  @@index([produitId])
  @@index([pointDeVenteId])
  @@index([type])
  @@index([dateMouvement])
}

// Type de changement de prix (ce qui a été modifié dans l'entrée d'historique)
enum TypeChangementPrix {
  INITIAL   // création du produit
  ACHAT     // seul le prix d'achat a changé (typiquement lors d'un approvisionnement)
  VENTE     // seul le prix de vente (prixUnitaire) a changé
  LES_DEUX  // achat et vente modifiés en même temps
}

// Historique daté des prix d'un produit (achat & vente) — traçabilité & transparence.
// Chaque entrée est un SNAPSHOT des deux prix effectifs à partir de `dateEffet`,
// même si un seul des deux a changé : cela permet de retrouver le prix appliqué à
// n'importe quelle date et de calculer la marge figée du moment.
model HistoriquePrixProduit {
  id               Int                @id @default(autoincrement())
  produitId        Int
  prixAchat        Decimal?           // prix d'achat effectif à partir de dateEffet
  prixVente        Decimal            // prix de vente (prixUnitaire) effectif à partir de dateEffet
  marge            Decimal?           // vente - achat (valeur), figée au moment du changement
  type             TypeChangementPrix
  source           String?            // MANUEL | APPRO | INITIAL | VALIDATION | ...
  motif            String?
  receptionApproId Int?               // réception d'appro à l'origine d'un changement de prix d'achat
  ip               String?            // adresse IP de l'auteur (Catalogue §15)
  agence           String?            // agence de l'auteur au moment du changement (Catalogue §15)
  valideParId      Int?               // validateur si le changement a suivi le workflow (Catalogue §5)
  dateEffet        DateTime           @default(now())
  creeParId        Int?
  createdAt        DateTime           @default(now())

  produit Produit @relation(fields: [produitId], references: [id], onDelete: Cascade)
  creePar User?   @relation("HistoriquePrixCreateur", fields: [creeParId], references: [id])

  @@index([produitId, dateEffet])
  @@index([dateEffet])
}

// ============================================================
// RÉCEPTIONS D'APPROVISIONNEMENT (Magasinier / Agent Logistique)
// ============================================================

model ReceptionApprovisionnement {
  id        Int                  @id @default(autoincrement())
  reference String               @unique
  type      TypeReceptionAppro
  statut    StatutReceptionAppro @default(BROUILLON)

  // Site qui réceptionne (PDV ou dépôt)
  pointDeVenteId Int
  pointDeVente   PointDeVente @relation(fields: [pointDeVenteId], references: [id])

  // Pour réception FOURNISSEUR
  fournisseurId  Int?
  fournisseur    Fournisseur? @relation(fields: [fournisseurId], references: [id])
  fournisseurNom String?      // si fournisseur non encore enregistré

  // Pour réception INTERNE (depuis un autre dépôt / siège)
  origineId    Int?
  origineNom   String?
  origineDepot PointDeVente? @relation("ReceptionsEnTantQuOrigine", fields: [origineId], references: [id])

  datePrevisionnelle DateTime
  dateReception      DateTime?

  // Contrôle qualité — saisie obligatoire avant mise en stock
  controlQualite Boolean @default(false)
  notesQualite   String?
  notes          String?

  receptionneParId Int
  receptionnePar   User  @relation("ReceptionnaireAppro", fields: [receptionneParId], references: [id])
  valideParId      Int?
  validePar        User? @relation("ValidateurAppro", fields: [valideParId], references: [id])

  lignes LigneReceptionAppro[]
  lots   LotProduit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([type])
  @@index([pointDeVenteId])
}

model LigneReceptionAppro {
  id               Int     @id @default(autoincrement())
  receptionId      Int
  produitId        Int
  quantiteAttendue Int
  quantiteRecue    Int?
  prixUnitaire     Decimal?
  etatQualite      String? // "BON" | "DEFECTUEUX" | "PARTIEL"
  notes            String?

  // Lot & péremption (Enterprise #5) : si renseignés à la réception, un LotProduit
  // est créé automatiquement à la validation (traçabilité FEFO). Optionnels.
  numeroLot        String?
  dlc              DateTime? // date limite de consommation
  dluo             DateTime? // date de durabilité minimale
  // Lot effectivement créé/réalimenté par cette ligne (renseigné après la mise en stock).
  lotId            Int?
  lot              LotProduit? @relation(fields: [lotId], references: [id])

  reception ReceptionApprovisionnement @relation(fields: [receptionId], references: [id], onDelete: Cascade)
  produit   Produit                    @relation(fields: [produitId], references: [id])

  @@index([lotId])
}

// ============================================================
// TRANSFERTS DE STOCK (entre PDV et/ou dépôts)
// ============================================================

model TransfertStock {
  id        Int                  @id @default(autoincrement())
  reference String               @unique
  statut    StatutTransfertStock @default(EN_COURS)

  origineId     Int
  origine       PointDeVente @relation("TransfertOrigine", fields: [origineId], references: [id])
  destinationId Int
  destination   PointDeVente @relation("TransfertDestination", fields: [destinationId], references: [id])

  creeParId   Int
  creePar     User  @relation("CreateurTransfert", fields: [creeParId], references: [id])
  valideParId Int?
  validePar   User? @relation("ValidateurTransfert", fields: [valideParId], references: [id])

  dateExpedition DateTime?
  dateReception  DateTime?
  notes          String?

  lignes LigneTransfertStock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([origineId])
  @@index([destinationId])
}

model LigneTransfertStock {
  id          Int      @id @default(autoincrement())
  transfertId Int
  produitId   Int
  quantite    Int
  prixUnit    Decimal?

  transfert TransfertStock @relation(fields: [transfertId], references: [id], onDelete: Cascade)
  produit   Produit        @relation(fields: [produitId], references: [id])
}

// ============================================================
// INVENTAIRES (PDV et dépôts)
// ============================================================

model InventaireSite {
  id             Int              @id @default(autoincrement())
  reference      String           @unique
  statut         StatutInventaire @default(EN_COURS)
  pointDeVenteId Int
  dateInventaire DateTime         @default(now())
  notes          String?

  realiseParId Int
  realisePar   User  @relation("RealisateurInventaire", fields: [realiseParId], references: [id])
  valideParId  Int?
  validePar    User? @relation("ValidateurInventaire", fields: [valideParId], references: [id])

  pointDeVente PointDeVente         @relation(fields: [pointDeVenteId], references: [id])
  lignes       LigneInventaireSite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([pointDeVenteId])
}

model LigneInventaireSite {
  id                Int    @id @default(autoincrement())
  inventaireId      Int
  produitId         Int
  quantiteSysteme   Int    // quantité selon le système
  quantiteConstatee Int    // quantité réelle comptée
  ecart             Int    // = constatée - système

  inventaire InventaireSite @relation(fields: [inventaireId], references: [id], onDelete: Cascade)
  produit    Produit        @relation(fields: [produitId], references: [id])
}

// ============================================================
// COMMANDES INTERNES (réapprovisionnement demandé par un PDV/dépôt)
// ============================================================

model CommandeInterne {
  id             Int                   @id @default(autoincrement())
  reference      String                @unique
  statut         StatutCommandeInterne @default(BROUILLON)
  demandeurId    Int
  demandeur      User                  @relation("DemandeurCommande", fields: [demandeurId], references: [id])
  pointDeVenteId Int
  pointDeVente   PointDeVente          @relation(fields: [pointDeVenteId], references: [id])
  notes          String?

  lignes LigneCommandeInterne[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([pointDeVenteId])
}

model LigneCommandeInterne {
  id               Int    @id @default(autoincrement())
  commandeId       Int
  produitId        Int
  quantiteDemandee Int
  quantiteValidee  Int?

  commande CommandeInterne @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  produit  Produit         @relation(fields: [produitId], references: [id])
}

// ============================================================
// BONS DE SORTIE EXCEPTIONNELS (pertes, casses, dons, conso interne)
// Pour les sorties groupant plusieurs produits — document formel imprimable
// ============================================================

enum StatutBonSortie {
  BROUILLON
  VALIDE
  ANNULE
}

model BonSortie {
  id             Int             @id @default(autoincrement())
  reference      String          @unique
  typeSortie     TypeSortieStock // PERTE, CASSE, DON, CONSOMMATION_INTERNE, LIVRAISON_CLIENT
  statut         StatutBonSortie @default(BROUILLON)
  pointDeVenteId Int
  motif          String
  notes          String?
  creeParId      Int
  valideParId    Int?

  pointDeVente PointDeVente @relation(fields: [pointDeVenteId], references: [id])
  creePar      User         @relation("BonsSortieCreePar", fields: [creeParId], references: [id])
  validePar    User?        @relation("BonsSortieValidePar", fields: [valideParId], references: [id])
  lignes       LigneBonSortie[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([pointDeVenteId])
  @@index([typeSortie])
}

model LigneBonSortie {
  id          Int      @id @default(autoincrement())
  bonSortieId Int
  produitId   Int
  quantite    Int
  prixUnit    Decimal?

  bonSortie BonSortie @relation(fields: [bonSortieId], references: [id], onDelete: Cascade)
  produit   Produit   @relation(fields: [produitId], references: [id])
}

// ============================================================
// ANOMALIES STOCK
// ============================================================

model AnomalieStock {
  id             Int            @id @default(autoincrement())
  reference      String         @unique
  produitId      Int
  pointDeVenteId Int?
  type           TypeAnomalie
  quantite       Int
  description    String
  statut         StatutAnomalie @default(EN_ATTENTE)
  signalePar     Int
  traitePar      Int?
  commentaire    String?

  produit      Produit       @relation(fields: [produitId], references: [id])
  pointDeVente PointDeVente? @relation(fields: [pointDeVenteId], references: [id])
  magasinier   User          @relation("AnomaliesSignalees", fields: [signalePar], references: [id])
  traiteur     User?         @relation("AnomaliesTraitees", fields: [traitePar], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([produitId])
  @@index([statut])
}

// Demande d'ajustement de stock — doit être approuvée par un admin avant application
model DemandeAjustementStock {
  id               Int                      @id @default(autoincrement())
  produitId        Int
  pointDeVenteId   Int
  ancienneQuantite Int
  nouvelleQuantite Int
  justification    String
  statut           StatutDemandeAjustement  @default(EN_ATTENTE)
  source           String                   @default("ADMIN") // "ADMIN" | "MAGAZINIER"

  demandeurId           Int
  validateurId          Int?
  commentaireValidation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  produit      Produit      @relation(fields: [produitId], references: [id])
  pointDeVente PointDeVente @relation(fields: [pointDeVenteId], references: [id])
  demandeur    User         @relation("DemandesAjustement",    fields: [demandeurId],  references: [id])
  validateur   User?        @relation("ValidationsAjustement", fields: [validateurId], references: [id])

  @@index([statut])
  @@index([produitId])
  @@index([pointDeVenteId])
}

// ============================================================
// CAISSE — Grande caisse (Caissier) + Petite caisse RPV
// ============================================================

model SessionCaisse {
  id             Int                 @id @default(autoincrement())
  caissierNom    String
  caissierId     Int                 // FK déclarée ci-dessous
  pointDeVenteId Int?
  fondsCaisse    Decimal             @default(0)
  statut         StatutSessionCaisse @default(OUVERTE)
  dateOuverture  DateTime            @default(now())
  dateFermeture  DateTime?
  notes          String?

  pointDeVente   PointDeVente?    @relation(fields: [pointDeVenteId], references: [id])
  caissier       User             @relation("SessionsCaisseCaissier", fields: [caissierId], references: [id])
  operations     OperationCaisse[]
  transferts     TransfertCaisse[]
  clotures       ClotureCaisse[]
  caissesPDV     CaissePDV[]
  ventesDirectes VenteDirecte[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Petite caisse RPV — liée automatiquement à la grande caisse du caissier
model CaissePDV {
  id              Int                 @id @default(autoincrement())
  nom             String
  rpvId           Int                 // FK déclarée ci-dessous
  pointDeVenteId  Int
  sessionCaisseId Int?                // grande caisse associée
  fondsCaisse     Decimal             @default(0)
  statut          StatutSessionCaisse @default(OUVERTE)
  dateOuverture   DateTime            @default(now())
  dateFermeture   DateTime?
  notes           String?

  pointDeVente  PointDeVente   @relation(fields: [pointDeVenteId], references: [id])
  rpv           User           @relation("CaissesPDVRPV", fields: [rpvId], references: [id])
  sessionCaisse SessionCaisse? @relation(fields: [sessionCaisseId], references: [id])
  operations    OperationCaissePDV[]
  ventesDirectes VenteDirecte[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OperationCaissePDV {
  id           Int                    @id @default(autoincrement())
  caissePDVId  Int
  type         TypeOperationCaisse
  mode         ModePaiement?
  categorie    CategorieDecaissement?
  montant      Decimal
  motif        String
  reference    String                 @unique
  operateurNom String
  operateurId  Int
  createdAt    DateTime               @default(now())

  caissePDV CaissePDV @relation(fields: [caissePDVId], references: [id])
  operateur User      @relation("OperationsCaissePDV", fields: [operateurId], references: [id])
}

model OperationCaisse {
  id           Int                    @id @default(autoincrement())
  sessionId    Int
  type         TypeOperationCaisse
  mode         ModePaiement?
  categorie    CategorieDecaissement?
  montant      Decimal
  motif        String
  reference    String                 @unique
  pieceJointe  String?
  operateurNom String
  operateurId  Int
  createdAt    DateTime               @default(now())

  session   SessionCaisse @relation(fields: [sessionId], references: [id])
  operateur User          @relation("OperationsCaisse", fields: [operateurId], references: [id])
}

model TransfertCaisse {
  id           Int    @id @default(autoincrement())
  sessionId    Int
  origine      String
  destination  String
  montant      Decimal
  motif        String?
  reference    String @unique
  operateurNom String
  operateurId  Int
  createdAt    DateTime @default(now())

  session   SessionCaisse @relation(fields: [sessionId], references: [id])
  operateur User          @relation("TransfertsCaisse", fields: [operateurId], references: [id])
}

model ClotureCaisse {
  id                       Int      @id @default(autoincrement())
  date                     DateTime
  caissierNom              String
  pointDeVenteId           Int?
  totalVentes              Int
  montantTotal             Decimal
  panierMoyen              Decimal
  nbClients                Int
  notes                    String?
  sessionId                Int?
  fondsCaisse              Decimal  @default(0)
  totalEncaissementsAutres Decimal  @default(0)
  totalDecaissements       Decimal  @default(0)
  totalTransferts          Decimal  @default(0)
  soldeTheorique           Decimal  @default(0)
  soldeReel                Decimal?
  ecart                    Decimal?

  pointDeVente PointDeVente?  @relation(fields: [pointDeVenteId], references: [id])
  session      SessionCaisse? @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())

  // Une seule clôture par PDV par session (pas par date brute)
  @@unique([sessionId, pointDeVenteId])
}

// ============================================================
// VENTES DIRECTES (hors packs)
// ============================================================

model VenteDirecte {
  id        Int                @id @default(autoincrement())
  reference String             @unique
  statut    StatutVenteDirecte @default(BROUILLON)

  pointDeVenteId  Int
  vendeurId       Int           // User (RPV, agent terrain, magasinier, admin, etc.)
  modePaiement    ModePaiementVente
  montantTotal    Decimal
  montantPaye     Decimal
  monnaieRendue   Decimal       @default(0)
  montantCompteCourant Decimal  @default(0) // part réglée depuis le compte courant client (CDC §3)
  notes           String?

  // Client enregistré ou walk-in
  clientId        Int?
  clientNom       String?       // pour les clients non enregistrés
  clientTelephone String?

  // Lien crédit (optionnel — renseigné si modePaiement = CREDIT)
  creditClientId  Int?
  creditClient    CreditClient? @relation(fields: [creditClientId], references: [id])

  // Caisse associée (petite ou grande)
  caissePDVId     Int?          // petite caisse RPV
  sessionCaisseId Int?          // grande caisse caissier

  pointDeVente  PointDeVente   @relation(fields: [pointDeVenteId], references: [id])
  vendeur       User           @relation("VendeurVente", fields: [vendeurId], references: [id])
  client        Client?        @relation(fields: [clientId], references: [id])
  caissePDV     CaissePDV?     @relation(fields: [caissePDVId], references: [id])
  sessionCaisse SessionCaisse? @relation(fields: [sessionCaisseId], references: [id])
  lignes        LigneVenteDirecte[]
  factureVente  FactureVente?        @relation("VenteDirecteFacture")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([pointDeVenteId])
  @@index([vendeurId])
  @@index([creditClientId])
}

model LigneVenteDirecte {
  id           Int     @id @default(autoincrement())
  venteId      Int
  produitId    Int?    // nullable si produit hors catalogue
  produitNom   String? // nom libre saisi par l'agent si hors catalogue
  quantite     Int
  prixUnitaire Decimal
  montant      Decimal

  vente   VenteDirecte @relation(fields: [venteId], references: [id], onDelete: Cascade)
  produit Produit?     @relation(fields: [produitId], references: [id])
}

// ============================================================
// CONTRÔLE TERRAIN
// ============================================================

model VisiteControle {
  id             Int                  @id @default(autoincrement())
  reference      String               @unique
  statut         StatutVisiteControle @default(PLANIFIEE)
  controleurId   Int
  pointDeVenteId Int?                 // PDV visité (null = visite multi-sites)
  datePlanifiee  DateTime
  dateRealise    DateTime?
  objectif       String
  notes          String?

  controleur   User          @relation("ControleurVisite", fields: [controleurId], references: [id])
  pointDeVente PointDeVente? @relation(fields: [pointDeVenteId], references: [id])
  rapports     RapportControle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statut])
  @@index([controleurId])
}

model RapportControle {
  id              Int     @id @default(autoincrement())
  visiteId        Int
  titre           String
  contenu         String
  recommandations String?
  // Destinataires séparés par virgule: "ADMIN,CHEF_AGENCE"
  destinataires   String?

  visite  VisiteControle  @relation(fields: [visiteId], references: [id], onDelete: Cascade)
  alertes AlerteRapport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AlerteRapport {
  id        Int                  @id @default(autoincrement())
  rapportId Int
  niveau    NiveauAlerteControle
  message   String

  rapport   RapportControle @relation(fields: [rapportId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
}

// ============================================================
// WALLET & TRANSACTIONS
// ============================================================

model Wallet {
  id           Int     @id @default(autoincrement())
  memberId     Int     @unique
  soldeGeneral Decimal @default(0.0)
  soldeTontine Decimal @default(0.0)
  soldeCredit  Decimal @default(0.0)

  member       User               @relation(fields: [memberId], references: [id])
  transactions WalletTransaction[]
  paiements    Paiement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WalletTransaction {
  id          Int             @id @default(autoincrement())
  walletId    Int
  type        TransactionType
  montant     Decimal
  description String?
  reference   String          @unique

  wallet Wallet @relation(fields: [walletId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// FACTURES & PAIEMENTS
// ============================================================

model Facture {
  id        Int           @id @default(autoincrement())
  reference String        @unique
  memberId  Int
  montant   Decimal
  type      TypeFacture
  statut    StatutFacture

  member    User       @relation(fields: [memberId], references: [id])
  paiements Paiement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Paiement {
  id        Int          @id @default(autoincrement())
  factureId Int
  walletId  Int
  montant   Decimal
  type      TypePaiement
  reference String       @unique
  createdAt DateTime     @default(now())

  facture Facture @relation(fields: [factureId], references: [id])
  wallet  Wallet  @relation(fields: [walletId], references: [id])
}

// ============================================================
// PACKS AfriSime
// ============================================================

model Pack {
  id                 Int                @id @default(autoincrement())
  nom                String
  type               TypePack
  description        String?
  actif              Boolean            @default(true)
  dureeJours         Int?
  frequenceVersement FrequenceVersement @default(HEBDOMADAIRE)
  montantVersement   Decimal?
  formuleRevendeur   FormuleRevendeur?
  montantCredit      Decimal?
  montantSeuil       Decimal?
  produitCibleId     Int?
  produitCible       Produit?           @relation("PackProduitCible", fields: [produitCibleId], references: [id])
  bonusPourcentage   Decimal?
  cyclesBonusTrigger Int?
  acomptePercent     Decimal?
  pointsParTranche   Int?
  montantTranche     Decimal?

  souscriptions SouscriptionPack[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
  
model SouscriptionPack {
  id                 Int                 @id @default(autoincrement())
  packId             Int
  pack               Pack                @relation(fields: [packId], references: [id])
  userId             Int?
  user               User?               @relation(fields: [userId], references: [id])
  clientId           Int?
  client             Client?             @relation(fields: [clientId], references: [id])
  statut             StatutSouscription  @default(EN_ATTENTE)
  formuleRevendeur   FormuleRevendeur?
  frequenceVersement FrequenceVersement?
  dateDebut          DateTime            @default(now())
  dateFin            DateTime?   
  dateCloture        DateTime?
  montantTotal       Decimal
  montantVerse       Decimal             @default(0)
  montantRestant     Decimal
  numeroCycle        Int                 @default(1)
  bonusObtenu        Boolean             @default(false)
  notes              String?
  enregistrePar      String?

  versements     VersementPack[]
  echeances      EcheancePack[]
  receptions     ReceptionProduitPack[]
  lignesCollecte LigneCollecte[]
  lignesProduits LigneSouscriptionProduit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VersementPack {
  id             Int                 @id @default(autoincrement())
  souscriptionId Int
  souscription   SouscriptionPack    @relation(fields: [souscriptionId], references: [id])
  type           TypeVersement
  montant        Decimal
  statut         StatutVersementPack @default(PAYE)
  datePrevue     DateTime?
  datePaiement   DateTime            @default(now())
  reference      String?             @unique
  notes          String?
  encaisseParId  Int?
  encaisseParNom String?

  ligneCollecte  LigneCollecte?  // relation inverse (1 versement ↔ 1 ligne collecte max)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EcheancePack {
  id             Int                 @id @default(autoincrement())
  souscriptionId Int
  souscription   SouscriptionPack    @relation(fields: [souscriptionId], references: [id])
  numero         Int
  montant        Decimal
  datePrevue     DateTime
  datePaiement   DateTime?
  statut         StatutVersementPack @default(EN_ATTENTE)
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([souscriptionId, numero])
}

model ReceptionProduitPack {
  id             Int                 @id @default(autoincrement())
  souscriptionId Int
  souscription   SouscriptionPack    @relation(fields: [souscriptionId], references: [id])
  statut         StatutReceptionPack @default(PLANIFIEE)
  datePrevisionnelle DateTime
  dateLivraison  DateTime?
  livreurNom     String?
  notes          String?

  // PDV cible : détermine quel magasinier doit confirmer la sortie stock
  pointDeVenteId Int?
  pointDeVente   PointDeVente? @relation(fields: [pointDeVenteId], references: [id])

  lignes        LigneReceptionPack[]
  facturesVente FactureVente[]       @relation("ReceptionPackFactures")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pointDeVenteId])
}

model LigneReceptionPack {
  id           Int                  @id @default(autoincrement())
  receptionId  Int
  reception    ReceptionProduitPack @relation(fields: [receptionId], references: [id], onDelete: Cascade)
  produitId    Int
  produit      Produit              @relation(fields: [produitId], references: [id])
  quantite     Int
  prixUnitaire Decimal
}

// ============================================================
// LIGNES PRODUITS SOUSCRIPTION
// ============================================================

model LigneSouscriptionProduit {
  id             Int              @id @default(autoincrement())
  souscriptionId Int
  souscription   SouscriptionPack @relation(fields: [souscriptionId], references: [id], onDelete: Cascade)

  // Produit lié (null si nouveau produit non encore créé dans le catalogue)
  produitId      Int?
  produit        Produit?         @relation("LigneProduitDemande", fields: [produitId], references: [id])

  // Saisie libre — toujours renseignée pour traçabilité
  produitNomSaisi  String
  categorieSaisie  String?
  uniteSaisie      String?

  quantite         Int
  quantiteParCycle Int?     // pour packs récurrents : qté à chaque cycle
  prixEstime       Decimal? // estimation agent terrain

  statut            StatutLigneSouscription @default(EN_ATTENTE)
  estNouveauProduit Boolean                @default(false)

  // PDV cible — dénormalisé depuis client.pointDeVenteId pour les agrégations logistique
  // (évite une double jointure souscription → client → pdv à chaque requête prévision)
  pointDeVenteId Int?
  pointDeVente   PointDeVente? @relation(fields: [pointDeVenteId], references: [id])

  // Traitement admin
  notes              String?
  produitSubstitutId Int?
  produitSubstitut   Produit? @relation("LigneProduitSubstitut", fields: [produitSubstitutId], references: [id])
  traiteParId        Int?
  traitePar          User?    @relation("LignesTraitees", fields: [traiteParId], references: [id])
  dateTraitement     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([souscriptionId])
  @@index([statut])
  @@index([pointDeVenteId, statut]) // index composite pour les agrégations prévisions
}

// ============================================================
// FIDÉLITÉ
// ============================================================

model PointsFidelite {
  id           Int  @id @default(autoincrement())
  solde        Int  @default(0)
  totalGagne   Int  @default(0)
  totalUtilise Int  @default(0)
  userId       Int? @unique
  clientId     Int? @unique

  user     User?   @relation(fields: [userId], references: [id])
  client   Client? @relation(fields: [clientId], references: [id])

  mouvements   MouvementPoints[]
  utilisations UtilisationRecompense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MouvementPoints {
  id               Int                 @id @default(autoincrement())
  pointsFideliteId Int
  pointsFidelite   PointsFidelite      @relation(fields: [pointsFideliteId], references: [id])
  type             TypeMouvementPoints
  points           Int
  description      String?
  referenceId      Int?
  referenceType    String?

  createdAt DateTime @default(now())
}

model RecompenseFidelite {
  id             Int            @id @default(autoincrement())
  nom            String
  description    String?
  type           TypeRecompense
  coutPoints     Int
  valeur         Decimal?
  produitId      Int?
  produit        Produit?       @relation(fields: [produitId], references: [id])
  actif          Boolean        @default(true)
  dateExpiration DateTime?

  utilisations UtilisationRecompense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}  

model UtilisationRecompense {
  id               Int              @id @default(autoincrement())
  recompenseId     Int
  recompense       RecompenseFidelite @relation(fields: [recompenseId], references: [id])
  pointsFideliteId Int
  pointsFidelite   PointsFidelite   @relation(fields: [pointsFideliteId], references: [id])
  pointsUtilises   Int
  statut           StatutRecompense @default(DISPONIBLE)
  dateUtilisation  DateTime?
  notes            String?

  createdAt DateTime @default(now())
}

// ============================================================
// MESSAGERIE
// ============================================================

model Message {
