// ============================================================
// PIÈCES JUSTIFICATIVES
// ============================================================

model PieceJustificative {
  id             Int      @id @default(autoincrement())
  nom            String
  url            String
  uploadthingKey String
  type           String
  taille         Int
  // Association polymorphique
  sourceType     String   // VERSEMENT_PACK | OPERATION_CAISSE | MOUVEMENT_STOCK | CLOTURE_COMPTABLE | RECEPTION_APPRO | TRANSFERT_STOCK
  sourceId       Int
