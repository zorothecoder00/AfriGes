model ConfigBeneficeRIA {
  id               Int     @id @default(autoincrement())
  tauxGenere       Decimal @default(10)
  tauxDistribue    Decimal @default(4)
  tauxReinvesti    Decimal @default(4)
  tauxFondSecurite Decimal @default(2)
